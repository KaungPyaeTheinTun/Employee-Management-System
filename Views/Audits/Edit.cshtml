@model EmployeesManagement.Models.Audit

@{
    ViewData["Title"] = "Edit Audit Log";
    
    var auditTypeColors = new Dictionary<string, (string bg, string text)>
    {
        ["Create"] = ("#e8f5ee", "#1a7a4a"),
        ["Update"] = ("#fef3e0", "#a05c00"),
        ["Delete"] = ("#fdecea", "#c0392b"),
    };
    
    var currentAuditType = Model.AuditType ?? "Update";
    var (typeBg, typeText) = auditTypeColors.ContainsKey(currentAuditType) ? auditTypeColors[currentAuditType] : ("#f2f2ef", "#3a3a38");
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Edit Audit Log</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Audit Logs</a></li>
            <li class="breadcrumb-item active">Edit #@Model.Id</li>
        </ol>
    </div>
    <a asp-action="Index" class="btn-ghost">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px">
            <path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Back to List
    </a>
</div>

<!-- Warning Alert -->
<div style="background:#fef3e0;border:1px solid rgba(160,92,0,0.2);border-radius:9px;padding:16px;margin-bottom:20px;display:flex;gap:12px;align-items:center">
    <div style="width:32px;height:32px;border-radius:32px;background:rgba(160,92,0,0.1);color:#a05c00;display:flex;align-items:center;justify-content:center">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <circle cx="9" cy="9" r="7.5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M9 5v5M9 13v-1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
    </div>
    <div>
        <div style="font-weight:600;margin-bottom:2px">Warning: Editing Audit Logs</div>
        <div style="font-size:13px;color:var(--ink2)">Audit logs are system-generated records. Modifying them may affect audit trail integrity. Please proceed with caution.</div>
    </div>
</div>

<form asp-action="Edit">
    <div asp-validation-summary="ModelOnly" class="field-error" style="padding:12px 16px;background:var(--red-bg);border-radius:9px;border:1px solid rgba(192,57,43,0.2);margin-bottom:20px;"></div>
    
    <input type="hidden" asp-for="Id" />

    <div class="detail-grid" style="grid-template-columns:1fr 2fr">
        <!-- Left: Summary Card -->
        <div>
            <div class="profile-card">
                <div class="profile-card-top" style="background:var(--bg2)">
                    <div class="profile-avatar-lg" style="background:@typeBg;color:@typeText;font-size:32px;">
                        @(currentAuditType.Substring(0, 1))
                    </div>
                    <div class="profile-name">Audit #@Model.Id</div>
                    <div class="profile-role">
                        <span class="status-badge" style="background:@typeBg;color:@typeText">@currentAuditType</span>
                    </div>
                </div>
                <div class="profile-card-body">
                    <div class="info-row">
                        <div class="info-icon">📊</div>
                        <div>
                            <div class="info-label">TABLE</div>
                            <div class="info-value">@Model.TableName</div>
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-icon">🔑</div>
                        <div>
                            <div class="info-label">PRIMARY KEY</div>
                            <div class="info-value" style="font-family:monospace">@Model.PrimaryKey</div>
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-icon">📅</div>
                        <div>
                            <div class="info-label">TIMESTAMP</div>
                            <div class="info-value">@Model.DateTime.ToString("dd MMM yyyy, HH:mm:ss")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Edit Form -->
        <div class="form-card">
            <div class="form-card-header">
                <span class="section-badge blue">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                        <path d="M9.5 2.5l2 2-7 7H2.5v-2l7-7z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" fill="none"/>
                    </svg>
                    Edit Audit Details
                </span>
            </div>
            <div class="form-card-body">
                <div class="row g-3">
                    <!-- User ID -->
                    <div class="col-md-12">
                        <label asp-for="UserId" class="field-label">User ID</label>
                        <input asp-for="UserId" class="field-control" placeholder="Enter user ID" />
                        <span asp-validation-for="UserId" class="field-error"></span>
                    </div>

                    <!-- Audit Type -->
                    <div class="col-md-12">
                        <label asp-for="AuditType" class="field-label">Audit Type</label>
                        <select asp-for="AuditType" class="field-control">
                            <option value="Create">Create</option>
                            <option value="Update">Update</option>
                            <option value="Delete">Delete</option>
                        </select>
                        <span asp-validation-for="AuditType" class="field-error"></span>
                    </div>

                    <!-- Table Name -->
                    <div class="col-md-12">
                        <label asp-for="TableName" class="field-label">Table Name</label>
                        <input asp-for="TableName" class="field-control" placeholder="Enter table name" />
                        <span asp-validation-for="TableName" class="field-error"></span>
                    </div>

                    <!-- DateTime -->
                    <div class="col-md-12">
                        <label asp-for="DateTime" class="field-label">Date & Time</label>
                        <input asp-for="DateTime" class="field-control" type="datetime-local" value="@Model.DateTime.ToString("yyyy-MM-ddTHH:mm:ss")" />
                        <span asp-validation-for="DateTime" class="field-error"></span>
                    </div>

                    <!-- Primary Key -->
                    <div class="col-md-12">
                        <label asp-for="PrimaryKey" class="field-label">Primary Key</label>
                        <input asp-for="PrimaryKey" class="field-control" placeholder="Enter primary key value" />
                        <span asp-validation-for="PrimaryKey" class="field-error"></span>
                    </div>

                    <!-- Old Values (JSON) -->
                    <div class="col-md-12">
                        <label asp-for="OldValues" class="field-label">Old Values (JSON)</label>
                        <textarea asp-for="OldValues" class="field-control" rows="4" placeholder="Enter old values as JSON"></textarea>
                        <span asp-validation-for="OldValues" class="field-error"></span>
                    </div>

                    <!-- New Values (JSON) -->
                    <div class="col-md-12">
                        <label asp-for="NewValues" class="field-label">New Values (JSON)</label>
                        <textarea asp-for="NewValues" class="field-control" rows="4" placeholder="Enter new values as JSON"></textarea>
                        <span asp-validation-for="NewValues" class="field-error"></span>
                    </div>

                    <!-- Affected Columns -->
                    <div class="col-md-12">
                        <label asp-for="AffectedColumns" class="field-label">Affected Columns</label>
                        <input asp-for="AffectedColumns" class="field-control" placeholder="Comma-separated column names" />
                        <span class="field-hint">Separate multiple columns with commas</span>
                        <span asp-validation-for="AffectedColumns" class="field-error"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Form Actions -->
    <div class="form-actions" style="margin-top:20px">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn-ghost">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px">
                <circle cx="7" cy="7" r="2.5" fill="currentColor"/>
                <path d="M1 7C2.5 3.5 4.5 2 7 2s4.5 1.5 6 5c-1.5 3.5-3.5 5-6 5S2.5 10.5 1 7z" stroke="currentColor" stroke-width="1.2" fill="none"/>
            </svg>
            View Details
        </a>
        <a asp-action="Index" class="btn-ghost">Cancel</a>
        <button type="submit" class="btn-primary">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px;vertical-align:-2px">
                <path d="M2 7l3.5 3.5L12 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Save Changes
        </button>
    </div>
</form>

<style>
    /* Form field styles */
    .field-label {
        display: block;
        font-size: 12px;
        font-weight: 500;
        color: var(--ink2);
        margin-bottom: 6px;
    }

    .field-control {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 13px;
        color: var(--ink1);
        background: var(--card-bg);
        transition: all 0.15s;
        font-family: 'SF Mono', 'Monaco', 'Menlo', 'Courier New', monospace;
    }

    .field-control:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(26, 79, 160, 0.1);
    }

    .field-control[readonly] {
        background: var(--bg2);
        cursor: not-allowed;
        opacity: 0.8;
    }

    select.field-control {
        appearance: none;
        background-image: url("data:image/svg+xml,%3Csvg width='12' height='12' viewBox='0 0 12 12' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M2 4L6 8L10 4' stroke='%23666' stroke-width='1.2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-position: right 12px center;
        padding-right: 32px;
    }

    textarea.field-control {
        resize: vertical;
        min-height: 80px;
    }

    .field-error {
        font-size: 11px;
        color: #c0392b;
        margin-top: 4px;
        display: block;
    }

    .field-hint {
        font-size: 11px;
        color: var(--ink3);
        margin-top: 4px;
        display: block;
    }

    /* Form card styles */
    .form-card {
        background: var(--card-bg);
        border-radius: 12px;
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .form-card-header {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        background: var(--bg2);
    }

    .form-card-body {
        padding: 20px;
    }

    .section-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
    }

    .section-badge.blue {
        background: #e8eefa;
        color: #1a4fa0;
    }

    /* Profile card styles */
    .profile-card {
        background: var(--card-bg);
        border-radius: 12px;
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .profile-card-top {
        padding: 24px 20px;
        text-align: center;
        background: var(--bg2);
        border-bottom: 1px solid var(--border);
    }

    .profile-avatar-lg {
        width: 80px;
        height: 80px;
        border-radius: 80px;
        margin: 0 auto 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 32px;
    }

    .profile-name {
        font-weight: 600;
        font-size: 16px;
        color: var(--ink1);
        margin-bottom: 6px;
    }

    .profile-role {
        font-size: 12px;
        color: var(--ink3);
    }

    .profile-card-body {
        padding: 20px;
    }

    .info-row {
        display: flex;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid var(--border);
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-icon {
        width: 24px;
        height: 24px;
        background: var(--bg2);
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
    }

    .info-label {
        font-size: 10px;
        color: var(--ink4);
        text-transform: uppercase;
        letter-spacing: 0.3px;
        margin-bottom: 2px;
    }

    .info-value {
        font-size: 13px;
        color: var(--ink1);
        font-weight: 500;
    }

    .status-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
    }

    /* Button styles */
    .btn-primary {
        display: inline-flex;
        align-items: center;
        padding: 10px 20px;
        background: var(--primary);
        color: white;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        border: none;
        cursor: pointer;
        transition: all 0.15s;
        text-decoration: none;
    }

    .btn-primary:hover {
        background: #134080;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(26, 79, 160, 0.2);
        color: white;
        text-decoration: none;
    }

    .btn-ghost {
        display: inline-flex;
        align-items: center;
        padding: 10px 20px;
        background: var(--bg2);
        color: var(--ink2);
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-ghost:hover {
        background: var(--border);
        color: var(--ink1);
        text-decoration: none;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        padding: 20px 0;
        border-top: 1px solid var(--border);
        margin-top: 20px;
    }

    /* Grid system */
    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 20px;
    }

    .row {
        display: flex;
        flex-wrap: wrap;
        margin: -8px;
    }

    .g-3 {
        margin: -8px;
    }

    .g-3 > [class*="col-"] {
        padding: 8px;
    }

    .col-md-12 {
        flex: 0 0 100%;
        max-width: 100%;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .detail-grid {
            grid-template-columns: 1fr;
        }
        
        .form-actions {
            flex-direction: column-reverse;
        }
        
        .btn-primary,
        .btn-ghost {
            width: 100%;
            justify-content: center;
        }
        
        .profile-avatar-lg {
            width: 60px;
            height: 60px;
            font-size: 24px !important;
        }
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}