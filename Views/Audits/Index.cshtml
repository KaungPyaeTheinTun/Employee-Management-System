@model IEnumerable<EmployeesManagement.Models.Audit>

@{
    ViewData["Title"] = "Audit Logs";
    
    var auditTypeColors = new Dictionary<string, (string bg, string text)>
    {
        ["Create"] = ("#e8f5ee", "#1a7a4a"),
        ["Update"] = ("#fef3e0", "#a05c00"),
        ["Delete"] = ("#fdecea", "#c0392b"),
    };
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Audit Logs</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item active">Audit Logs</li>
        </ol>
    </div>
</div>

<div class="table-card">
    <!-- Toolbar -->
    <div class="table-toolbar">
        <span class="table-title">System Audit Trail</span>

        <div class="filter-chips">
            <div class="chip filter-chip active" data-filter="all">All <span style="opacity:.5;margin-left:2px">@Model.Count()</span></div>
            <div class="chip filter-chip" data-filter="create">Create</div>
            <div class="chip filter-chip" data-filter="update">Update</div>
            <div class="chip filter-chip" data-filter="delete">Delete</div>
        </div>

        <div class="table-search">
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
                <circle cx="5.5" cy="5.5" r="4.5" stroke="currentColor" stroke-width="1.2" />
                <path d="M9 9L12 12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
            </svg>
            <input id="tableSearch" type="text" placeholder="Search user, table, action..." />
        </div>

        <!-- Items per page selector -->
        <div class="items-per-page">
            <select id="itemsPerPage" class="per-page-select">
                <option value="10">10 per page</option>
                <option value="25">25 per page</option>
                <option value="50">50 per page</option>
                <option value="100">100 per page</option>
            </select>
        </div>
    </div>

    <!-- Desktop table -->
    <div class="table-wrap">
        <table class="emp-table" id="auditTable">
            <thead>
                <tr>
                    <th data-sort="0">USER</th>
                    <th data-sort="1">ACTION</th>
                    <th data-sort="2">TABLE</th>
                    <th data-sort="3">DATE & TIME</th>
                    <th data-sort="4">RECORD ID</th>
                    <th data-sort="5">CHANGES</th>
                    <th>ACTIONS</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @{
                    var avatarColors = new[] {
                        ("#e8eefa","#1a4fa0"), ("#e8f5ee","#1a7a4a"), ("#fef3e0","#a05c00"),
                        ("#fdecea","#c0392b"), ("#f2f2ef","#3a3a38"), ("#f0eeff","#4a35c0")
                    };
                    int colorIdx = 0;
                }
                @foreach (var item in Model)
                {
                    var (bg, tc) = avatarColors[colorIdx++ % avatarColors.Length];
                    var userInitials = "?";


                    var auditTypeKey = item.AuditType ?? "Update";
                    var (typeBg, typeText) = auditTypeColors.ContainsKey(auditTypeKey) ? auditTypeColors[auditTypeKey] : ("#f2f2ef", "#3a3a38");

                    <tr data-id="@item.Id" data-audit-type="@item.AuditType?.ToLower()">
                        <td>
                                <div>
                                    <div class="emp-id">@item.UserId</div>
                                </div>
                        </td>
                        <td>
                            <span class="status-badge" style="background:@typeBg;color:@typeText">@item.AuditType</span>
                        </td>
                        <td>
                            <span class="dept-badge" style="background:@bg;color:@tc">@item.TableName</span>
                        </td>
                        <td>
                            <div style="display:flex;flex-direction:column;gap:2px">
                                <span class="date-badge">@item.DateTime.ToString("MMM dd, yyyy")</span>
                                <span style="font-size:10px;color:var(--ink4);">@item.DateTime.ToString("HH:mm:ss")</span>
                            </div>
                        </td>
                        <td>
                            <span class="mono" style="font-size:12px;color:var(--ink3)">@item.PrimaryKey</span>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.OldValues) || !string.IsNullOrEmpty(item.NewValues))
                            {
                                <div class="audit-changes">
                                    @if (!string.IsNullOrEmpty(item.OldValues))
                                    {
                                        <div class="audit-badge old" title="Old Values">
                                            <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                                                <circle cx="5" cy="5" r="4" stroke="currentColor" stroke-width="1.2"/>
                                                <path d="M5 2v3l2 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                                            </svg>
                                            Old
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(item.NewValues))
                                    {
                                        <div class="audit-badge new" title="New Values">
                                            <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                                                <circle cx="5" cy="5" r="4" stroke="currentColor" stroke-width="1.2"/>
                                                <path d="M5 8V5L3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                                            </svg>
                                            New
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(item.AffectedColumns))
                                    {
                                        <span class="affected-columns" title="Affected Columns">@item.AffectedColumns</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span style="color:var(--ink4);font-size:11px">No changes</span>
                            }
                        </td>
                        <td>
                            <div class="action-group">
                                <a class="action-btn" asp-action="Details" asp-route-id="@item.Id" title="View Details">
                                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                        <circle cx="7" cy="7" r="2.5" fill="currentColor" />
                                        <path d="M1 7C2.5 3.5 4.5 2 7 2s4.5 1.5 6 5c-1.5 3.5-3.5 5-6 5S2.5 10.5 1 7z" stroke="currentColor" stroke-width="1.2" fill="none" />
                                    </svg>
                                </a>
                                <a class="action-btn" asp-action="Edit" asp-route-id="@item.Id" title="Edit">
                                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                        <path d="M9.5 2.5l2 2-7 7H2.5v-2l7-7z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" fill="none"/>
                                    </svg>
                                </a>
                                 <a class="action-btn del" asp-action="Delete" asp-route-id="@item.Id" title="Delete">
                                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                        <path d="M2 4h10M5 4V2.5h4V4M11 4l-.75 8H3.75L3 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                                    </svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Mobile cards (injected by JS) -->
        <div id="mobileAuditCards" class="mobile-emp-cards"></div>
    </div>

    <!-- Pagination -->
    <div class="table-pagination">
        <span class="pagination-info" id="paginationInfo"></span>
        <div class="pagination-controls" id="tablePagination">
            <button class="pagination-btn" id="prevPage" disabled>Previous</button>
            <div class="page-numbers" id="pageNumbers"></div>
            <button class="pagination-btn" id="nextPage">Next</button>
        </div>
    </div>
</div>

<style>
    /* Audit-specific styles */
    .status-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
    }

    .dept-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
    }

    .date-badge {
        background: var(--bg2);
        padding: 4px 8px;
        border-radius: 20px;
        font-size: 11px;
        color: var(--ink3);
        white-space: nowrap;
        display: inline-block;
    }

    .mono {
        font-family: monospace;
        font-size: 12px;
    }

    .emp-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .emp-avatar {
        width: 32px;
        height: 32px;
        border-radius: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 13px;
        flex-shrink: 0;
    }

    .emp-name {
        font-weight: 500;
        font-size: 13px;
        color: var(--ink1);
    }

    .emp-id {
        font-size: 11px;
        color: var(--ink3);
        margin-top: 2px;
    }

    .audit-changes {
        display: flex;
        align-items: center;
        gap: 6px;
        flex-wrap: wrap;
    }

    .audit-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 2px 8px;
        border-radius: 16px;
        font-size: 10px;
        font-weight: 500;
        cursor: help;
    }

    .audit-badge.old {
        background: #fdecea;
        color: #c0392b;
    }

    .audit-badge.new {
        background: #e8f5ee;
        color: #1a7a4a;
    }

    .affected-columns {
        font-size: 10px;
        color: var(--ink3);
        background: var(--bg2);
        padding: 2px 8px;
        border-radius: 16px;
        cursor: help;
        max-width: 150px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* Pagination styles */
    .table-pagination {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px;
        border-top: 1px solid var(--border);
        flex-wrap: wrap;
        gap: 12px;
    }

    .pagination-info {
        font-size: 12px;
        color: var(--ink3);
    }

    .pagination-controls {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .pagination-btn {
        padding: 6px 12px;
        border: 1px solid var(--border);
        background: var(--card-bg);
        border-radius: 6px;
        font-size: 12px;
        color: var(--ink2);
        cursor: pointer;
        transition: all 0.2s;
    }

    .pagination-btn:hover:not(:disabled) {
        background: var(--bg2);
        border-color: var(--primary);
        color: var(--primary);
    }

    .pagination-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .page-numbers {
        display: flex;
        gap: 4px;
    }

    .page-number {
        min-width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--border);
        background: var(--card-bg);
        border-radius: 6px;
        font-size: 12px;
        color: var(--ink2);
        cursor: pointer;
        transition: all 0.2s;
    }

    .page-number:hover {
        background: var(--bg2);
        border-color: var(--primary);
        color: var(--primary);
    }

    .page-number.active {
        background: var(--primary);
        border-color: var(--primary);
        color: white;
    }

    /* Items per page selector */
    .items-per-page {
        margin-left: auto;
    }

    .per-page-select {
        padding: 6px 10px;
        border: 1px solid var(--border);
        border-radius: 6px;
        font-size: 12px;
        color: var(--ink2);
        background: var(--card-bg);
        cursor: pointer;
    }

    .per-page-select:hover {
        border-color: var(--primary);
    }

    /* Action buttons */
        .action-group {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .action-btn {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        color: var(--ink2);
        background: var(--bg2);
        transition: all 0.15s;
    }

    .action-btn:hover {
        background: var(--primary);
        color: white;
    }

    .action-btn.del:hover {
        background: #c0392b;
        color: white;
    }

    /* Mobile card styles */
    .mobile-emp-card {
        background: var(--card-bg);
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
        border: 1px solid var(--border);
    }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .emp-table th:nth-child(2),
        .emp-table td:nth-child(2),
        .emp-table th:nth-child(3),
        .emp-table td:nth-child(3),
        .emp-table th:nth-child(4),
        .emp-table td:nth-child(4),
        .emp-table th:nth-child(5),
        .emp-table td:nth-child(5) {
            display: none; /* Hide Action, Table, Date/Time, Record ID on mobile */
        }

        .emp-table th:first-child,
        .emp-table td:first-child,
        .emp-table th:nth-child(6),
        .emp-table td:nth-child(6),
        .emp-table th:last-child,
        .emp-table td:last-child {
            display: table-cell;
        }

        .table-pagination {
            flex-direction: column;
            align-items: flex-start;
        }

        .pagination-controls {
            width: 100%;
            justify-content: center;
        }

        .items-per-page {
            margin-left: 0;
            width: 100%;
        }

        .per-page-select {
            width: 100%;
        }
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
    // Get DOM elements
    const searchInput = document.getElementById('tableSearch');
    const table = document.getElementById('auditTable');
    const tableBody = document.getElementById('tableBody');
    const rows = Array.from(tableBody.querySelectorAll('tr'));
    const mobileContainer = document.getElementById('mobileAuditCards');
    const filterChips = document.querySelectorAll('.filter-chip');
    const itemsPerPageSelect = document.getElementById('itemsPerPage');
    const prevBtn = document.getElementById('prevPage');
    const nextBtn = document.getElementById('nextPage');
    const pageNumbersDiv = document.getElementById('pageNumbers');
    const paginationInfo = document.getElementById('paginationInfo');

    // Pagination state
    let currentPage = 1;
    let itemsPerPage = 10;
    let filteredRows = rows;
    let totalPages = 1;
    let currentAuditTypeFilter = 'all';

    // Initialize
    function init() {
        itemsPerPage = parseInt(itemsPerPageSelect.value);
        filterRows();
        updatePagination();
        renderCurrentPage();
        toggleMobileView();
    }

    // Filter rows based on search and audit type
    function filterRows() {
        const searchTerm = searchInput.value.toLowerCase();

        filteredRows = rows.filter(row => {
            const userName = row.querySelector('.emp-name')?.textContent.toLowerCase() || '';
            const userId = row.querySelector('.emp-id')?.textContent.toLowerCase() || '';
            const auditType = row.querySelector('.status-badge')?.textContent.toLowerCase() || '';
            const tableName = row.querySelector('.dept-badge')?.textContent.toLowerCase() || '';
            const recordId = row.querySelector('td:nth-child(5) .mono')?.textContent.toLowerCase() || '';

            const matchesSearch = !searchTerm ||
                userName.includes(searchTerm) ||
                userId.includes(searchTerm) ||
                auditType.includes(searchTerm) ||
                tableName.includes(searchTerm) ||
                recordId.includes(searchTerm);

            const matchesFilter = currentAuditTypeFilter === 'all' || auditType.includes(currentAuditTypeFilter);

            return matchesSearch && matchesFilter;
        });

        totalPages = Math.ceil(filteredRows.length / itemsPerPage);
        if (currentPage > totalPages) currentPage = totalPages || 1;
    }

    // Render current page
    function renderCurrentPage() {
        const start = (currentPage - 1) * itemsPerPage;
        const end = start + itemsPerPage;
        const pageRows = filteredRows.slice(start, end);

        // Hide all rows first
        rows.forEach(row => row.style.display = 'none');

        // Show only current page rows
        pageRows.forEach(row => row.style.display = '');

        // Update mobile cards
        generateMobileCards(pageRows);

        // Update pagination info
        updatePaginationInfo();
    }

    // Update pagination controls
    function updatePagination() {
        // Update button states
        prevBtn.disabled = currentPage === 1;
        nextBtn.disabled = currentPage === totalPages || totalPages === 0;

        // Generate page numbers
        generatePageNumbers();
    }

    // Generate page number buttons
    function generatePageNumbers() {
        pageNumbersDiv.innerHTML = '';

        if (totalPages <= 7) {
            // Show all pages
            for (let i = 1; i <= totalPages; i++) {
                addPageButton(i);
            }
        } else {
            // Show first page
            addPageButton(1);

            if (currentPage > 3) {
                addEllipsis();
            }

            // Show pages around current page
            let start = Math.max(2, currentPage - 1);
            let end = Math.min(totalPages - 1, currentPage + 1);

            for (let i = start; i <= end; i++) {
                addPageButton(i);
            }

            if (currentPage < totalPages - 2) {
                addEllipsis();
            }

            // Show last page
            addPageButton(totalPages);
        }
    }

    function addPageButton(pageNum) {
        const btn = document.createElement('button');
        btn.className = `page-number ${pageNum === currentPage ? 'active' : ''}`;
        btn.textContent = pageNum;
        btn.addEventListener('click', () => {
            currentPage = pageNum;
            renderCurrentPage();
            updatePagination();
        });
        pageNumbersDiv.appendChild(btn);
    }

    function addEllipsis() {
        const span = document.createElement('span');
        span.className = 'page-number';
        span.textContent = '...';
        span.style.cursor = 'default';
        pageNumbersDiv.appendChild(span);
    }

    // Update pagination info text
    function updatePaginationInfo() {
        const start = filteredRows.length ? (currentPage - 1) * itemsPerPage + 1 : 0;
        const end = Math.min(currentPage * itemsPerPage, filteredRows.length);
        paginationInfo.textContent = `Showing ${start}-${end} of ${filteredRows.length} audit logs`;

        // Update the total count in the "All" filter chip
        const allChip = document.querySelector('.filter-chip[data-filter="all"]');
        if (allChip) {
            const countSpan = allChip.querySelector('span');
            if (countSpan) {
                countSpan.textContent = rows.length;
            }
        }
    }

    // Generate mobile cards
    function generateMobileCards(pageRows) {
        if (!mobileContainer) return;

        mobileContainer.innerHTML = '';

        pageRows.forEach(row => {
            // Extract data with fallbacks
            const userName = row.querySelector('.emp-name')?.textContent || 'Unknown';
            const userId = row.querySelector('.emp-id')?.textContent || '';
            const avatar = row.querySelector('.emp-avatar');
            const avatarBg = avatar?.style.backgroundColor || '#e8eefa';
            const avatarColor = avatar?.style.color || '#1a4fa0';
            const avatarText = avatar?.textContent || '?';

            const auditType = row.querySelector('.status-badge')?.textContent || 'Update';
            const auditTypeBg = row.querySelector('.status-badge')?.style.backgroundColor || '#f2f2ef';
            const auditTypeColor = row.querySelector('.status-badge')?.style.color || '#3a3a38';

            const tableName = row.querySelector('.dept-badge')?.textContent || '—';
            const tableBg = row.querySelector('.dept-badge')?.style.backgroundColor || avatarBg;
            const tableColor = row.querySelector('.dept-badge')?.style.color || avatarColor;

            const date = row.querySelector('.date-badge')?.textContent || '—';
            const time = row.querySelector('td:nth-child(4) span:last-child')?.textContent || '—';
            const recordId = row.querySelector('td:nth-child(5) .mono')?.textContent || '—';

            const hasOld = row.querySelector('.audit-badge.old') !== null;
            const hasNew = row.querySelector('.audit-badge.new') !== null;
            const affectedColumns = row.querySelector('.affected-columns')?.textContent || '';

            const detailsLink = row.querySelector('.action-btn[title="View Details"]')?.href || '#';

            const card = document.createElement('div');
            card.className = 'mobile-emp-card';
            card.innerHTML = `
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px">
                    <div class="emp-avatar" style="background:${avatarBg};color:${avatarColor}">${avatarText}</div>
                    <div style="flex:1">
                        <div class="emp-name" style="font-weight:600;margin-bottom:2px">${userName}</div>
                        <div class="emp-id">${userId}</div>
                    </div>
                    <span class="status-badge" style="background:${auditTypeBg};color:${auditTypeColor}">${auditType}</span>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px">
                    <div>
                        <div style="font-size:10px;color:var(--ink3);margin-bottom:2px">TABLE</div>
                        <span class="dept-badge" style="background:${tableBg};color:${tableColor}">${tableName}</span>
                    </div>
                    <div>
                        <div style="font-size:10px;color:var(--ink3);margin-bottom:2px">RECORD ID</div>
                        <div style="font-size:12px;font-family:monospace">${recordId}</div>
                    </div>
                </div>

                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
                    <div>
                        <div style="font-size:10px;color:var(--ink3);margin-bottom:2px">DATE & TIME</div>
                        <div style="font-size:12px">${date} at ${time}</div>
                    </div>
                    ${hasOld || hasNew ? `
                        <div style="display:flex;gap:4px">
                            ${hasOld ? '<span class="audit-badge old">Old</span>' : ''}
                            ${hasNew ? '<span class="audit-badge new">New</span>' : ''}
                        </div>
                    ` : ''}
                </div>

                ${affectedColumns ? `
                    <div style="margin-bottom:12px">
                        <div style="font-size:10px;color:var(--ink3);margin-bottom:4px">AFFECTED COLUMNS</div>
                        <div style="font-size:11px;background:var(--bg2);padding:8px;border-radius:6px">${affectedColumns}</div>
                    </div>
                ` : ''}

                <div class="action-group" style="justify-content:flex-end">
                    <a class="action-btn" href="${detailsLink}" title="View Details">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                            <circle cx="7" cy="7" r="2.5" fill="currentColor"/>
                            <path d="M1 7C2.5 3.5 4.5 2 7 2s4.5 1.5 6 5c-1.5 3.5-3.5 5-6 5S2.5 10.5 1 7z" stroke="currentColor" stroke-width="1.2" fill="none"/>
                        </svg>
                    </a>
                </div>
            `;
            mobileContainer.appendChild(card);
        });
    }

    // Toggle mobile/desktop view
    function toggleMobileView() {
        if (!mobileContainer) return;

        if (window.innerWidth <= 768) {
            mobileContainer.style.display = 'block';
        } else {
            mobileContainer.style.display = 'none';
        }
    }

    // Filter chips
    filterChips.forEach(chip => {
        chip.addEventListener('click', function () {
            filterChips.forEach(c => c.classList.remove('active'));
            this.classList.add('active');
            currentAuditTypeFilter = this.dataset.filter;
            currentPage = 1;
            filterRows();
            updatePagination();
            renderCurrentPage();
        });
    });

    // Event Listeners
    searchInput.addEventListener('input', function () {
        currentPage = 1;
        filterRows();
        updatePagination();
        renderCurrentPage();
    });

    itemsPerPageSelect.addEventListener('change', function () {
        itemsPerPage = parseInt(this.value);
        currentPage = 1;
        filterRows();
        updatePagination();
        renderCurrentPage();
    });

    prevBtn.addEventListener('click', function () {
        if (currentPage > 1) {
            currentPage--;
            renderCurrentPage();
            updatePagination();
        }
    });

    nextBtn.addEventListener('click', function () {
        if (currentPage < totalPages) {
            currentPage++;
            renderCurrentPage();
            updatePagination();
        }
    });

    window.addEventListener('resize', toggleMobileView);

    // Initialize
    init();
});
</script>