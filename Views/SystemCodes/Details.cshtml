@model EmployeesManagement.Models.SystemCode

@{
    ViewData["Title"] = "System Code Details";
    
    // Generate consistent color based on code
    var avatarColors = new[] {
        ("#e8eefa","#1a4fa0"), ("#e8f5ee","#1a7a4a"), ("#fef3e0","#a05c00"),
        ("#fdecea","#c0392b"), ("#f2f2ef","#3a3a38"), ("#f0eeff","#4a35c0")
    };
    int colorIdx = (Model.Code?.Length ?? 0) % avatarColors.Length;
    var (bg, tc) = avatarColors[colorIdx];
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">System Code Details</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">System Codes</a></li>
            <li class="breadcrumb-item active">@Model.Code</li>
        </ol>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="add-btn">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M9.5 2.5l2 2-7 7H2.5v-2l7-7z" stroke="currentColor" stroke-width="1.3" fill="none"/>
            </svg>
            Edit System Code
        </a>
        <a asp-action="Index" class="btn-ghost">Back to List</a>
    </div>
</div>

<div class="detail-grid">
    <!-- Left: Profile card -->
    <div>
        <div class="profile-card">
            <div class="profile-card-top">
                <div class="profile-avatar-lg" style="background:@bg;color:@tc;font-size:32px;">@(Model.Code?.Substring(0,1).ToUpper() ?? "C")</div>
                <div class="profile-name" style="font-family:monospace">@Model.Code</div>
                <div class="profile-role">
                    <span class="dept-badge" style="background:@bg;color:@tc;font-size:12px;padding:4px 10px;">System Code</span>
                </div>
            </div>
            <div class="profile-card-body">
                <div class="info-row">
                    <div class="info-icon">📋</div>
                    <div>
                        <div class="info-label">CODE</div>
                        <div class="info-value mono" style="font-family:monospace;font-weight:600">@Model.Code</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">📝</div>
                    <div>
                        <div class="info-label">DESCRIPTION</div>
                        <div class="info-value">@Model.Description</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">🏷️</div>
                    <div>
                        <div class="info-label">DISPLAY ORDER</div>
                        <div class="info-value">@(ViewBag.DisplayOrder ?? "Not set")</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">📂</div>
                    <div>
                        <div class="info-label">CATEGORY</div>
                        <div class="info-value">@(ViewBag.Category ?? "Uncategorized")</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Status Card -->
        <div class="profile-card" style="margin-top:16px">
            <div class="detail-section-header" style="border-radius:var(--r-lg) var(--r-lg) 0 0">
                Status Information
            </div>
            <div class="profile-card-body">
                <div class="info-row">
                    <div class="info-icon">⚡</div>
                    <div>
                        <div class="info-label">ACTIVE</div>
                        <div class="info-value">
                            @if (ViewBag.IsActive ?? true)
                            {
                                <span class="status-badge success">Active</span>
                            }
                            else
                            {
                                <span class="status-badge error">Inactive</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">🔒</div>
                    <div>
                        <div class="info-label">SYSTEM CRITICAL</div>
                        <div class="info-value">
                            @if (ViewBag.IsSystem ?? false)
                            {
                                <span class="status-badge warning">Yes - Handle with care</span>
                            }
                            else
                            {
                                <span class="status-badge neutral">No</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Audit card -->
        <div class="profile-card" style="margin-top:16px">
            <div class="detail-section-header" style="border-radius:var(--r-lg) var(--r-lg) 0 0">
                Audit Information
            </div>
            <div class="profile-card-body">
                <div class="info-row">
                    <div class="info-icon">⊕</div>
                    <div>
                        <div class="info-label">CREATED BY</div>
                        <div class="info-value">@(Model.CreatedById ?? "System")</div>
                        <div class="mono" style="font-size:11px;color:var(--ink4)">@Model.CreatedOn.ToString("dd MMM yyyy, HH:mm")</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">✎</div>
                    <div>
                        <div class="info-label">LAST MODIFIED</div>
                        <div class="info-value">@(Model.ModifiedById ?? "Not modified")</div>
                        @if (!string.IsNullOrEmpty(Model.ModifiedById) && Model.ModifiedOn != null)
                        {
                            <div class="mono" style="font-size:11px;color:var(--ink4)">@Model.ModifiedOn.ToString("dd MMM yyyy, HH:mm")</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Detail sections -->
    <div class="detail-sections">

        <!-- Code Details Section -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <rect x="2" y="3" width="10" height="8" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M5 2v2M9 2v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Code Details
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-2">
                    <div>
                        <div class="detail-field-label">CODE</div>
                        <div class="detail-field-value">
                            <span class="dept-badge" style="background:@bg;color:@tc;font-family:monospace">@Model.Code</span>
                        </div>
                    </div>
                    <div>
                        <div class="detail-field-label">DESCRIPTION</div>
                        <div class="detail-field-value">@Model.Description</div>
                    </div>
                    <div>
                        <div class="detail-field-label">DISPLAY ORDER</div>
                        <div class="detail-field-value">@(ViewBag.DisplayOrder ?? "0")</div>
                    </div>
                    <div>
                        <div class="detail-field-label">CATEGORY</div>
                        <div class="detail-field-value">@(ViewBag.Category ?? "—")</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Usage Statistics -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <rect x="2" y="4" width="2" height="8" fill="currentColor"/>
                    <rect x="6" y="2" width="2" height="10" fill="currentColor"/>
                    <rect x="10" y="3" width="2" height="9" fill="currentColor"/>
                </svg>
                Usage Statistics
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-3">
                    <div class="stat-card">
                        <div class="stat-label">TOTAL REFERENCES</div>
                        <div class="stat-value">@(ViewBag.TotalReferences ?? 0)</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">ACTIVE REFERENCES</div>
                        <div class="stat-value">@(ViewBag.ActiveReferences ?? 0)</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">LAST USED</div>
                        <div class="stat-value" style="font-size:14px">@(ViewBag.LastUsed ?? "Never")</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Where Used Section -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M7 4v3l2 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                    <path d="M2 2L4 4M12 2L10 4M12 12L10 10M2 12L4 10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Where Used
            </div>
            <div class="detail-section-body">
                @if (ViewBag.References != null && ((IEnumerable<dynamic>)ViewBag.References).Any())
                {
                    <div style="display:flex;flex-direction:column;gap:8px;">
                        @foreach (var reference in ViewBag.References)
                        {
                            <div style="display:flex;align-items:center;gap:10px;padding:8px 12px;background:var(--bg2);border-radius:8px;">
                                <span class="dept-badge" style="background:#e8eefa;color:#1a4fa0;font-size:10px;">@reference.Type</span>
                                <span style="flex:1;font-size:13px;">@reference.Name</span>
                                <span class="mono" style="font-size:11px;color:var(--ink4)">ID: @reference.Id</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="padding:20px;text-align:center;background:var(--bg2);border-radius:8px;color:var(--ink4);">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" style="margin-bottom:8px;opacity:0.5">
                            <circle cx="12" cy="12" r="10" stroke-width="1.5" fill="none"/>
                            <path d="M12 8v5M12 16h.01" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <div>This code is not currently in use</div>
                    </div>
                }
            </div>
        </div>

        <!-- System Information -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M7 4v3l2 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                System Information
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-2">
                    <div>
                        <div class="detail-field-label">ID</div>
                        <div class="detail-field-value mono">@Model.Id</div>
                    </div>
                    <div>
                        <div class="detail-field-label">CREATED</div>
                        <div class="detail-field-value mono">@Model.CreatedOn.ToString("dd MMM yyyy HH:mm")</div>
                    </div>
                    <div>
                        <div class="detail-field-label">CREATED BY</div>
                        <div class="detail-field-value">@(Model.CreatedById ?? "System")</div>
                    </div>
                    <div>
                        <div class="detail-field-label">MODIFIED</div>
                        <div class="detail-field-value mono">@(Model.ModifiedOn.ToString("dd MMM yyyy HH:mm") ?? "—")</div>
                    </div>
                    <div>
                        <div class="detail-field-label">MODIFIED BY</div>
                        <div class="detail-field-value">@(Model.ModifiedById ?? "—")</div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
/* Additional styles for details page */
.status-badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
    white-space: nowrap;
}

.status-badge.success {
    background: rgba(26, 122, 74, 0.1);
    color: #1a7a4a;
}

.status-badge.warning {
    background: rgba(160, 92, 0, 0.1);
    color: #a05c00;
}

.status-badge.error {
    background: rgba(192, 57, 43, 0.1);
    color: #c0392b;
}

.status-badge.neutral {
    background: var(--bg2);
    color: var(--ink3);
}

.detail-grid-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
}

.detail-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
}

.detail-field-label {
    font-size: 11px;
    color: var(--ink4);
    text-transform: uppercase;
    letter-spacing: 0.3px;
    margin-bottom: 4px;
}

.detail-field-value {
    font-size: 14px;
    color: var(--ink1);
    font-weight: 500;
}

.stat-card {
    background: var(--bg2);
    border-radius: 12px;
    padding: 16px;
    text-align: center;
}

.stat-label {
    font-size: 11px;
    color: var(--ink4);
    text-transform: uppercase;
    letter-spacing: 0.3px;
    margin-bottom: 4px;
}

.stat-value {
    font-size: 24px;
    font-weight: 600;
    color: var(--ink1);
    line-height: 1.2;
}

.mono {
    font-family: monospace;
}

/* Responsive adjustments */
@@media (max-width: 768px) {
    .detail-grid-2,
    .detail-grid-3 {
        grid-template-columns: 1fr;
        gap: 12px;
    }
    
    .stat-card {
        padding: 12px;
    }
    
    .stat-value {
        font-size: 20px;
    }
    
    .page-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
    }
    
    .page-header > div:last-child {
        width: 100%;
        flex-wrap: wrap;
    }
    
    .profile-card-top .profile-avatar-lg {
        width: 60px;
        height: 60px;
        font-size: 24px !important;
    }
}
</style>