@model EmployeesManagement.Models.SystemCode

@{
    ViewData["Title"] = "Edit System Code";
    
    // Generate consistent color based on code for avatar
    var avatarColors = new[] {
        ("#e8eefa","#1a4fa0"), ("#e8f5ee","#1a7a4a"), ("#fef3e0","#a05c00"),
        ("#fdecea","#c0392b"), ("#f2f2ef","#3a3a38"), ("#f0eeff","#4a35c0")
    };
    int colorIdx = (Model.Code?.Length ?? 0) % avatarColors.Length;
    var (bg, tc) = avatarColors[colorIdx];
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Edit System Code</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">System Codes</a></li>
            <li class="breadcrumb-item active">Edit @Model.Code</li>
        </ol>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn-ghost">View Details</a>
        <a asp-action="Index" class="btn-ghost">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px">
                <path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Back to List
        </a>
    </div>
</div>

<form asp-action="Edit" id="editForm">
    <div asp-validation-summary="ModelOnly" class="field-error" style="padding:12px 16px;background:var(--red-bg);border-radius:9px;border:1px solid rgba(192,57,43,0.2);margin-bottom:20px;"></div>

    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CreatedById" />
    <input type="hidden" asp-for="CreatedOn" />

    <!-- System Code Details -->
    <div class="form-card" style="margin-bottom:16px">
        <div class="form-card-header">
            <span class="section-badge blue">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <rect x="2" y="3" width="8" height="6" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M4 2v2M8 2v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                System Code Information
            </span>
            <span class="mono" style="margin-left:auto;font-size:11px;color:var(--ink4)">ID: @Model.Id</span>
        </div>
        <div class="form-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Code" class="field-label">System Code</label>
                    <input asp-for="Code" class="field-control" placeholder="e.g. EMP_STATUS, LEAVE_TYPE, DOC_CAT" />
                    <span asp-validation-for="Code" class="field-error"></span>
                    <small class="field-hint">Unique identifier for the system code (uppercase, no spaces)</small>
                </div>
                <div class="col-md-6">
                    <label asp-for="Description" class="field-label">Description</label>
                    <input asp-for="Description" class="field-control" placeholder="e.g. Employee Status, Leave Type, Document Category" />
                    <span asp-validation-for="Description" class="field-error"></span>
                    <small class="field-hint">Clear description of what this system code represents</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Preview Card -->
    <div class="form-card" style="margin-bottom:16px;background:var(--bg2)">
        <div class="form-card-header">
            <span class="section-badge neutral">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <circle cx="6" cy="6" r="4" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M6 3v3l2 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Preview
            </span>
        </div>
        <div class="form-card-body">
            <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
                <div style="display:flex;align-items:center;gap:12px">
                    <div class="emp-avatar" style="background:@bg;color:@tc;width:40px;height:40px;font-size:16px" id="previewAvatar">@(Model.Code?.Substring(0,1).ToUpper() ?? "C")</div>
                    <div>
                        <div style="font-family:monospace;font-weight:600;font-size:16px" id="previewCode">@Model.Code</div>
                        <div style="font-size:12px;color:var(--ink4)" id="previewDesc">@Model.Description</div>
                    </div>
                </div>
                <span class="dept-badge" style="background:@bg;color:@tc" id="previewBadge">@Model.Code</span>
            </div>
            <div class="field-hint" style="margin-top:12px">
                This is how the system code will appear in lists and dropdowns
            </div>
        </div>
    </div>

    <!-- Audit Trail -->
    <div class="form-card" style="margin-bottom:16px">
        <div class="form-card-header">
            <span class="section-badge neutral">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <circle cx="6" cy="6" r="4" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M6 3v3l2 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Audit Trail
            </span>
        </div>
        <div class="form-card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="CreatedById" class="field-label">Created By</label>
                    <input asp-for="CreatedById" class="field-control" value="@(Model.CreatedById ?? "System")" readonly disabled />
                </div>
                <div class="col-md-3">
                    <label asp-for="CreatedOn" class="field-label">Created On</label>
                    <input asp-for="CreatedOn" class="field-control" value="@Model.CreatedOn.ToString("yyyy-MM-dd HH:mm")" readonly disabled />
                </div>
                <div class="col-md-3">
                    <label asp-for="ModifiedById" class="field-label">Modified By</label>
                    <input asp-for="ModifiedById" class="field-control" value="@(Model.ModifiedById)"/>
                </div>
                <div class="col-md-3">
                    <label asp-for="ModifiedOn" class="field-label">Modified On</label>
                    <input asp-for="ModifiedOn" class="field-control" value="@(Model.ModifiedOn.ToString("yyyy-MM-dd HH:mm") ?? "—")"/>
                </div>
            </div>
            <div class="field-hint" style="margin-top:12px;padding:8px 12px;background:var(--bg2);border-radius:6px">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="display:inline;margin-right:4px;vertical-align:-2px">
                    <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M7 4v4M7 10h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                <span>System fields are automatically tracked</span>
            </div>
        </div>
    </div>

    <!-- Usage Information (if this code is in use) -->
    @if (Model.Id > 0)
    {
        <div class="form-card" style="margin-bottom:16px;border:1px solid rgba(26,79,160,0.3)">
            <div class="form-card-header" style="background:rgba(26,79,160,0.05)">
                <span class="section-badge blue">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                        <rect x="2" y="4" width="2" height="5" fill="currentColor"/>
                        <rect x="5" y="2" width="2" height="7" fill="currentColor"/>
                        <rect x="8" y="3" width="2" height="6" fill="currentColor"/>
                    </svg>
                    Usage Information
                </span>
            </div>
            <div class="form-card-body">
                <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
                    <div style="display:flex;align-items:center;gap:12px">
                        <div style="background:var(--info-bg);border-radius:12px;padding:10px">
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#1a4fa0">
                                <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                <path d="M10 6v4l2 2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <div>
                            <div style="font-size:12px;color:var(--ink4);margin-bottom:2px">REFERENCES</div>
                            <div style="font-size:18px;font-weight:600;color:var(--ink1)">3</div>
                        </div>
                    </div>
                    <div class="field-hint" style="margin-left:auto">
                        This code is referenced in 3 system records
                    </div>
                </div>
                <div style="margin-top:12px;padding:12px;background:var(--warning-bg);border-radius:8px;font-size:13px;color:#a05c00;display:flex;align-items:center;gap:8px">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor">
                        <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3" fill="none"/>
                        <path d="M8 5v4M8 12h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                    <span>Modifying this code may affect dependent records. Update with caution.</span>
                </div>
            </div>
        </div>
    }

    <!-- Actions -->
    <div class="form-actions" style="border-top:none;padding-top:0">
        <a asp-action="Index" class="btn-ghost">Cancel</a>
        <button type="submit" class="btn-primary">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px;vertical-align:-2px">
                <path d="M2 7l3.5 3.5L12 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Update System Code
        </button>
    </div>
</form>

<style>
/* Additional styles for checkboxes and form elements */
.field-checkbox {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 0;
}

.field-checkbox input[type="checkbox"] {
    width: 16px;
    height: 16px;
    margin: 0;
    cursor: pointer;
}

.field-checkbox label {
    font-size: 14px;
    color: var(--ink2);
    cursor: pointer;
    font-weight: normal;
}

.field-control[readonly],
.field-control[disabled] {
    background-color: var(--bg2);
    cursor: not-allowed;
    opacity: 0.7;
}

/* Status background colors */
:root {
    --info-bg: #e8eefa;
    --warning-bg: #fff0d9;
}

/* Responsive adjustments */
@@media (max-width: 768px) {
    .field-hint {
        font-size: 11px;
    }
    
    .form-card-body .row.g-3 > [class*="col-"] {
        margin-bottom: 8px;
    }
    
    .page-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
    }
    
    .page-header > div:last-child {
        width: 100%;
        flex-wrap: wrap;
    }
}
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Live preview of code and description
            const codeInput = document.querySelector('input[name="Code"]');
            const descInput = document.querySelector('input[name="Description"]');
            const previewCode = document.getElementById('previewCode');
            const previewDesc = document.getElementById('previewDesc');
            const previewBadge = document.getElementById('previewBadge');
            const previewAvatar = document.getElementById('previewAvatar');
            
            // Avatar colors array matching index page
            const avatarColors = [
                { bg: "#e8eefa", text: "#1a4fa0" },
                { bg: "#e8f5ee", text: "#1a7a4a" },
                { bg: "#fef3e0", text: "#a05c00" },
                { bg: "#fdecea", text: "#c0392b" },
                { bg: "#f2f2ef", text: "#3a3a38" },
                { bg: "#f0eeff", text: "#4a35c0" }
            ];
            
            function updatePreview() {
                let code = codeInput.value.trim();
                let desc = descInput.value.trim();
                
                // Use current values or fallback to original
                let displayCode = code || "@Model.Code";
                let displayDesc = desc || "@Model.Description";
                
                // Calculate color based on code length
                let colorIndex = displayCode.length % avatarColors.length;
                let colors = avatarColors[colorIndex];
                
                previewCode.textContent = displayCode;
                previewDesc.textContent = displayDesc;
                previewBadge.textContent = displayCode;
                previewBadge.style.backgroundColor = colors.bg;
                previewBadge.style.color = colors.text;
                
                // Update avatar
                let avatarLetter = displayCode.substring(0,1).toUpperCase();
                previewAvatar.textContent = avatarLetter;
                previewAvatar.style.backgroundColor = colors.bg;
                previewAvatar.style.color = colors.text;
            }
            
            if (codeInput) codeInput.addEventListener('input', updatePreview);
            if (descInput) descInput.addEventListener('input', updatePreview);
            
            // Format code input to uppercase and replace spaces with underscores
            if (codeInput) {
                codeInput.addEventListener('blur', function() {
                    let value = this.value.trim().toUpperCase().replace(/\s+/g, '_');
                    this.value = value;
                    updatePreview();
                });
            }
            
            // Track form changes for unsaved warning
            const form = document.getElementById('editForm');
            let formChanged = false;
            
            form.addEventListener('input', function() {
                formChanged = true;
            });
            
            // Warn on cancel if changes were made
            const cancelBtn = document.querySelector('.btn-ghost[asp-action="Index"]');
            if (cancelBtn) {
                cancelBtn.addEventListener('click', function(e) {
                    if (formChanged) {
                        if (!confirm('You have unsaved changes. Are you sure you want to leave?')) {
                            e.preventDefault();
                        }
                    }
                });
            }
            
            // Auto-format for numeric inputs
            const numericInputs = document.querySelectorAll('input[type="number"]');
            numericInputs.forEach(input => {
                input.addEventListener('change', function() {
                    const min = parseInt(this.min) || 0;
                    const max = parseInt(this.max) || 999;
                    let value = parseInt(this.value) || min;
                    
                    if (value < min) value = min;
                    if (value > max) value = max;
                    
                    this.value = value;
                });
            });
        });
    </script>
}