@{
    ViewData["Title"] = "Dashboard";
}

@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    string welcomeName = "Admin";
    if (SignInManager.IsSignedIn(User))
    {
        var u = await UserManager.GetUserAsync(User);
        welcomeName = u?.Email ?? "Admin";
    }
}

<!-- Welcome row -->
<div class="page-header">
    <div>
        <h1 class="page-header-title">
            Welcome back, <strong style="color:var(--ink2)">@welcomeName</strong>
        </h1>
    </div>
    <div style="display:flex;align-items:center;gap:8px;background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:8px 14px;font-size:13px;color:var(--ink3)">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.5">
            <rect x="2" y="3" width="10" height="9" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
            <path d="M5 1v3M9 1v3M2 6h10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        @DateTime.Now.ToString("dddd, MMMM dd, yyyy")
    </div>
</div>

<!-- Stats grid -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-header">
            <div class="stat-icon">👥</div>
            <span class="stat-trend up">+2 this month</span>
        </div>
        <div class="stat-value">@(ViewBag.TotalEmployees ?? 0)</div>
        <div class="stat-label">Total Employees</div>
    </div>
    <div class="stat-card">
        <div class="stat-header">
            <div class="stat-icon">✓</div>
            <span class="stat-trend up">96% rate</span>
        </div>
        <div class="stat-value">@(ViewBag.ActiveEmployees ?? ViewBag.TotalEmployees ?? 0)</div>
        <div class="stat-label">Present Today</div>
    </div>
    <div class="stat-card">
        <div class="stat-header">
            <div class="stat-icon">⊘</div>
            <span class="stat-trend neutral">2 pending</span>
        </div>
        <div class="stat-value">@(ViewBag.OnLeave ?? 0)</div>
        <div class="stat-label">On Leave</div>
    </div>
    <div class="stat-card">
        <div class="stat-header">
            <div class="stat-icon">✦</div>
            <span class="stat-trend up">This month</span>
        </div>
        <div class="stat-value">@(ViewBag.NewHires ?? 0)</div>
        <div class="stat-label">New Hires</div>
    </div>
</div>

<!-- Quick actions + recent row -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px" class="dash-two-col">

    <!-- Quick Actions -->
    <div class="table-card">
        <div class="table-toolbar" style="border-bottom:1px solid var(--border)">
            <span class="table-title">Quick Actions</span>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:16px">
            <a asp-controller="Employees" asp-action="Create" class="quick-action">
                <div class="quick-action-icon" style="background:var(--blue-bg);color:var(--blue)">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                        <circle cx="8" cy="6" r="3.5" fill="currentColor" opacity=".8"/>
                        <path d="M2 16c0-3.31 2.69-6 6-6s6 2.69 6 6" stroke="currentColor" stroke-width="1.5" fill="none"/>
                        <path d="M14 5v5M11.5 7.5h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                </div>
                <span class="quick-action-label">Add Employee</span>
            </a>
            <a href="#" class="quick-action">
                <div class="quick-action-icon" style="background:var(--green-bg);color:var(--green)">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                        <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.4"/>
                        <path d="M9 5v4.5l3 2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                    </svg>
                </div>
                <span class="quick-action-label">Mark Attendance</span>
            </a>
            <a href="#" class="quick-action">
                <div class="quick-action-icon" style="background:var(--amber-bg);color:var(--amber)">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                        <rect x="2" y="2" width="14" height="3" rx="1.5" fill="currentColor" opacity=".6"/>
                        <rect x="2" y="7.5" width="10" height="3" rx="1.5" fill="currentColor"/>
                        <rect x="2" y="13" width="7" height="3" rx="1.5" fill="currentColor" opacity=".7"/>
                    </svg>
                </div>
                <span class="quick-action-label">Generate Report</span>
            </a>
            <a href="#" class="quick-action">
                <div class="quick-action-icon" style="background:var(--surface2);color:var(--ink2)">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                        <rect x="2" y="4" width="14" height="12" rx="1.5" stroke="currentColor" stroke-width="1.3" fill="none"/>
                        <path d="M6 2v3M12 2v3M2 8h14" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                        <path d="M5 12h2M9 12h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                    </svg>
                </div>
                <span class="quick-action-label">Leave Requests</span>
            </a>
        </div>
    </div>

    <!-- Department Breakdown -->
    <div class="table-card">
        <div class="table-toolbar" style="border-bottom:1px solid var(--border)">
            <span class="table-title">By Department</span>
            <a asp-controller="Employees" asp-action="Index" style="font-size:12px;color:var(--ink3);margin-left:auto">View all →</a>
        </div>
        <div style="padding:12px 0">
            @{
                var depts = new[] {
                    ("Engineering",   38, "#1a4fa0", "#e8eefa"),
                    ("HR",            15, "#1a7a4a", "#e8f5ee"),
                    ("Finance",       12, "#a05c00", "#fef3e0"),
                    ("Marketing",     10, "#c0392b", "#fdecea"),
                    ("Operations",    25, "#3a3a38", "#f2f2ef"),
                };
                int total = depts.Sum(d => d.Item2);
            }
            @foreach (var (name, count, color, bg) in depts)
            {
                var pct = total > 0 ? (int)Math.Round(count * 100.0 / total) : 0;
                <div style="padding:8px 20px;display:flex;align-items:center;gap:12px;transition:background 0.12s;border-radius:0" class="dept-row">
                    <div style="width:8px;height:8px;border-radius:50%;background:@color;flex-shrink:0"></div>
                    <span style="font-size:13px;font-weight:500;flex:1">@name</span>
                    <div style="width:80px;height:5px;background:var(--surface2);border-radius:3px;overflow:hidden">
                        <div style="width:@pct%;height:100%;background:@color;border-radius:3px;transition:width 0.6s"></div>
                    </div>
                    <span style="font-size:12px;font-family:var(--font-mono);color:var(--ink3);min-width:32px;text-align:right">@count</span>
                </div>
            }
        </div>
    </div>
</div>

<!-- Recent Employees + Activity -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px" class="dash-two-col">

    <!-- Recent Employees -->
    <div class="table-card">
        <div class="table-toolbar" style="border-bottom:1px solid var(--border)">
            <span class="table-title">Recent Employees</span>
            <a asp-controller="Employees" asp-action="Index" style="font-size:12px;color:var(--ink3);margin-left:auto">View all →</a>
        </div>

        @if (ViewBag.RecentEmployees != null && ((IEnumerable<dynamic>)ViewBag.RecentEmployees).Any())
        {
            <div style="padding:8px 0">
                @foreach (var emp in ViewBag.RecentEmployees)
                {
                    <a asp-controller="Employees" asp-action="Details" asp-route-id="@emp.Id"
                       style="display:flex;align-items:center;gap:12px;padding:10px 20px;transition:background 0.12s;text-decoration:none;color:inherit">
                        <div class="emp-avatar" style="background:var(--surface2);width:36px;height:36px;border-radius:9px;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center">
                            @(emp.FirstName?.Substring(0, 1))@(emp.LastName?.Substring(0, 1))
                        </div>
                        <div style="flex:1;min-width:0">
                            <div style="font-size:13px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@emp.FirstName @emp.LastName</div>
                            <div style="font-size:11px;color:var(--ink4)">@emp.Department · @emp.Designation</div>
                        </div>
                        <span class="status-badge active" style="font-size:10px;padding:3px 8px">Active</span>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">👥</div>
                <div class="empty-title">No employees yet</div>
                <div class="empty-sub">
                    <a asp-controller="Employees" asp-action="Create" class="add-btn" style="margin-top:12px;display:inline-flex">Add first employee</a>
                </div>
            </div>
        }
    </div>

    <!-- Recent Activity -->
    <div class="table-card">
        <div class="table-toolbar" style="border-bottom:1px solid var(--border)">
            <span class="table-title">Recent Activity</span>
        </div>
        <div style="padding:8px 0">
            @{
                var activities = new[] {
                    ("Employee record updated",    "John Doe edited",        "2 min ago",  "✎", "#e8eefa", "#1a4fa0"),
                    ("New employee added",         "EMP0012 onboarded",      "1 hr ago",   "+", "#e8f5ee", "#1a7a4a"),
                    ("Leave request approved",     "Maria's 3-day leave",    "3 hrs ago",  "✓", "#e8f5ee", "#1a7a4a"),
                    ("Leave request pending",      "Tom submitted request",  "5 hrs ago",  "!", "#fef3e0", "#a05c00"),
                    ("Payroll processed",          "March payroll run",      "Yesterday",  "₿", "#f2f2ef", "#3a3a38"),
                };
            }
            @foreach (var (title, sub, time, icon, bg, tc) in activities)
            {
                <div style="display:flex;align-items:flex-start;gap:12px;padding:10px 20px">
                    <div style="width:30px;height:30px;border-radius:8px;background:@bg;color:@tc;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;flex-shrink:0">@icon</div>
                    <div style="flex:1;min-width:0">
                        <div style="font-size:13px;font-weight:500">@title</div>
                        <div style="font-size:11px;color:var(--ink4)">@sub</div>
                    </div>
                    <span style="font-size:11px;color:var(--ink4);font-family:var(--font-mono);white-space:nowrap">@time</span>
                </div>
            }
        </div>
    </div>
</div>

<style>
.dash-two-col { }
.quick-action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 16px 8px;
    border-radius: var(--r);
    border: 1px solid var(--border);
    background: var(--surface2);
    cursor: pointer;
    transition: all 0.18s;
    text-decoration: none;
    color: var(--ink);
}
.quick-action:hover {
    background: var(--surface);
    border-color: var(--border2);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(0,0,0,0.06);
    color: var(--ink);
}
.quick-action-icon {
    width: 44px;
    height: 44px;
    border-radius: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
}
.quick-action-label {
    font-size: 12px;
    font-weight: 600;
    text-align: center;
    color: var(--ink2);
}
.dept-row:hover { background: var(--surface2); }

@@media (max-width: 900px) {
    .dash-two-col { grid-template-columns: 1fr !important; }
}
</style>
