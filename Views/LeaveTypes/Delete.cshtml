@model EmployeesManagement.Models.LeaveType

@{
    ViewData["Title"] = "Delete Leave Type";
    var bgColor = "#fdecea";
    var textColor = "#c0392b";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Delete Leave Type</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Leave Types</a></li>
            <li class="breadcrumb-item active">Delete</li>
        </ol>
    </div>
</div>

<div class="delete-card">
    <!-- Warning header -->
    <div class="delete-warning-header">
        <div class="delete-warning-icon">⚠</div>
        <div>
            <div class="delete-warning-title">This action cannot be undone</div>
            <div class="delete-warning-sub">Deleting this leave type will permanently remove it and may affect existing leave requests.</div>
        </div>
    </div>

    <!-- Leave type summary -->
    <div style="padding:20px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:14px">
        <div class="emp-avatar" style="width:48px;height:48px;border-radius:12px;background:@bgColor;color:@textColor;border:1px solid var(--border);font-size:20px;font-weight:600">@Model.Name.Substring(0,1)</div>
        <div>
            <div style="font-size:17px;font-weight:700">@Model.Name</div>
            <div style="font-size:13px;color:var(--ink3)">
                <span class="dept-badge" style="background:@bgColor;color:@textColor;margin-right:6px">@Model.Code</span>
            </div>
        </div>
        <span class="mono" style="margin-left:auto;font-size:12px;color:var(--ink4)">ID: @Model.Id</span>
    </div>

    <!-- Details -->
    <dl class="delete-dl">
        <dt>Leave Type Name</dt>
        <dd>@Model.Name</dd>

        <dt>Leave Code</dt>
        <dd><span class="dept-badge" style="background:@bgColor;color:@textColor">@Model.Code</span></dd>

        <dt>Created On</dt>
        <dd class="mono">@Model.CreatedOn.ToString("dd MMM yyyy HH:mm")</dd>

        <dt>Created By</dt>
        <dd>@(Model.CreatedById ?? "System")</dd>

        <dt>Last Modified</dt>
        <dd class="mono">@(Model.ModifiedOn.ToString("dd MMM yyyy HH:mm") ?? "—")</dd>

        <dt>Modified By</dt>
        <dd>@(Model.ModifiedById ?? "—")</dd>
    </dl>

    <!-- Usage Information -->
    <div style="padding:16px 24px;background:var(--surface2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)">
        <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
            <div style="display:flex;align-items:center;gap:12px">
                <div style="background:var(--warning-bg);border-radius:12px;padding:10px">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#a05c00">
                        <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5" fill="none"/>
                        <path d="M10 6v4M10 14h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                </div>
                <div>
                    <div style="font-size:12px;color:var(--ink4);margin-bottom:2px">PENDING LEAVE REQUESTS</div>
                    <div style="font-size:20px;font-weight:600;color:var(--ink1)">3</div>
                </div>
            </div>
            <div style="display:flex;align-items:center;gap:12px">
                <div style="background:var(--success-bg);border-radius:12px;padding:10px">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#1a7a4a">
                        <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5" fill="none"/>
                        <path d="M6 10l3 3 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                </div>
                <div>
                    <div style="font-size:12px;color:var(--ink4);margin-bottom:2px">APPROVED REQUESTS</div>
                    <div style="font-size:20px;font-weight:600;color:var(--ink1)">18</div>
                </div>
            </div>
            <div style="display:flex;align-items:center;gap:12px">
                <div style="background:var(--error-bg);border-radius:12px;padding:10px">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#c0392b">
                        <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5" fill="none"/>
                        <path d="M7 13l6-6M13 13L7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                </div>
                <div>
                    <div style="font-size:12px;color:var(--ink4);margin-bottom:2px">REJECTED REQUESTS</div>
                    <div style="font-size:20px;font-weight:600;color:var(--ink1)">2</div>
                </div>
            </div>
        </div>
        <div style="margin-top:16px;padding:12px;background:var(--error-bg);border-radius:8px;font-size:13px;color:var(--error);display:flex;align-items:center;gap:8px">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor">
                <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3" fill="none"/>
                <path d="M8 5v4M8 12h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
            <span>This leave type has <strong>23 total requests</strong>. Deleting it may affect historical data.</span>
        </div>
    </div>

    <!-- Actions -->
    <div style="padding:16px 24px;background:var(--surface2);border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:10px">
        <a asp-action="Index" class="btn-ghost">Cancel</a>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn-ghost">View Details</a>
        <form asp-action="Delete" method="post" style="display:inline">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn-danger-outline">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" style="margin-right:6px;vertical-align:-2px">
                    <path d="M2 4h9M5 4V3a1.5 1.5 0 0 1 3 0v1M10.5 4l-.7 7H3.2L2.5 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" fill="none"/>
                </svg>
                Permanently Delete
            </button>
        </form>
    </div>
</div>

<style>
/* Additional styles for delete confirmation */
.delete-card {
    max-width: 800px;
    margin: 0 auto;
    background: white;
    border-radius: 20px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.05);
    overflow: hidden;
    border: 1px solid var(--border);
}

.delete-warning-header {
    background: #fff2f0;
    padding: 20px 24px;
    border-bottom: 1px solid rgba(192,57,43,0.2);
    display: flex;
    align-items: center;
    gap: 16px;
}

.delete-warning-icon {
    width: 36px;
    height: 36px;
    background: #c0392b;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: bold;
}

.delete-warning-title {
    font-size: 16px;
    font-weight: 600;
    color: #c0392b;
    margin-bottom: 4px;
}

.delete-warning-sub {
    font-size: 13px;
    color: var(--ink3);
}

.delete-dl {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 8px 0;
    padding: 24px;
    margin: 0;
    border-bottom: 1px solid var(--border);
}

.delete-dl dt {
    font-size: 12px;
    font-weight: 500;
    color: var(--ink4);
    letter-spacing: 0.3px;
    text-transform: uppercase;
    padding: 8px 0;
}

.delete-dl dd {
    font-size: 14px;
    color: var(--ink1);
    padding: 8px 0;
    margin: 0;
    border-bottom: 1px dashed var(--border);
}

.delete-dl dd:last-of-type {
    border-bottom: none;
}

/* Status background colors */
:root {
    --warning-bg: #fff0d9;
    --success-bg: #e0f2e9;
    --error-bg: #fce8e6;
    --error: #c0392b;
}

/* Responsive adjustments */
@@media (max-width: 600px) {
    .delete-card {
        border-radius: 16px;
    }
    
    .delete-warning-header {
        padding: 16px;
    }
    
    .delete-dl {
        grid-template-columns: 1fr;
        gap: 4px 0;
        padding: 16px;
    }
    
    .delete-dl dt {
        padding: 8px 0 4px 0;
    }
    
    .delete-dl dd {
        padding: 4px 0 8px 0;
    }
    
    div[style*="flex"] {
        flex-direction: column;
        align-items: stretch !important;
    }
    
    .btn-ghost, .btn-danger-outline {
        text-align: center;
        justify-content: center;
    }
}
</style>

<script>
function confirmDeletion() {
    return confirm('Are you absolutely sure you want to delete this leave type? This action cannot be undone.');
}
</script>