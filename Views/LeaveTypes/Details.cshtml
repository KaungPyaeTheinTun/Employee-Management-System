@model EmployeesManagement.Models.LeaveType

@{
    ViewData["Title"] = "Leave Type Details";
    var bgColor = "#e8eefa";
    var textColor = "#1a4fa0";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Leave Type Details</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Leave Types</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="add-btn">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M9.5 2.5l2 2-7 7H2.5v-2l7-7z" stroke="currentColor" stroke-width="1.3" fill="none"/>
            </svg>
            Edit Leave Type
        </a>
        <a asp-action="Index" class="btn-ghost">Back to List</a>
    </div>
</div>

<div class="detail-grid">
    <!-- Left: Profile card -->
    <div>
        <div class="profile-card">
            <div class="profile-card-top">
                <div class="profile-avatar-lg" style="background:@bgColor;color:@textColor;font-size:32px;">@Model.Name.Substring(0,1)</div>
                <div class="profile-name">@Model.Name</div>
                <div class="profile-role">
                    <span class="dept-badge" style="background:@bgColor;color:@textColor;font-size:14px;padding:6px 12px;">@Model.Code</span>
                </div>
            </div>
            <div class="profile-card-body">
                <div class="info-row">
                    <div class="info-icon">📋</div>
                    <div>
                        <div class="info-label">LEAVE TYPE NAME</div>
                        <div class="info-value">@Model.Name</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">🔤</div>
                    <div>
                        <div class="info-label">LEAVE CODE</div>
                        <div class="info-value mono">@Model.Code</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Audit card -->
        <div class="profile-card" style="margin-top:16px">
            <div class="detail-section-header" style="border-radius:var(--r-lg) var(--r-lg) 0 0">
                Audit Information
            </div>
            <div class="profile-card-body">
                <div class="info-row">
                    <div class="info-icon">⊕</div>
                    <div>
                        <div class="info-label">CREATED BY</div>
                        <div class="info-value">@(Model.CreatedById ?? "System")</div>
                        <div class="mono" style="font-size:11px;color:var(--ink4)">@Model.CreatedOn.ToString("dd MMM yyyy, HH:mm")</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">✎</div>
                    <div>
                        <div class="info-label">LAST MODIFIED</div>
                        <div class="info-value">@(Model.ModifiedById ?? "Not modified")</div>
                        @if (!string.IsNullOrEmpty(Model.ModifiedById) && Model.ModifiedOn != null)
                        {
                            <div class="mono" style="font-size:11px;color:var(--ink4)">@Model.ModifiedOn.ToString("dd MMM yyyy, HH:mm")</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Detail sections -->
    <div class="detail-sections">

        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <rect x="2" y="3" width="10" height="8" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M5 2v2M9 2v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Leave Type Information
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-2">
                    <div>
                        <div class="detail-field-label">NAME</div>
                        <div class="detail-field-value">@Model.Name</div>
                    </div>
                    <div>
                        <div class="detail-field-label">CODE</div>
                        <div class="detail-field-value">@Model.Code</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M7 4v3l2 1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Leave Configuration
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-2">
                    <div>
                        <div class="detail-field-label">DEFAULT DAYS PER YEAR</div>
                        <div class="detail-field-value">20 days</div>
                    </div>
                    <div>
                        <div class="detail-field-label">MAX CONSECUTIVE DAYS</div>
                        <div class="detail-field-value">15 days</div>
                    </div>
                    <div>
                        <div class="detail-field-label">CARRY FORWARD DAYS</div>
                        <div class="detail-field-value">5 days</div>
                    </div>
                    <div>
                        <div class="detail-field-label">PAID LEAVE</div>
                        <div class="detail-field-value">
                            <span class="status-badge success">Yes</span>
                        </div>
                    </div>
                    <div>
                        <div class="detail-field-label">REQUIRES APPROVAL</div>
                        <div class="detail-field-value">
                            <span class="status-badge warning">Yes</span>
                        </div>
                    </div>
                    <div>
                        <div class="detail-field-label">STATUS</div>
                        <div class="detail-field-value">
                            <span class="status-badge success">Active</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Section (Optional) -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <rect x="2" y="4" width="2" height="8" fill="currentColor"/>
                    <rect x="6" y="2" width="2" height="10" fill="currentColor"/>
                    <rect x="10" y="3" width="2" height="9" fill="currentColor"/>
                </svg>
                Usage Statistics
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-3">
                    <div class="stat-card">
                        <div class="stat-label">TOTAL REQUESTS</div>
                        <div class="stat-value">24</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">APPROVED</div>
                        <div class="stat-value">18</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">PENDING</div>
                        <div class="stat-value">3</div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
/* Additional styles for details page */
.status-badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
}

.status-badge.success {
    background: rgba(26, 122, 74, 0.1);
    color: #1a7a4a;
}

.status-badge.warning {
    background: rgba(160, 92, 0, 0.1);
    color: #a05c00;
}

.status-badge.error {
    background: rgba(192, 57, 43, 0.1);
    color: #c0392b;
}

.detail-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
}

.stat-card {
    background: var(--bg2);
    border-radius: 12px;
    padding: 16px;
    text-align: center;
}

.stat-label {
    font-size: 11px;
    color: var(--ink4);
    text-transform: uppercase;
    letter-spacing: 0.3px;
    margin-bottom: 4px;
}

.stat-value {
    font-size: 24px;
    font-weight: 600;
    color: var(--ink1);
    line-height: 1.2;
}

/* Responsive adjustments */
@@media (max-width: 768px) {
    .detail-grid-3 {
        grid-template-columns: 1fr;
        gap: 8px;
    }
    
    .stat-card {
        padding: 12px;
    }
    
    .stat-value {
        font-size: 20px;
    }
}
</style>