@model EmployeeManagement.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "Assign User Rights";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Assign User Rights</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">User Roles</a></li>
            <li class="breadcrumb-item active">Assign Rights</li>
        </ol>
    </div>
    <a asp-action="Index" class="btn-ghost">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px">
            <path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Back to List
    </a>
</div>

<div class="table-card">
    <div class="table-toolbar">
        <span class="table-title">Role Rights Assignment</span>
    </div>

    <form asp-action="UserGroupRights" method="post" id="rightsForm">
        <div class="form-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="RoleId" class="field-label">Select Role <span class="field-required">*</span></label>
                    <select asp-for="RoleId" class="field-control role-select" asp-items="ViewBag.RoleId">
                        <option value="">— Select Role —</option>
                    </select>
                    <span class="field-hint">Select a role to view and assign its permissions</span>
                </div>
            </div>
        </div>

        <!-- Permissions Tree -->
        <div class="permissions-section" id="permissionsSection" style="display: none;">
            <div class="permissions-header">
                <div class="permissions-header-left">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                        <rect x="2" y="3" width="14" height="12" rx="2" stroke="currentColor" stroke-width="1.2" fill="none"/>
                        <path d="M5 7h8M5 11h5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                    </svg>
                    <span>Permissions Matrix</span>
                </div>
                <div class="permissions-actions">
                    <button type="button" class="btn-link-sm" id="expandAllBtn">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                            <path d="M3 5l3 3 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                        </svg>
                        Expand All
                    </button>
                    <button type="button" class="btn-link-sm" id="collapseAllBtn">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                            <path d="M3 7l3-3 3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                        </svg>
                        Collapse All
                    </button>
                </div>
            </div>

            <div class="tree-container">
                <div id="tree">
                    <ul id="treeData" class="permission-tree">
                        <!-- Grandparent -->
                        <li class="tree-node">
                            <div class="tree-node-header">
                                <button type="button" class="tree-toggle expanded">
                                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                                        <path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                                    </svg>
                                </button>
                                <div class="tree-checkbox">
                                    <input class="grandparent" value="0" type="checkbox" id="allModules" />
                                    <label for="allModules"></label>
                                </div>
                                <i class="tree-icon">📁</i>
                                <span class="tree-label">All Modules</span>
                            </div>

                            <ul class="tree-children expanded">
                                @foreach (var item in Model.Profiles)
                                {
                                    <li class="tree-node">
                                        <div class="tree-node-header">
                                            <button type="button" class="tree-toggle expanded">
                                                <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                                                    <path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                                                </svg>
                                            </button>
                                            <div class="tree-checkbox">
                                                <input class="parent"
                                                       value="@item.Id"
                                                       name="Ids[]"
                                                       type="checkbox"
                                                       id="parent_@item.Id"
                                                       @(Model.RoleRightsIds.Contains(item.Id) ? "checked" : "") />
                                                <label for="parent_@item.Id"></label>
                                            </div>
                                            <i class="tree-icon">📂</i>
                                            <span class="tree-label">@item.Name</span>
                                        </div>

                                        @if (item.Children.Any())
                                        {
                                            <ul class="tree-children expanded">
                                                @foreach (var child in item.Children.OrderBy(c => c.Order))
                                                {
                                                    <li class="tree-node">
                                                        <div class="tree-node-header">
                                                            @if (child.Children.Any())
                                                            {
                                                                <button type="button" class="tree-toggle expanded">
                                                                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                                                                        <path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                                                                    </svg>
                                                                </button>
                                                            }
                                                            else
                                                            {
                                                                <span class="tree-toggle-placeholder"></span>
                                                            }
                                                            <div class="tree-checkbox">
                                                                <input class="child"
                                                                       value="@child.Id"
                                                                       name="Ids[]"
                                                                       type="checkbox"
                                                                       id="child_@child.Id"
                                                                       @(Model.RoleRightsIds.Contains(child.Id) ? "checked" : "") />
                                                                <label for="child_@child.Id"></label>
                                                            </div>
                                                            <i class="tree-icon">@(child.Children.Any() ? "📂" : "📄")</i>
                                                            <span class="tree-label">@child.Name</span>
                                                        </div>

                                                        @if (child.Children.Any())
                                                        {
                                                            <ul class="tree-children expanded">
                                                                @foreach (var childInner in child.Children.OrderBy(c => c.Order))
                                                                {
                                                                    <li class="tree-node">
                                                                        <div class="tree-node-header">
                                                                            <span class="tree-toggle-placeholder"></span>
                                                                            <div class="tree-checkbox">
                                                                                <input class="child"
                                                                                       value="@childInner.Id"
                                                                                       name="Ids[]"
                                                                                       type="checkbox"
                                                                                       id="child_@childInner.Id"
                                                                                       @(Model.RoleRightsIds.Contains(childInner.Id) ? "checked" : "") />
                                                                                <label for="child_@childInner.Id"></label>
                                                                            </div>
                                                                            <i class="tree-icon">📄</i>
                                                                            <span class="tree-label">@childInner.Name</span>
                                                                        </div>
                                                                    </li>
                                                                }
                                                            </ul>
                                                        }
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </li>
                                }
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="form-actions" style="border-top:none;padding-top:0">
            <a asp-action="Index" class="btn-ghost">Cancel</a>
            <button type="submit" class="btn-primary" style="background-color: black;">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px;vertical-align:-2px">
                    <path d="M2 7l3.5 3.5L12 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Assign Rights
            </button>
        </div>
    </form>
</div>

<style>
    /* Page Header */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 24px;
        gap: 16px;
    }

    .page-header-title {
        font-size: 24px;
        font-weight: 600;
        color: var(--ink1);
        margin: 0 0 8px 0;
    }

    .breadcrumb {
        display: flex;
        flex-wrap: wrap;
        padding: 0;
        margin: 0;
        list-style: none;
        gap: 8px;
        font-size: 13px;
    }

    .breadcrumb-item {
        color: var(--ink3);
    }

    .breadcrumb-item a {
        color: var(--primary);
        text-decoration: none;
    }

    .breadcrumb-item a:hover {
        text-decoration: underline;
    }

    .breadcrumb-item.active {
        color: var(--ink2);
        font-weight: 500;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "/";
        margin-right: 8px;
        color: var(--ink4);
    }

    /* Table Card */
    .table-card {
        background: var(--card-bg);
        border-radius: 12px;
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .table-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        background: var(--bg2);
        flex-wrap: wrap;
        gap: 12px;
    }

    .table-title {
        font-weight: 600;
        font-size: 14px;
        color: var(--ink1);
    }

    /* Form field styles */
    .field-label {
        display: block;
        font-size: 12px;
        font-weight: 500;
        color: var(--ink2);
        margin-bottom: 6px;
    }

    .field-required {
        color: #c0392b;
        font-size: 12px;
    }

    .field-control {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 13px;
        color: var(--ink1);
        background: var(--card-bg);
        transition: all 0.15s;
    }

    .field-control:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(26, 79, 160, 0.1);
    }

    select.field-control {
        appearance: none;
        background-image: url("data:image/svg+xml,%3Csvg width='12' height='12' viewBox='0 0 12 12' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M2 4L6 8L10 4' stroke='%23666' stroke-width='1.2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-position: right 12px center;
        padding-right: 32px;
        cursor: pointer;
    }

    .field-hint {
        display: block;
        font-size: 11px;
        color: var(--ink3);
        margin-top: 4px;
    }

    .form-card-body {
        padding: 20px;
    }

    /* Permissions Section */
    .permissions-section {
        border-top: 1px solid var(--border);
    }

    .permissions-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 20px;
        background: var(--bg2);
        border-bottom: 1px solid var(--border);
    }

    .permissions-header-left {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 600;
        font-size: 13px;
        color: var(--ink2);
    }

    .permissions-actions {
        display: flex;
        gap: 12px;
    }

    .btn-link-sm {
        background: none;
        border: none;
        font-size: 11px;
        color: var(--primary);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 4px 8px;
        border-radius: 4px;
        transition: all 0.15s;
    }

    .btn-link-sm:hover {
        background: var(--border);
    }

    /* Tree Styles */
    .tree-container {
        padding: 20px;
        max-height: 500px;
        overflow-y: auto;
    }

    .permission-tree {
        list-style: none;
        padding-left: 0;
        margin: 0;
    }

    .permission-tree ul {
        list-style: none;
        padding-left: 24px;
        margin: 0;
    }

    .tree-node {
        margin: 4px 0;
    }

    .tree-node-header {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 8px;
        border-radius: 8px;
        transition: background 0.15s;
    }

    .tree-node-header:hover {
        background: var(--bg2);
    }

    .tree-toggle {
        width: 20px;
        height: 20px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--ink3);
        transition: transform 0.2s;
        padding: 0;
    }

    .tree-toggle.collapsed svg {
        transform: rotate(-90deg);
    }

    .tree-toggle-placeholder {
        width: 20px;
        height: 20px;
    }

    .tree-checkbox {
        position: relative;
    }

    .tree-checkbox input[type="checkbox"] {
        position: absolute;
        opacity: 0;
        cursor: pointer;
        width: 18px;
        height: 18px;
        margin: 0;
    }

    .tree-checkbox label {
        display: inline-block;
        width: 18px;
        height: 18px;
        background: var(--card-bg);
        border: 2px solid var(--border);
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.15s;
    }

    .tree-checkbox input[type="checkbox"]:checked + label {
        background: var(--primary);
        border-color: var(--primary);
        position: relative;
    }

    .tree-checkbox input[type="checkbox"]:checked + label::after {
        content: "✓";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: white;
        font-size: 11px;
    }

    .tree-checkbox input[type="checkbox"]:hover + label {
        border-color: var(--primary);
    }

    .tree-icon {
        font-size: 14px;
        color: var(--ink3);
        width: 20px;
    }

    .tree-label {
        font-size: 13px;
        color: var(--ink1);
        cursor: pointer;
    }

    .tree-children {
        padding-left: 28px;
    }

    .tree-children.collapsed {
        display: none;
    }

    /* Button styles */
    .btn-primary {
        display: inline-flex;
        align-items: center;
        padding: 10px 20px;
        background: var(--primary);
        color: white;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        border: none;
        cursor: pointer;
        transition: all 0.15s;
        text-decoration: none;
    }

    .btn-primary:hover {
        background: #134080;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(26, 79, 160, 0.2);
        color: white;
        text-decoration: none;
    }

    .btn-ghost {
        display: inline-flex;
        align-items: center;
        padding: 10px 20px;
        background: var(--bg2);
        color: var(--ink2);
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-ghost:hover {
        background: var(--border);
        color: var(--ink1);
        text-decoration: none;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        padding: 20px;
        border-top: 1px solid var(--border);
        margin-top: 0;
    }

    /* Grid system */
    .row {
        display: flex;
        flex-wrap: wrap;
        margin: -8px;
    }

    .g-3 {
        margin: -8px;
    }

    .g-3 > [class*="col-"] {
        padding: 8px;
    }

    .col-md-6 {
        flex: 0 0 50%;
        max-width: 50%;
    }

    /* CSS Variables */
    :root {
        --ink1: #1a1a1a;
        --ink2: #4a4a4a;
        --ink3: #8a8a8a;
        --ink4: #c0c0c0;
        --border: #e5e5e5;
        --bg2: #f8f8f8;
        --card-bg: #ffffff;
        --primary: #1a4fa0;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .col-md-6 {
            flex: 0 0 100%;
            max-width: 100%;
        }
        
        .form-actions {
            flex-direction: column-reverse;
        }
        
        .btn-primary,
        .btn-ghost {
            width: 100%;
            justify-content: center;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .permissions-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 8px;
        }

        .tree-container {
            padding: 12px;
        }

        .tree-children {
            padding-left: 16px;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Role dropdown change redirect
        const roleSelect = document.querySelector('.role-select');
        const currentUrl = document.querySelector('.currentrooturl')?.getAttribute('href') || '/Profiles/UserRights';
        const permissionsSection = document.getElementById('permissionsSection');

        if (roleSelect) {
            // Show/hide permissions section based on selection
            function togglePermissionsSection() {
                if (roleSelect.value) {
                    permissionsSection.style.display = 'block';
                } else {
                    permissionsSection.style.display = 'none';
                }
            }

            roleSelect.addEventListener('change', function() {
                if (this.value) {
                    window.location.href = currentUrl + '/' + this.value;
                } else {
                    togglePermissionsSection();
                }
            });

            togglePermissionsSection();
        }

        // Tree toggle functionality
        function initTreeToggles() {
            const toggles = document.querySelectorAll('.tree-toggle');
            toggles.forEach(toggle => {
                toggle.removeEventListener('click', handleToggleClick);
                toggle.addEventListener('click', handleToggleClick);
            });
        }

        function handleToggleClick(e) {
            e.stopPropagation();
            const btn = e.currentTarget;
            const parentLi = btn.closest('.tree-node');
            const childrenUl = parentLi.querySelector(':scope > .tree-children');
            
            if (childrenUl) {
                btn.classList.toggle('collapsed');
                childrenUl.classList.toggle('collapsed');
            }
        }

        // Expand All
        const expandAllBtn = document.getElementById('expandAllBtn');
        if (expandAllBtn) {
            expandAllBtn.addEventListener('click', function() {
                document.querySelectorAll('.tree-children').forEach(el => {
                    el.classList.remove('collapsed');
                });
                document.querySelectorAll('.tree-toggle').forEach(btn => {
                    btn.classList.remove('collapsed');
                });
            });
        }

        // Collapse All
        const collapseAllBtn = document.getElementById('collapseAllBtn');
        if (collapseAllBtn) {
            collapseAllBtn.addEventListener('click', function() {
                document.querySelectorAll('.tree-children').forEach(el => {
                    el.classList.add('collapsed');
                });
                document.querySelectorAll('.tree-toggle').forEach(btn => {
                    btn.classList.add('collapsed');
                });
            });
        }

        // Checkbox hierarchy logic
        function initCheckboxHierarchy() {
            // Parent and grandparent checkboxes affect children
            document.querySelectorAll('input.parent, input.grandparent').forEach(checkbox => {
                checkbox.removeEventListener('change', handleParentChange);
                checkbox.addEventListener('change', handleParentChange);
            });

            // Child checkboxes affect parent
            document.querySelectorAll('input.child').forEach(checkbox => {
                checkbox.removeEventListener('change', handleChildChange);
                checkbox.addEventListener('change', handleChildChange);
            });
        }

        function handleParentChange(e) {
            const checkbox = e.target;
            const parentLi = checkbox.closest('.tree-node');
            const childCheckboxes = parentLi.querySelectorAll(':scope .tree-children input[type="checkbox"]');
            childCheckboxes.forEach(child => {
                child.checked = checkbox.checked;
            });
        }

        function handleChildChange(e) {
            const checkbox = e.target;
            const parentLi = checkbox.closest('.tree-node');
            const parentDiv = parentLi?.parentElement?.closest('.tree-node');
            if (parentDiv) {
                const siblingCheckboxes = parentDiv.querySelectorAll(':scope > .tree-children input[type="checkbox"]');
                const allChecked = Array.from(siblingCheckboxes).every(cb => cb.checked);
                const someChecked = Array.from(siblingCheckboxes).some(cb => cb.checked);
                const parentCheckbox = parentDiv.querySelector(':scope > .tree-node-header input[type="checkbox"]');
                
                if (parentCheckbox) {
                    if (allChecked) {
                        parentCheckbox.checked = true;
                        parentCheckbox.indeterminate = false;
                    } else if (someChecked) {
                        parentCheckbox.checked = false;
                        parentCheckbox.indeterminate = true;
                    } else {
                        parentCheckbox.checked = false;
                        parentCheckbox.indeterminate = false;
                    }
                }
            }
        }

        // Initialize for dynamically loaded content
        initTreeToggles();
        initCheckboxHierarchy();

        // Handle indeterminate state for parent checkboxes on page load
        document.querySelectorAll('input.parent').forEach(checkbox => {
            const parentLi = checkbox.closest('.tree-node');
            const childCheckboxes = parentLi.querySelectorAll(':scope .tree-children input[type="checkbox"]');
            if (childCheckboxes.length > 0) {
                const checkedCount = Array.from(childCheckboxes).filter(cb => cb.checked).length;
                if (checkedCount > 0 && checkedCount < childCheckboxes.length) {
                    checkbox.indeterminate = true;
                    checkbox.checked = false;
                }
            }
        });
    });
</script>

<a class="currentrooturl" href="/Profiles/UserRights" style="display: none;"></a>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}