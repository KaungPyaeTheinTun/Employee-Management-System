@model EmployeeManagement.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "AssignRole";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">@ViewData["Title"]</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Assign User Role</a></li>
        </ol>
    </div>
</div>

<div class="row" style="justify-content: center;">
    <div class="col-md-8">
        <!-- User Details Card -->
        <div class="form-card" style="max-width:800px;margin:0 auto;">
            <div class="form-card-header">
                <span class="section-badge blue">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                        <circle cx="6" cy="4" r="2.5" fill="currentColor"/>
                        <path d="M1 11c0-2.76 2.24-5 5-5s5 2.24 5 5" stroke="currentColor" stroke-width="1.3" fill="none"/>
                    </svg>
                    Roles Information
                </span>
            </div>

            <div class="form-card-body">
                <form asp-action="AssignRights" id="createForm">
                    <div asp-validation-summary="ModelOnly" class="field-error" style="padding:12px 16px;background:var(--red-bg);border-radius:9px;border:1px solid rgba(192,57,43,0.2);margin-bottom:20px;"></div>

                    <!-- Personal Details Section -->
                    <div style="margin-bottom:24px;">
                        <h4 style="font-size:14px;font-weight:600;color:var(--ink2);margin-bottom:16px;">Select Roles</h4>
                        <div class="row g-3">

                            <div class="col-md-6">
                                <label asp-for="RoleId" class="field-label">Role</label>
                                <div style="position:relative">
                                    <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--ink3);z-index:1;">
                                        <!-- Role Icon - Shield with checkmark -->
                                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2">
                                            <path d="M8 1.5L2.5 4v4.5c0 3 5.5 6 5.5 6s5.5-3 5.5-6V4L8 1.5z" stroke="currentColor" fill="none"/>
                                            <path d="M6 8.5L7.5 10 10 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                                        </svg>
                                    </span>
                                    <select asp-for="RoleId" class="field-control" asp-items="ViewBag.Roles" style="padding-left:36px;">
                                        <option value="">— Select Role —</option>
                                    </select>
                                </div>
                                <span asp-validation-for="RoleId" class="field-error"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="TaskId" class="field-label">Task</label>
                                <div style="position:relative">
                                    <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--ink3);z-index:1;">
                                        <!-- Task Icon - Clipboard with checkmark -->
                                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2">
                                            <rect x="3" y="2.5" width="10" height="12" rx="1.5" stroke="currentColor" fill="none"/>
                                            <path d="M5.5 2V0.5h5V2" stroke="currentColor" stroke-linejoin="round" fill="none"/>
                                            <path d="M6 8L8 10 11 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                                        </svg>
                                    </span>
                                    <select asp-for="TaskId" class="field-control" asp-items="ViewBag.Tasks" style="padding-left:36px;">
                                        <option value="">— Select Task —</option>
                                    </select>
                                </div>
                                <span asp-validation-for="TaskId" class="field-error"></span>
                            </div>

                        </div>
                    </div>

                    <!-- Actions -->
                    <div style="border-top:1px solid var(--border);padding-top:20px;display:flex;gap:12px;justify-content:flex-end;">
                        <a asp-action="Index" class="btn-ghost">Cancel</a>
                        <button type="submit" class="btn-primary">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px;vertical-align:-2px">
                                <path d="M2 7l3.5 3.5L12 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            Assign Role
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Security Notice -->
        <div style="max-width:800px;margin:20px auto 0;text-align:center;">
            <div class="field-hint" style="font-size:12px;display:flex;align-items:center;justify-content:center;gap:8px;">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <rect x="2" y="5" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M4 5V3.5C4 2 5.5 1 7 1s3 1 3 2.5V5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                <span>All data is encrypted and securely stored</span>
            </div>
        </div>
    </div>
</div>

<style>
/* Form element styles */
.field-checkbox {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 0;
}

.field-checkbox input[type="checkbox"] {
    width: 16px;
    height: 16px;
    margin: 0;
    cursor: pointer;
}

.field-checkbox label {
    font-size: 14px;
    color: var(--ink2);
    cursor: pointer;
    font-weight: normal;
}

/* Input icon positioning */
input.field-control, select.field-control {
    transition: border-color 0.2s, box-shadow 0.2s;
}

input.field-control:focus, select.field-control:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(26, 79, 160, 0.1);
}

/* Password toggle button styles */
.btn-icon {
    transition: color 0.2s, background-color 0.2s;
    z-index: 2;
}

.btn-icon:hover {
    background-color: var(--bg2) !important;
    color: var(--blue) !important;
}

.btn-icon:active {
    background-color: var(--bg3) !important;
}

/* Responsive adjustments */
@@media (max-width: 768px) {
    .form-card {
        margin-left: 12px;
        margin-right: 12px;
    }
    
    .form-card-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 4px;
    }
    
    div[style*="justify-content: flex-end"] {
        flex-direction: column;
    }
    
    .btn-ghost, .btn-primary {
        width: 100%;
        justify-content: center !important;
    }
}

/* Animation for submit button */
.btn-primary {
    transition: transform 0.2s, box-shadow 0.2s;
}

.btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(26, 79, 160, 0.2);
}

.btn-primary:active {
    transform: translateY(0);
}

/* Section headers */
h4 {
    letter-spacing: -0.01em;
}
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Password show/hide functionality
        function togglePasswordVisibility() {
            const passwordField = document.getElementById('passwordField');
            const eyeIcon = document.getElementById('eyeIcon');
            const eyeOffIcon = document.getElementById('eyeOffIcon');
            
            if (passwordField.type === 'password') {
                passwordField.type = 'text';
                eyeIcon.style.display = 'none';
                eyeOffIcon.style.display = 'block';
            } else {
                passwordField.type = 'password';
                eyeIcon.style.display = 'block';
                eyeOffIcon.style.display = 'none';
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            const emailInput = document.getElementById('Email');
            
            // Focus on email field on page load
            if (emailInput) {
                emailInput.focus();
            }
            
            // Optional: Add keyboard shortcut (Ctrl+Shift+P) to toggle password
            document.addEventListener('keydown', function(e) {
                if (e.ctrlKey && e.shiftKey && e.key === 'P') {
                    e.preventDefault();
                    togglePasswordVisibility();
                }
            });
        });
    </script>
}