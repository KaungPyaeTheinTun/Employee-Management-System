@model EmployeesManagement.Models.WorkFlowUserGroup

@{
    ViewData["Title"] = "WorkFlow User Group Details";
    var bgColor = "#e8eefa";
    var textColor = "#1a4fa0";
    var deptBadgeBg = "#e8eefa";
    var deptBadgeText = "#1a4fa0";
    var docTypeBadgeBg = "#f0eeff";
    var docTypeBadgeText = "#4a35c0";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">WorkFlow User Group Details</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">WorkFlow User Groups</a></li>
            <li class="breadcrumb-item active">@Model.Code</li>
        </ol>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="add-btn">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M9.5 2.5l2 2-7 7H2.5v-2l7-7z" stroke="currentColor" stroke-width="1.3" fill="none"/>
            </svg>
            Edit Group
        </a>
        <a asp-action="Index" class="btn-ghost">Back to List</a>
    </div>
</div>

<div class="detail-grid">
    <!-- Left: Profile card -->
    <div>
        <div class="profile-card">
            <div class="profile-card-top">
                <div class="profile-avatar-lg" style="background:@bgColor;color:@textColor;font-size:32px;">@(Model.Code?.Substring(0, 1).ToUpper() ?? "G")</div>
                <div class="profile-name">@Model.Code</div>
                <div class="profile-role">
                    <span class="dept-badge" style="background:@bgColor;color:@textColor;font-size:14px;padding:6px 12px;">@Model.Code</span>
                </div>
            </div>
            <div class="profile-card-body">
                <div class="info-row">
                    <div class="info-icon">📋</div>
                    <div>
                        <div class="info-label">GROUP CODE</div>
                        <div class="info-value mono">@Model.Code</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">📝</div>
                    <div>
                        <div class="info-label">DESCRIPTION</div>
                        <div class="info-value">@Model.Description</div>
                    </div>
                </div>
                @if (Model.Department != null)
                {
                    <div class="info-row">
                        <div class="info-icon">🏢</div>
                        <div>
                            <div class="info-label">DEPARTMENT</div>
                            <div class="info-value">
                                <span class="dept-badge" style="background:@deptBadgeBg;color:@deptBadgeText">@Model.Department.Name</span>
                            </div>
                        </div>
                    </div>
                }
                @if (Model.DocumentType != null)
                {
                    <div class="info-row">
                        <div class="info-icon">📄</div>
                        <div>
                            <div class="info-label">DOCUMENT TYPE</div>
                            <div class="info-value">
                                <span class="dept-badge" style="background:@docTypeBadgeBg;color:@docTypeBadgeText">@Model.DocumentType.Description</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Members Card -->
        <div class="profile-card" style="margin-top:16px">
            <div class="detail-section-header" style="border-radius:var(--r-lg) var(--r-lg) 0 0">
                Group Members
            </div>
            <div class="profile-card-body">
                <div class="info-row">
                    <div class="info-icon">👥</div>
                    <div>
                        <div class="info-label">TOTAL MEMBERS</div>
                        <div class="info-value">0 members</div>
                    </div>
                </div>
                <div style="margin-top:12px">
                    <a asp-controller="WorkFlowUserGroupMembers" asp-action="Index" asp-route-id="@Model.Id" class="btn-ghost-sm" style="width:100%;text-align:center;justify-content:center;">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" style="margin-right:4px">
                            <path d="M2 3h8v6H2V3z" stroke="currentColor" stroke-width="1.2" fill="none"/>
                            <path d="M4 2v1M8 2v1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                            <circle cx="6" cy="6" r="1" fill="currentColor"/>
                        </svg>
                        Manage Members
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Detail sections -->
    <div class="detail-sections">
        <!-- Group Information -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <rect x="2" y="3" width="10" height="8" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M5 2v2M9 2v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Group Information
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-2">
                    <div>
                        <div class="detail-field-label">GROUP CODE</div>
                        <div class="detail-field-value mono">@Model.Code</div>
                    </div>
                    <div>
                        <div class="detail-field-label">DESCRIPTION</div>
                        <div class="detail-field-value">@Model.Description</div>
                    </div>
                    @if (Model.Department != null)
                    {
                        <div>
                            <div class="detail-field-label">DEPARTMENT</div>
                            <div class="detail-field-value">
                                <span class="dept-badge" style="background:@deptBadgeBg;color:@deptBadgeText">@Model.Department.Name</span>
                            </div>
                        </div>
                    }
                    @if (Model.DocumentType != null)
                    {
                        <div>
                            <div class="detail-field-label">DOCUMENT TYPE</div>
                            <div class="detail-field-value">
                                <span class="dept-badge" style="background:@docTypeBadgeBg;color:@docTypeBadgeText">@Model.DocumentType.Description</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- WorkFlow Configuration -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M7 4v3l2 1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                WorkFlow Configuration
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-2">
                    <div>
                        <div class="detail-field-label">APPROVAL SEQUENCE</div>
                        <div class="detail-field-value">Sequential</div>
                    </div>
                    <div>
                        <div class="detail-field-label">ESCALATION DAYS</div>
                        <div class="detail-field-value">3 days</div>
                    </div>
                    <div>
                        <div class="detail-field-label">REQUIRES ALL APPROVALS</div>
                        <div class="detail-field-value">
                            <span class="status-badge success">Yes</span>
                        </div>
                    </div>
                    <div>
                        <div class="detail-field-label">STATUS</div>
                        <div class="detail-field-value">
                            <span class="status-badge success">Active</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Section -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <rect x="2" y="4" width="2" height="8" fill="currentColor"/>
                    <rect x="6" y="2" width="2" height="10" fill="currentColor"/>
                    <rect x="10" y="3" width="2" height="9" fill="currentColor"/>
                </svg>
                Usage Statistics
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-3">
                    <div class="stat-card">
                        <div class="stat-label">TOTAL MEMBERS</div>
                        <div class="stat-value">0</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">ACTIVE APPROVALS</div>
                        <div class="stat-value">0</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">PENDING TASKS</div>
                        <div class="stat-value">0</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Related Actions -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <path d="M2 4h10v8H2V4z" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M4 2v2M10 2v2M2 7h10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Related Actions
            </div>
            <div class="detail-section-body">
                <div class="action-buttons">
                    <a asp-controller="WorkFlowUserGroupMembers" asp-action="Index" asp-route-id="@Model.Id" class="action-link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                            <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2"/>
                            <path d="M8 5v3l2 1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                        </svg>
                        View Group Members
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="action-link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                            <path d="M11 2l3 3-8 8H3v-3l8-8z" stroke="currentColor" stroke-width="1.2" fill="none"/>
                        </svg>
                        Edit Group
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="action-link delete">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                            <path d="M3 4h10M5 4V3a1.5 1.5 0 0 1 3 0v1M11 4l-.7 8H5.7L5 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" fill="none"/>
                        </svg>
                        Delete Group
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Detail Grid Layout */
    .detail-grid {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 20px;
    }

    /* Profile Card Styles */
    .profile-card {
        background: var(--card-bg);
        border-radius: 16px;
        border: 1px solid var(--border);
        overflow: hidden;
        position: sticky;
        top: 20px;
    }

    .profile-card-top {
        text-align: center;
        padding: 24px 20px 16px;
        background: linear-gradient(135deg, var(--bg2) 0%, var(--card-bg) 100%);
        border-bottom: 1px solid var(--border);
    }

    .profile-avatar-lg {
        width: 100px;
        height: 100px;
        margin: 0 auto 16px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 48px;
        font-weight: 600;
        border-radius: 50%;
        overflow: hidden;
    }

    .profile-name {
        font-size: 18px;
        font-weight: 600;
        color: var(--ink1);
        margin-bottom: 4px;
    }

    .profile-role {
        font-size: 12px;
        color: var(--ink3);
    }

    .profile-card-body {
        padding: 16px;
    }

    .info-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid var(--border);
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-icon {
        width: 32px;
        height: 32px;
        background: var(--bg2);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
    }

    .info-label {
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--ink4);
        margin-bottom: 2px;
    }

    .info-value {
        font-size: 13px;
        font-weight: 500;
        color: var(--ink1);
    }

    /* Detail Sections Styles */
    .detail-sections {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .detail-section {
        background: var(--card-bg);
        border-radius: 12px;
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .detail-section-header {
        padding: 14px 20px;
        background: var(--bg2);
        border-bottom: 1px solid var(--border);
        font-weight: 600;
        font-size: 13px;
        color: var(--ink2);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .detail-section-body {
        padding: 20px;
    }

    .detail-grid-2 {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    .detail-grid-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }

    .detail-field-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--ink4);
        margin-bottom: 6px;
    }

    .detail-field-value {
        font-size: 13px;
        font-weight: 500;
        color: var(--ink1);
        word-break: break-word;
    }

    /* Badge styles */
    .dept-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
    }

    .status-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
        white-space: nowrap;
    }

    .status-badge.success {
        background: rgba(26, 122, 74, 0.1);
        color: #1a7a4a;
    }

    .status-badge.warning {
        background: rgba(160, 92, 0, 0.1);
        color: #a05c00;
    }

    .status-badge.error {
        background: rgba(192, 57, 43, 0.1);
        color: #c0392b;
    }

    /* Stat Card */
    .stat-card {
        background: var(--bg2);
        border-radius: 12px;
        padding: 16px;
        text-align: center;
    }

    .stat-label {
        font-size: 11px;
        color: var(--ink4);
        text-transform: uppercase;
        letter-spacing: 0.3px;
        margin-bottom: 4px;
    }

    .stat-value {
        font-size: 24px;
        font-weight: 600;
        color: var(--ink1);
        line-height: 1.2;
    }

    /* Action Links */
    .action-buttons {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .action-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        background: var(--bg2);
        border-radius: 8px;
        color: var(--ink2);
        text-decoration: none;
        transition: all 0.15s;
        font-size: 13px;
        font-weight: 500;
    }

    .action-link:hover {
        background: var(--border);
        color: var(--primary);
        text-decoration: none;
    }

    .action-link.delete:hover {
        background: #fdecea;
        color: #c0392b;
    }

    .btn-ghost-sm {
        display: inline-flex;
        align-items: center;
        padding: 8px 12px;
        background: var(--bg2);
        color: var(--ink2);
        border-radius: 6px;
        font-size: 12px;
        font-weight: 500;
        text-decoration: none;
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-ghost-sm:hover {
        background: var(--border);
        color: var(--ink1);
        text-decoration: none;
    }

    .mono {
        font-family: monospace;
        font-size: 11px;
        color: var(--ink3);
    }

    /* Button styles */
    .add-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: var(--primary);
        color: white;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.15s;
    }

    .add-btn:hover {
        background: #134080;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(26, 79, 160, 0.2);
        color: white;
        text-decoration: none;
    }

    .btn-ghost {
        display: inline-flex;
        align-items: center;
        padding: 8px 16px;
        background: var(--bg2);
        color: var(--ink2);
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-ghost:hover {
        background: var(--border);
        color: var(--ink1);
        text-decoration: none;
    }

    /* Page Header */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 24px;
        gap: 16px;
    }

    .page-header-title {
        font-size: 24px;
        font-weight: 600;
        color: var(--ink1);
        margin: 0 0 8px 0;
    }

    .breadcrumb {
        display: flex;
        flex-wrap: wrap;
        padding: 0;
        margin: 0;
        list-style: none;
        gap: 8px;
        font-size: 13px;
    }

    .breadcrumb-item {
        color: var(--ink3);
    }

    .breadcrumb-item a {
        color: var(--primary);
        text-decoration: none;
    }

    .breadcrumb-item a:hover {
        text-decoration: underline;
    }

    .breadcrumb-item.active {
        color: var(--ink2);
        font-weight: 500;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "/";
        margin-right: 8px;
        color: var(--ink4);
    }

    /* CSS Variables */
    :root {
        --ink1: #1a1a1a;
        --ink2: #4a4a4a;
        --ink3: #8a8a8a;
        --ink4: #c0c0c0;
        --border: #e5e5e5;
        --bg2: #f8f8f8;
        --card-bg: #ffffff;
        --primary: #1a4fa0;
    }

    /* Responsive */
    @@media (max-width: 900px) {
        .detail-grid {
            grid-template-columns: 1fr;
            gap: 16px;
        }

        .profile-card {
            position: static;
        }

        .detail-grid-2,
        .detail-grid-3 {
            grid-template-columns: 1fr;
            gap: 16px;
        }
    }

    @@media (max-width: 768px) {
        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .add-btn,
        .btn-ghost {
            width: 100%;
            justify-content: center;
        }

        .detail-section-body {
            padding: 16px;
        }

        .profile-avatar-lg {
            width: 80px;
            height: 80px;
            font-size: 36px;
        }

        .profile-name {
            font-size: 16px;
        }
    }
</style>