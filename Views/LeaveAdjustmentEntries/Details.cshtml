@model EmployeesManagement.Models.LeaveAdjustmentEntry

@{
    ViewData["Title"] = "Leave Adjustment Details";
    var adjustmentType = Model.AdjustmentType?.Description ?? "Addition";
    var adjustmentTypeColor = adjustmentType == "Addition" ? "#1a7a4a" : "#c0392b";
    var adjustmentTypeBg = adjustmentType == "Addition" ? "#e8f5ee" : "#fdecea";
    var days = Model.NoOfDays;
    var daysColor = adjustmentType == "Addition" ? "#1a7a4a" : "#c0392b";
    var daysBg = adjustmentType == "Addition" ? "#e8f5ee" : "#fdecea";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Leave Adjustment Details</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Leave Adjustments</a></li>
            <li class="breadcrumb-item active">@(Model.Employee?.FullName ?? "Adjustment")</li>
        </ol>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="add-btn">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M9.5 2.5l2 2-7 7H2.5v-2l7-7z" stroke="currentColor" stroke-width="1.3" fill="none"/>
            </svg>
            Edit Adjustment
        </a>
        <a asp-action="Index" class="btn-ghost">Back to List</a>
    </div>
</div>

<div class="detail-grid">
    <!-- Left: Profile card -->
    <div>
        <div class="profile-card">
            <div class="profile-card-top">
                <div class="profile-avatar-lg" style="background:#e8eefa;color:#1a4fa0;font-size:32px;">@(Model.Employee?.FullName?.Substring(0, 1).ToUpper() ?? "E")</div>
                <div class="profile-name">@(Model.Employee?.FullName ?? "N/A")</div>
                <div class="profile-role">
                    <span class="dept-badge" style="background:#e8eefa;color:#1a4fa0;font-size:14px;padding:6px 12px;">@(Model.Employee?.EmpNo ?? "N/A")</span>
                </div>
            </div>
            <div class="profile-card-body">
                <div class="info-row">
                    <div class="info-icon">📅</div>
                    <div>
                        <div class="info-label">LEAVE PERIOD</div>
                        <div class="info-value">@Model.LeavePeriod</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">⚙️</div>
                    <div>
                        <div class="info-label">ADJUSTMENT TYPE</div>
                        <div class="info-value">
                            <span class="type-badge" style="background:@adjustmentTypeBg;color:@adjustmentTypeColor">@adjustmentType</span>
                        </div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">🔢</div>
                    <div>
                        <div class="info-label">DAYS ADJUSTED</div>
                        <div class="info-value">
                            <span class="days-badge" style="background:@daysBg;color:@daysColor">@(adjustmentType == "Deduction" ? "-" : "+")@days day@(days != 1 ? "s" : "")</span>
                        </div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">📝</div>
                    <div>
                        <div class="info-label">DESCRIPTION</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model.AdjustmentDescription) ? "—" : Model.AdjustmentDescription)</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Audit card -->
        <div class="profile-card" style="margin-top:16px">
            <div class="detail-section-header" style="border-radius:var(--r-lg) var(--r-lg) 0 0">
                Audit Information
            </div>
            <div class="profile-card-body">
                <div class="info-row">
                    <div class="info-icon">⊕</div>
                    <div>
                        <div class="info-label">CREATED BY</div>
                        <div class="info-value">@(Model.CreatedById ?? "System")</div>
                        <div class="mono" style="font-size:11px;color:var(--ink4)">@Model.CreatedOn.ToString("dd MMM yyyy, HH:mm")</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">✎</div>
                    <div>
                        <div class="info-label">LAST MODIFIED</div>
                        <div class="info-value">@(Model.ModifiedById ?? "Not modified")</div>
                        @if (!string.IsNullOrEmpty(Model.ModifiedById))
                        {
                            <div class="mono" style="font-size:11px;color:var(--ink4)">@Model.ModifiedOn.ToString("dd MMM yyyy, HH:mm")</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Detail sections -->
    <div class="detail-sections">
        <!-- Adjustment Information -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <rect x="2" y="3" width="10" height="8" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M5 2v2M9 2v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Adjustment Information
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-2">
                    <div>
                        <div class="detail-field-label">LEAVE PERIOD</div>
                        <div class="detail-field-value">@Model.LeavePeriod</div>
                    </div>
                    <div>
                        <div class="detail-field-label">ADJUSTMENT DATE</div>
                        <div class="detail-field-value">@Model.LeaveAdjustmentDate.ToString("dd MMMM yyyy")</div>
                    </div>
                    <div>
                        <div class="detail-field-label">ADJUSTMENT TYPE</div>
                        <div class="detail-field-value">
                            <span class="type-badge" style="background:@adjustmentTypeBg;color:@adjustmentTypeColor">@adjustmentType</span>
                        </div>
                    </div>
                    <div>
                        <div class="detail-field-label">NUMBER OF DAYS</div>
                        <div class="detail-field-value">
                            <span class="days-badge" style="background:@daysBg;color:@daysColor">@days day@(days != 1 ? "s" : "")</span>
                        </div>
                    </div>
                    <div>
                        <div class="detail-field-label">DESCRIPTION</div>
                        <div class="detail-field-value">@(string.IsNullOrEmpty(Model.AdjustmentDescription) ? "—" : Model.AdjustmentDescription)</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Leave Period Details -->
        @if (Model.LeaveStartDate.HasValue || Model.LeaveEndDate.HasValue)
        {
            <div class="detail-section">
                <div class="detail-section-header">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                        <rect x="1.5" y="2.5" width="11" height="9" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                        <path d="M3 5h8M3 7h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                    </svg>
                    Leave Period Details
                </div>
                <div class="detail-section-body">
                    <div class="detail-grid-2">
                        @if (Model.LeaveStartDate.HasValue)
                        {
                            <div>
                                <div class="detail-field-label">LEAVE START DATE</div>
                                <div class="detail-field-value">@Model.LeaveStartDate.Value.ToString("dd MMMM yyyy")</div>
                            </div>
                        }
                        @if (Model.LeaveEndDate.HasValue)
                        {
                            <div>
                                <div class="detail-field-label">LEAVE END DATE</div>
                                <div class="detail-field-value">@Model.LeaveEndDate.Value.ToString("dd MMMM yyyy")</div>
                            </div>
                        }
                        @if (Model.LeaveStartDate.HasValue && Model.LeaveEndDate.HasValue)
                        {
                            var totalDays = (Model.LeaveEndDate.Value - Model.LeaveStartDate.Value).Days + 1;
                            <div>
                                <div class="detail-field-label">TOTAL LEAVE DAYS</div>
                                <div class="detail-field-value">@totalDays days</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Employee Information -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <circle cx="7" cy="5" r="3" fill="currentColor" />
                    <path d="M1 13c0-3.31 2.69-6 6-6s6 2.69 6 6" stroke="currentColor" stroke-width="1.3" fill="none" />
                </svg>
                Employee Information
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-2">
                    <div>
                        <div class="detail-field-label">EMPLOYEE NAME</div>
                        <div class="detail-field-value">@(Model.Employee?.FullName ?? "N/A")</div>
                    </div>
                    <div>
                        <div class="detail-field-label">EMPLOYEE ID</div>
                        <div class="detail-field-value mono">@(Model.Employee?.EmpNo ?? "N/A")</div>
                    </div>
                    <div>
                        <div class="detail-field-label">DEPARTMENT</div>
                        <div class="detail-field-value">@(Model.Employee?.Department?.Name ?? "N/A")</div>
                    </div>
                    <div>
                        <div class="detail-field-label">DESIGNATION</div>
                        <div class="detail-field-value">@(Model.Employee?.Designation?.Name ?? "N/A")</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Statistics Section -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <rect x="2" y="4" width="2" height="8" fill="currentColor"/>
                    <rect x="6" y="2" width="2" height="10" fill="currentColor"/>
                    <rect x="10" y="3" width="2" height="9" fill="currentColor"/>
                </svg>
                Leave Balance Impact
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-3">
                    <div class="stat-card">
                        <div class="stat-label">BEFORE ADJUSTMENT</div>
                        <div class="stat-value">@(Model.Employee?.LeaveOutStandingBalance ?? 0)</div>
                    </div>
                    <div class="stat-card highlight">
                        <div class="stat-label">ADJUSTMENT</div>
                        <div class="stat-value @(adjustmentType == "Deduction" ? "deduction" : "addition")">@(adjustmentType == "Deduction" ? "-" : "+")@days</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">AFTER ADJUSTMENT</div>
                        <div class="stat-value">@((Model.Employee?.LeaveOutStandingBalance ?? 0) + (adjustmentType == "Deduction" ? -days : days))</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Related Actions -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <path d="M2 4h10v8H2V4z" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M4 2v2M10 2v2M2 7h10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Related Actions
            </div>
            <div class="detail-section-body">
                <div class="action-buttons">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="action-link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                            <path d="M11 2l3 3-8 8H3v-3l8-8z" stroke="currentColor" stroke-width="1.2" fill="none"/>
                        </svg>
                        Edit Adjustment
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="action-link delete">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                            <path d="M3 4h10M5 4V3a1.5 1.5 0 0 1 3 0v1M11 4l-.7 8H5.7L5 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" fill="none"/>
                        </svg>
                        Delete Adjustment
                    </a>
                    <a asp-controller="Employees" asp-action="Details" asp-route-id="@Model.EmployeeId" class="action-link">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                            <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2"/>
                            <path d="M8 5v3l2 1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                        </svg>
                        View Employee Profile
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Detail Grid Layout */
    .detail-grid {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: 20px;
    }

    /* Profile Card Styles */
    .profile-card {
        background: var(--card-bg);
        border-radius: 16px;
        border: 1px solid var(--border);
        overflow: hidden;
        position: sticky;
        top: 20px;
    }

    .profile-card-top {
        text-align: center;
        padding: 24px 20px 16px;
        background: linear-gradient(135deg, var(--bg2) 0%, var(--card-bg) 100%);
        border-bottom: 1px solid var(--border);
    }

    .profile-avatar-lg {
        width: 100px;
        height: 100px;
        margin: 0 auto 16px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 48px;
        font-weight: 600;
        border-radius: 50%;
        overflow: hidden;
    }

    .profile-name {
        font-size: 18px;
        font-weight: 600;
        color: var(--ink1);
        margin-bottom: 4px;
    }

    .profile-role {
        font-size: 12px;
        color: var(--ink3);
    }

    .profile-card-body {
        padding: 16px;
    }

    .info-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid var(--border);
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-icon {
        width: 32px;
        height: 32px;
        background: var(--bg2);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
    }

    .info-label {
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--ink4);
        margin-bottom: 2px;
    }

    .info-value {
        font-size: 13px;
        font-weight: 500;
        color: var(--ink1);
    }

    /* Detail Sections Styles */
    .detail-sections {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .detail-section {
        background: var(--card-bg);
        border-radius: 12px;
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .detail-section-header {
        padding: 14px 20px;
        background: var(--bg2);
        border-bottom: 1px solid var(--border);
        font-weight: 600;
        font-size: 13px;
        color: var(--ink2);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .detail-section-body {
        padding: 20px;
    }

    .detail-grid-2 {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    .detail-grid-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }

    .detail-field-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--ink4);
        margin-bottom: 6px;
    }

    .detail-field-value {
        font-size: 13px;
        font-weight: 500;
        color: var(--ink1);
        word-break: break-word;
    }

    /* Badge styles */
    .dept-badge, .type-badge, .days-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
    }

    .mono {
        font-family: monospace;
        font-size: 11px;
        color: var(--ink3);
    }

    /* Stat Card */
    .stat-card {
        background: var(--bg2);
        border-radius: 12px;
        padding: 16px;
        text-align: center;
    }

    .stat-card.highlight {
        background: linear-gradient(135deg, #e8eefa 0%, #e8f5ee 100%);
        border: 1px solid var(--primary);
    }

    .stat-label {
        font-size: 11px;
        color: var(--ink4);
        text-transform: uppercase;
        letter-spacing: 0.3px;
        margin-bottom: 4px;
    }

    .stat-value {
        font-size: 24px;
        font-weight: 600;
        color: var(--ink1);
        line-height: 1.2;
    }

    .stat-value.addition {
        color: #1a7a4a;
    }

    .stat-value.deduction {
        color: #c0392b;
    }

    /* Action Links */
    .action-buttons {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .action-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        background: var(--bg2);
        border-radius: 8px;
        color: var(--ink2);
        text-decoration: none;
        transition: all 0.15s;
        font-size: 13px;
        font-weight: 500;
    }

    .action-link:hover {
        background: var(--border);
        color: var(--primary);
        text-decoration: none;
    }

    .action-link.delete:hover {
        background: #fdecea;
        color: #c0392b;
    }

    /* Button styles */
    .add-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: var(--primary);
        color: white;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.15s;
    }

    .add-btn:hover {
        background: #134080;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(26, 79, 160, 0.2);
        color: white;
        text-decoration: none;
    }

    .btn-ghost {
        display: inline-flex;
        align-items: center;
        padding: 8px 16px;
        background: var(--bg2);
        color: var(--ink2);
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-ghost:hover {
        background: var(--border);
        color: var(--ink1);
        text-decoration: none;
    }

    /* Page Header */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 24px;
        gap: 16px;
    }

    .page-header-title {
        font-size: 24px;
        font-weight: 600;
        color: var(--ink1);
        margin: 0 0 8px 0;
    }

    .breadcrumb {
        display: flex;
        flex-wrap: wrap;
        padding: 0;
        margin: 0;
        list-style: none;
        gap: 8px;
        font-size: 13px;
    }

    .breadcrumb-item {
        color: var(--ink3);
    }

    .breadcrumb-item a {
        color: var(--primary);
        text-decoration: none;
    }

    .breadcrumb-item a:hover {
        text-decoration: underline;
    }

    .breadcrumb-item.active {
        color: var(--ink2);
        font-weight: 500;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "/";
        margin-right: 8px;
        color: var(--ink4);
    }

    /* CSS Variables */
    :root {
        --ink1: #1a1a1a;
        --ink2: #4a4a4a;
        --ink3: #8a8a8a;
        --ink4: #c0c0c0;
        --border: #e5e5e5;
        --bg2: #f8f8f8;
        --card-bg: #ffffff;
        --primary: #1a4fa0;
    }

    /* Responsive */
    @@media (max-width: 900px) {
        .detail-grid {
            grid-template-columns: 1fr;
            gap: 16px;
        }

        .profile-card {
            position: static;
        }

        .detail-grid-2,
        .detail-grid-3 {
            grid-template-columns: 1fr;
            gap: 16px;
        }
    }

    @@media (max-width: 768px) {
        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .add-btn,
        .btn-ghost {
            width: 100%;
            justify-content: center;
        }

        .detail-section-body {
            padding: 16px;
        }

        .profile-avatar-lg {
            width: 80px;
            height: 80px;
            font-size: 36px;
        }

        .profile-name {
            font-size: 16px;
        }
    }
</style>