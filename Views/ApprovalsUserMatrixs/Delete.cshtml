@model EmployeesManagement.Models.ApprovalsUserMatrix

@{
    ViewData["Title"] = "Delete Approval Matrix";
    var userName = Model.User?.FullName ?? "N/A";
    var documentType = Model.DocumentType?.Description ?? "N/A";
    var groupCode = Model.WorkFlowUserGroup?.Code ?? "N/A";
    var groupDescription = Model.WorkFlowUserGroup?.Description ?? "";
    var isActive = Model.Active;
    var bgColor = "#fdecea";
    var textColor = "#c0392b";
    var userBg = "#e8eefa";
    var userText = "#1a4fa0";
    var docTypeBg = "#f0eeff";
    var docTypeText = "#4a35c0";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Delete Approval Matrix</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Approvals User Matrix</a></li>
            <li class="breadcrumb-item active">Delete</li>
        </ol>
    </div>
</div>

<div class="delete-card">
    <!-- Warning header -->
    <div class="delete-warning-header">
        <div class="delete-warning-icon">⚠</div>
        <div>
            <div class="delete-warning-title">This action cannot be undone</div>
            <div class="delete-warning-sub">Deleting this approval matrix will permanently remove this approval routing configuration.</div>
        </div>
    </div>

    <!-- Approval Matrix summary -->
    <div style="padding:20px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:14px;flex-wrap:wrap">
        <div class="emp-avatar" style="width:48px;height:48px;border-radius:12px;background:@userBg;color:@userText;border:1px solid var(--border);font-size:20px;font-weight:600">@(userName.Substring(0, 1).ToUpper())</div>
        <div style="flex:1">
            <div style="font-size:17px;font-weight:700">@userName</div>
            <div style="font-size:13px;color:var(--ink3);margin-top:2px">
                <span class="dept-badge" style="background:@docTypeBg;color:@docTypeText;margin-right:6px">@documentType</span>
                <span class="dept-badge" style="background:@userBg;color:@userText">@groupCode</span>
            </div>
        </div>
        <span class="mono" style="font-size:12px;color:var(--ink4)">ID: @Model.Id</span>
    </div>

    <!-- Details -->
    <dl class="delete-dl">
        <dt>User</dt>
        <dd>
            <div class="emp-cell">
                <div class="emp-avatar" style="background:@userBg;color:@userText;width:28px;height:28px;font-size:11px">@(userName.Substring(0, 1).ToUpper())</div>
                <div>
                    <div>@userName</div>
                    <div style="font-size:11px;color:var(--ink3)">@(Model.User?.Email ?? "")</div>
                </div>
            </div>
        </dd>

        <dt>Document Type</dt>
        <dd><span class="dept-badge" style="background:@docTypeBg;color:@docTypeText">@documentType</span></dd>

        <dt>WorkFlow User Group</dt>
        <dd>
            <div>
                <span class="dept-badge" style="background:@userBg;color:@userText">@groupCode</span>
                @if (!string.IsNullOrEmpty(groupDescription))
                {
                    <div style="font-size:11px;color:var(--ink3);margin-top:4px">@groupDescription</div>
                }
            </div>
        </dd>

        <dt>Status</dt>
        <dd>
            @if (isActive)
            {
                <span class="status-badge active">Active</span>
            }
            else
            {
                <span class="status-badge inactive">Inactive</span>
            }
        </dd>

        <dt>Created On</dt>
        <dd class="mono">@Model.CreatedOn.ToString("dd MMM yyyy HH:mm")</dd>

        <dt>Created By</dt>
        <dd>@(Model.CreatedBy?.FullName ?? "System")</dd>

        <dt>Last Modified</dt>
        <dd class="mono">@(Model.ModifiedOn.ToString("dd MMM yyyy HH:mm") ?? "—")</dd>

        <dt>Modified By</dt>
        <dd>@(Model.ModifiedBy?.FullName ?? "—")</dd>
    </dl>

    <!-- Usage Information -->
    <div style="padding:16px 24px;background:var(--bg2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)">
        <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
            <div style="display:flex;align-items:center;gap:12px">
                <div style="background:var(--warning-bg);border-radius:12px;padding:10px">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#a05c00">
                        <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5" fill="none"/>
                        <path d="M10 6v4M10 14h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                </div>
                <div>
                    <div style="font-size:12px;color:var(--ink4);margin-bottom:2px">PENDING APPROVALS</div>
                    <div style="font-size:20px;font-weight:600;color:var(--ink1)">0</div>
                </div>
            </div>
            <div style="display:flex;align-items:center;gap:12px">
                <div style="background:var(--success-bg);border-radius:12px;padding:10px">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#1a7a4a">
                        <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5" fill="none"/>
                        <path d="M6 10l3 3 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                </div>
                <div>
                    <div style="font-size:12px;color:var(--ink4);margin-bottom:2px">COMPLETED APPROVALS</div>
                    <div style="font-size:20px;font-weight:600;color:var(--ink1)">0</div>
                </div>
            </div>
            <div style="display:flex;align-items:center;gap:12px">
                <div style="background:var(--error-bg);border-radius:12px;padding:10px">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#c0392b">
                        <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5" fill="none"/>
                        <path d="M7 13l6-6M13 13L7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                </div>
                <div>
                    <div style="font-size:12px;color:var(--ink4);margin-bottom:2px">REJECTED APPROVALS</div>
                    <div style="font-size:20px;font-weight:600;color:var(--ink1)">0</div>
                </div>
            </div>
        </div>
        <div style="margin-top:16px;padding:12px;background:var(--error-bg);border-radius:8px;font-size:13px;color:var(--error);display:flex;align-items:center;gap:8px">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor">
                <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3" fill="none"/>
                <path d="M8 5v4M8 12h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
            <span>This approval matrix has <strong>0 associated approval records</strong>. Deleting it will remove this approval routing configuration.</span>
        </div>
    </div>

    <!-- Actions -->
    <div style="padding:16px 24px;background:var(--bg2);border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:10px;flex-wrap:wrap">
        <a asp-action="Index" class="btn-ghost">Cancel</a>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn-ghost">View Details</a>
        <form asp-action="Delete" method="post" style="display:inline">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn-danger-outline">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" style="margin-right:6px;vertical-align:-2px">
                    <path d="M2 4h9M5 4V3a1.5 1.5 0 0 1 3 0v1M10.5 4l-.7 7H3.2L2.5 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" fill="none"/>
                </svg>
                Permanently Delete
            </button>
        </form>
    </div>
</div>

<style>
    /* Delete Card Styles */
    .delete-card {
        max-width: 800px;
        margin: 0 auto;
        background: var(--card-bg);
        border-radius: 20px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.05);
        overflow: hidden;
        border: 1px solid var(--border);
    }

    /* Warning Header */
    .delete-warning-header {
        background: #fff2f0;
        padding: 20px 24px;
        border-bottom: 1px solid rgba(192, 57, 43, 0.2);
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .delete-warning-icon {
        width: 36px;
        height: 36px;
        background: #c0392b;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        font-weight: bold;
    }

    .delete-warning-title {
        font-size: 16px;
        font-weight: 600;
        color: #c0392b;
        margin-bottom: 4px;
    }

    .delete-warning-sub {
        font-size: 13px;
        color: var(--ink3);
    }

    /* Definition List Styles */
    .delete-dl {
        display: grid;
        grid-template-columns: 140px 1fr;
        gap: 8px 0;
        padding: 24px;
        margin: 0;
        border-bottom: 1px solid var(--border);
    }

    .delete-dl dt {
        font-size: 12px;
        font-weight: 500;
        color: var(--ink4);
        letter-spacing: 0.3px;
        text-transform: uppercase;
        padding: 8px 0;
    }

    .delete-dl dd {
        font-size: 14px;
        color: var(--ink1);
        padding: 8px 0;
        margin: 0;
        border-bottom: 1px dashed var(--border);
    }

    .delete-dl dd:last-of-type {
        border-bottom: none;
    }

    /* Badge styles */
    .dept-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
    }

    .status-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
        white-space: nowrap;
    }

    .status-badge.active {
        background: #e8f5ee;
        color: #1a7a4a;
    }

    .status-badge.inactive {
        background: #f2f2ef;
        color: #3a3a38;
    }

    .emp-avatar {
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 14px;
        flex-shrink: 0;
    }

    .emp-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .mono {
        font-family: monospace;
        font-size: 12px;
        color: var(--ink3);
    }

    /* Button styles */
    .btn-ghost {
        display: inline-flex;
        align-items: center;
        padding: 8px 16px;
        background: var(--bg2);
        color: var(--ink2);
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-ghost:hover {
        background: var(--border);
        color: var(--ink1);
        text-decoration: none;
    }

    .btn-danger-outline {
        display: inline-flex;
        align-items: center;
        padding: 8px 20px;
        background: transparent;
        color: #c0392b;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        border: 1px solid #c0392b;
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-danger-outline:hover {
        background: #c0392b;
        color: white;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(192, 57, 43, 0.2);
    }

    /* Page Header */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 24px;
        gap: 16px;
    }

    .page-header-title {
        font-size: 24px;
        font-weight: 600;
        color: var(--ink1);
        margin: 0 0 8px 0;
    }

    .breadcrumb {
        display: flex;
        flex-wrap: wrap;
        padding: 0;
        margin: 0;
        list-style: none;
        gap: 8px;
        font-size: 13px;
    }

    .breadcrumb-item {
        color: var(--ink3);
    }

    .breadcrumb-item a {
        color: var(--primary);
        text-decoration: none;
    }

    .breadcrumb-item a:hover {
        text-decoration: underline;
    }

    .breadcrumb-item.active {
        color: var(--ink2);
        font-weight: 500;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "/";
        margin-right: 8px;
        color: var(--ink4);
    }

    /* Status background colors */
    :root {
        --warning-bg: #fff0d9;
        --success-bg: #e0f2e9;
        --error-bg: #fce8e6;
        --error: #c0392b;
        --ink1: #1a1a1a;
        --ink2: #4a4a4a;
        --ink3: #8a8a8a;
        --ink4: #c0c0c0;
        --border: #e5e5e5;
        --bg2: #f8f8f8;
        --card-bg: #ffffff;
        --primary: #1a4fa0;
    }

    /* Responsive adjustments */
    @@media (max-width: 600px) {
        .delete-card {
            border-radius: 16px;
        }
        
        .delete-warning-header {
            padding: 16px;
        }
        
        .delete-dl {
            grid-template-columns: 1fr;
            gap: 4px 0;
            padding: 16px;
        }
        
        .delete-dl dt {
            padding: 8px 0 4px 0;
        }
        
        .delete-dl dd {
            padding: 4px 0 8px 0;
        }
        
        div[style*="display:flex"] {
            flex-direction: column;
            align-items: stretch !important;
        }
        
        .btn-ghost, .btn-danger-outline {
            text-align: center;
            justify-content: center;
            width: 100%;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<script>
    // Confirmation dialog for deletion
    document.addEventListener('DOMContentLoaded', function() {
        const deleteForm = document.querySelector('form[asp-action="Delete"]');
        if (deleteForm) {
            deleteForm.addEventListener('submit', function(e) {
                if (!confirm('Are you absolutely sure you want to delete this approval matrix? This action cannot be undone.')) {
                    e.preventDefault();
                }
            });
        }
    });
</script>