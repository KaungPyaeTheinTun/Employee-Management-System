@model EmployeesManagement.Models.ApprovalsUserMatrix

@{
    ViewData["Title"] = "Edit Approval Matrix";
    var userName = Model.User?.FullName ?? "N/A";
    var documentType = Model.DocumentType?.Description ?? "N/A";
    var groupCode = Model.WorkFlowUserGroup?.Code ?? "N/A";
    var groupDescription = Model.WorkFlowUserGroup?.Description ?? "";
    var isActive = Model.Active;
    var userBg = "#e8eefa";
    var userText = "#1a4fa0";
    var docTypeBg = "#f0eeff";
    var docTypeText = "#4a35c0";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Edit Approval Matrix</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Approvals User Matrix</a></li>
            <li class="breadcrumb-item active">Edit @userName</li>
        </ol>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn-ghost">View Details</a>
        <a asp-action="Index" class="btn-ghost">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px">
                <path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Back to List
        </a>
    </div>
</div>

<form asp-action="Edit" id="editForm">
    <div asp-validation-summary="ModelOnly" class="field-error" style="padding:12px 16px;background:var(--red-bg);border-radius:9px;border:1px solid rgba(192,57,43,0.2);margin-bottom:20px;"></div>

    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CreatedById" />
    <input type="hidden" asp-for="CreatedOn" />

    <!-- Approval Matrix Information -->
    <div class="form-card" style="margin-bottom:16px">
        <div class="form-card-header">
            <span class="section-badge blue">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <rect x="2" y="3" width="8" height="6" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M4 2v2M8 2v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Approval Matrix Information
            </span>
            <span class="mono" style="margin-left:auto;font-size:11px;color:var(--ink4)">ID: @Model.Id</span>
        </div>
        <div class="form-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="UserId" class="field-label">User <span class="field-required">*</span></label>
                    <select asp-for="UserId" class="field-control" asp-items="ViewBag.UserId">
                        <option value="">— Select User —</option>
                    </select>
                    <span asp-validation-for="UserId" class="field-error"></span>
                    <span class="field-hint">Select the user who will be part of this approval matrix</span>
                </div>
                <div class="col-md-6">
                    <label asp-for="DocumentTypeId" class="field-label">Document Type <span class="field-required">*</span></label>
                    <select asp-for="DocumentTypeId" class="field-control" asp-items="ViewBag.DocumentTypeId">
                        <option value="">— Select Document Type —</option>
                    </select>
                    <span asp-validation-for="DocumentTypeId" class="field-error"></span>
                    <span class="field-hint">Select the document type this matrix applies to</span>
                </div>
                <div class="col-md-6">
                    <label asp-for="WorkFlowUserGroupId" class="field-label">WorkFlow User Group <span class="field-required">*</span></label>
                    <select asp-for="WorkFlowUserGroupId" class="field-control" asp-items="ViewBag.WorkFlowUserGroupId">
                        <option value="">— Select WorkFlow Group —</option>
                    </select>
                    <span asp-validation-for="WorkFlowUserGroupId" class="field-error"></span>
                    <span class="field-hint">Select the workflow user group for approval routing</span>
                </div>
                <div class="col-md-6">
                    <div class="field-checkbox">
                        <input type="checkbox" asp-for="Active" id="Active" class="checkbox-control" />
                        <label for="Active" class="checkbox-label">Active</label>
                    </div>
                    <span class="field-hint">Inactive entries will not be used in approval workflows</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Preview Card -->
    <div class="form-card" style="margin-bottom:16px;background:var(--bg2);" id="previewCard">
        <div class="form-card-header">
            <span class="section-badge neutral">Live Preview</span>
        </div>
        <div class="form-card-body">
            <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
                <div style="display:flex;align-items:center;gap:12px;">
                    <div id="previewAvatar" class="emp-avatar" style="width:48px;height:48px;background:@userBg;color:@userText;font-size:18px">@(userName.Substring(0, 1).ToUpper())</div>
                    <div>
                        <div style="font-size:11px;color:var(--ink3);margin-bottom:2px;">USER</div>
                        <div id="previewUser" style="font-size:13px;color:var(--ink1);font-weight:500;">@userName</div>
                    </div>
                </div>
                <div style="flex:1">
                    <div style="font-size:11px;color:var(--ink3);margin-bottom:2px;">DOCUMENT TYPE</div>
                    <div id="previewDocType" class="dept-badge" style="background:@docTypeBg;color:@docTypeText;display:inline-block">@documentType</div>
                </div>
                <div>
                    <div style="font-size:11px;color:var(--ink3);margin-bottom:2px;">WORKFLOW GROUP</div>
                    <div id="previewGroup" class="dept-badge" style="background:@userBg;color:@userText;display:inline-block">@groupCode</div>
                </div>
            </div>
            <div style="margin-top:16px;padding:12px;background:var(--card-bg);border-radius:8px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
                <div>
                    <div style="font-size:11px;color:var(--ink3);margin-bottom:2px;">STATUS</div>
                    <div id="previewStatus" class="status-badge @(isActive ? "active" : "inactive")" style="display:inline-block">@(isActive ? "Active" : "Inactive")</div>
                </div>
                <div style="font-size:11px;color:var(--ink4);">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="display:inline;margin-right:4px;vertical-align:-2px">
                        <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2" fill="none"/>
                        <path d="M7 4v4M7 10h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    <span>This matrix will be used for approval routing when active</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="form-actions" style="border-top:none;padding-top:0">
        <a asp-action="Index" class="btn-ghost">Cancel</a>
        <button type="submit" class="btn-primary" style="background-color: black;">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px;vertical-align:-2px">
                <path d="M2 7l3.5 3.5L12 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Update Approval Matrix
        </button>
    </div>
</form>

<style>
    /* Form field styles */
    .field-label {
        display: block;
        font-size: 12px;
        font-weight: 500;
        color: var(--ink2);
        margin-bottom: 6px;
    }

    .field-required {
        color: #c0392b;
        font-size: 12px;
    }

    .field-control {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 13px;
        color: var(--ink1);
        background: var(--card-bg);
        transition: all 0.15s;
    }

    .field-control:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(26, 79, 160, 0.1);
    }

    /* Select field specific styles */
    select.field-control {
        appearance: none;
        background-image: url("data:image/svg+xml,%3Csvg width='12' height='12' viewBox='0 0 12 12' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M2 4L6 8L10 4' stroke='%23666' stroke-width='1.2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-position: right 12px center;
        padding-right: 32px;
        cursor: pointer;
    }

    select.field-control:hover {
        border-color: var(--primary);
    }

    select.field-control option {
        padding: 8px;
        font-size: 13px;
    }

    /* Checkbox styles */
    .field-checkbox {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 0;
        margin-top: 6px;
    }

    .checkbox-control {
        width: 18px;
        height: 18px;
        margin: 0;
        cursor: pointer;
        accent-color: var(--primary);
    }

    .checkbox-label {
        font-size: 14px;
        font-weight: 500;
        color: var(--ink1);
        cursor: pointer;
    }

    .field-error {
        font-size: 11px;
        color: #c0392b;
        margin-top: 4px;
        display: block;
    }

    .field-hint {
        display: block;
        font-size: 11px;
        color: var(--ink3);
        margin-top: 4px;
    }

    input[readonly], 
    input[disabled] {
        background-color: var(--bg2);
        cursor: not-allowed;
        opacity: 0.7;
    }

    /* Form card styles */
    .form-card {
        background: var(--card-bg);
        border-radius: 12px;
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .form-card-header {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        background: var(--bg2);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .form-card-body {
        padding: 20px;
    }

    .section-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
    }

    .section-badge.blue {
        background: #e8eefa;
        color: #1a4fa0;
    }

    .section-badge.green {
        background: #e8f5ee;
        color: #1a7a4a;
    }

    .section-badge.neutral {
        background: var(--bg2);
        color: var(--ink2);
    }

    /* Badge styles */
    .dept-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
    }

    .status-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
        white-space: nowrap;
    }

    .status-badge.active {
        background: #e8f5ee;
        color: #1a7a4a;
    }

    .status-badge.inactive {
        background: #f2f2ef;
        color: #3a3a38;
    }

    .emp-avatar {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 12px;
        flex-shrink: 0;
    }

    .mono {
        font-family: monospace;
        font-size: 11px;
        color: var(--ink3);
    }

    /* Button styles */
    .btn-primary {
        display: inline-flex;
        align-items: center;
        padding: 10px 20px;
        background: var(--primary);
        color: white;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        border: none;
        cursor: pointer;
        transition: all 0.15s;
        text-decoration: none;
    }

    .btn-primary:hover {
        background: #134080;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(26, 79, 160, 0.2);
        color: white;
        text-decoration: none;
    }

    .btn-ghost {
        display: inline-flex;
        align-items: center;
        padding: 10px 20px;
        background: var(--bg2);
        color: var(--ink2);
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-ghost:hover {
        background: var(--border);
        color: var(--ink1);
        text-decoration: none;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        padding: 20px 0;
        border-top: 1px solid var(--border);
        margin-top: 20px;
    }

    /* Page Header */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 24px;
        gap: 16px;
    }

    .page-header-title {
        font-size: 24px;
        font-weight: 600;
        color: var(--ink1);
        margin: 0 0 8px 0;
    }

    .breadcrumb {
        display: flex;
        flex-wrap: wrap;
        padding: 0;
        margin: 0;
        list-style: none;
        gap: 8px;
        font-size: 13px;
    }

    .breadcrumb-item {
        color: var(--ink3);
    }

    .breadcrumb-item a {
        color: var(--primary);
        text-decoration: none;
    }

    .breadcrumb-item a:hover {
        text-decoration: underline;
    }

    .breadcrumb-item.active {
        color: var(--ink2);
        font-weight: 500;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "/";
        margin-right: 8px;
        color: var(--ink4);
    }

    /* Grid system */
    .row {
        display: flex;
        flex-wrap: wrap;
        margin: -8px;
    }

    .g-3 {
        margin: -8px;
    }

    .g-3 > [class*="col-"] {
        padding: 8px;
    }

    .col-md-3 {
        flex: 0 0 25%;
        max-width: 25%;
    }

    .col-md-6 {
        flex: 0 0 50%;
        max-width: 50%;
    }

    /* CSS Variables */
    :root {
        --ink1: #1a1a1a;
        --ink2: #4a4a4a;
        --ink3: #8a8a8a;
        --ink4: #c0c0c0;
        --border: #e5e5e5;
        --bg2: #f8f8f8;
        --card-bg: #ffffff;
        --primary: #1a4fa0;
        --red-bg: rgba(192, 57, 43, 0.1);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .col-md-3,
        .col-md-6 {
            flex: 0 0 100%;
            max-width: 100%;
        }
        
        .form-actions {
            flex-direction: column-reverse;
        }
        
        .btn-primary,
        .btn-ghost {
            width: 100%;
            justify-content: center;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .form-card-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 8px;
        }

        .mono {
            margin-left: 0 !important;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Get form elements
        const userSelect = document.getElementById('UserId');
        const docTypeSelect = document.getElementById('DocumentTypeId');
        const groupSelect = document.getElementById('WorkFlowUserGroupId');
        const activeCheckbox = document.getElementById('Active');
        
        // Preview elements
        const previewAvatar = document.getElementById('previewAvatar');
        const previewUser = document.getElementById('previewUser');
        const previewDocType = document.getElementById('previewDocType');
        const previewGroup = document.getElementById('previewGroup');
        const previewStatus = document.getElementById('previewStatus');

        // Avatar colors
        const avatarColors = [
            { bg: "#e8eefa", text: "#1a4fa0" },
            { bg: "#e8f5ee", text: "#1a7a4a" },
            { bg: "#fef3e0", text: "#a05c00" },
            { bg: "#fdecea", text: "#c0392b" },
            { bg: "#f2f2ef", text: "#3a3a38" },
            { bg: "#f0eeff", text: "#4a35c0" }
        ];

        // Get select option text
        function getSelectedText(select) {
            const selectedOption = select?.options[select.selectedIndex];
            return selectedOption ? selectedOption.text : 'Not selected';
        }

        function getSelectedValue(select) {
            return select?.value || '';
        }

        function updatePreview() {
            // Update User preview
            const userName = getSelectedText(userSelect);
            const userId = getSelectedValue(userSelect);
            let colorIndex = userId.length % avatarColors.length;
            let colors = avatarColors[colorIndex];
            
            if (previewUser) {
                previewUser.textContent = userName || 'Not selected';
            }
            
            if (previewAvatar) {
                let avatarLetter = userName && userName !== 'Not selected' ? userName.substring(0, 1).toUpperCase() : 'U';
                previewAvatar.textContent = avatarLetter;
                previewAvatar.style.backgroundColor = colors.bg;
                previewAvatar.style.color = colors.text;
            }
            
            // Update Document Type preview
            const docTypeName = getSelectedText(docTypeSelect);
            if (previewDocType) {
                previewDocType.textContent = docTypeName || 'Not selected';
                if (docTypeName && docTypeName !== 'Not selected') {
                    previewDocType.style.background = "#f0eeff";
                    previewDocType.style.color = "#4a35c0";
                } else {
                    previewDocType.style.background = "#e8eefa";
                    previewDocType.style.color = "#1a4fa0";
                }
            }
            
            // Update WorkFlow Group preview
            const groupName = getSelectedText(groupSelect);
            if (previewGroup) {
                previewGroup.textContent = groupName || 'Not selected';
                let groupColorIndex = groupName.length % avatarColors.length;
                let groupColors = avatarColors[groupColorIndex];
                previewGroup.style.backgroundColor = groupColors.bg;
                previewGroup.style.color = groupColors.text;
            }
            
            // Update Status preview
            const isActive = activeCheckbox ? activeCheckbox.checked : true;
            if (previewStatus) {
                previewStatus.textContent = isActive ? 'Active' : 'Inactive';
                previewStatus.className = `status-badge ${isActive ? 'active' : 'inactive'}`;
            }
        }

        // Add event listeners
        if (userSelect) userSelect.addEventListener('change', updatePreview);
        if (docTypeSelect) docTypeSelect.addEventListener('change', updatePreview);
        if (groupSelect) groupSelect.addEventListener('change', updatePreview);
        if (activeCheckbox) activeCheckbox.addEventListener('change', updatePreview);
        
        // Track unsaved changes
        const form = document.getElementById('editForm');
        const cancelBtn = document.querySelector('.btn-ghost[asp-action="Index"]');
        let formChanged = false;
        
        if (form) {
            form.addEventListener('input', function() {
                formChanged = true;
            });
        }
        
        if (cancelBtn) {
            cancelBtn.addEventListener('click', function(e) {
                if (formChanged) {
                    if (!confirm('You have unsaved changes. Are you sure you want to leave?')) {
                        e.preventDefault();
                    }
                }
            });
        }
    });
</script>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}