@model IEnumerable<EmployeesManagement.Models.LeaveApplication>

@{
    ViewData["Title"] = "Leave Applications";
    var statusColors = new Dictionary<string, (string bg, string text)>
    {
        ["Pending"] = ("#fef3e0", "#a05c00"),
        ["Approval"] = ("#e8f5ee", "#1a7a4a"),
        ["Reject"] = ("#fdecea", "#c0392b"),
    };
}


<div class="page-header">
    <div>
        <h1 class="page-header-title">Leave Applications</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item active">Leave Applications</li>
        </ol>
    </div>
    <a asp-action="Create" class="add-btn">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
        New Application
    </a>
</div>

<div class="table-card">
    <!-- Toolbar -->
    <div class="table-toolbar">
        <span class="table-title">All Leave Applications</span>

        <div class="filter-chips">
            <div class="chip filter-chip active" data-filter="all">All <span style="opacity:.5;margin-left:2px">@Model.Count()</span></div>
            <div class="chip filter-chip" data-filter="pending">Pending</div>
            <div class="chip filter-chip" data-filter="approval">Approved</div>
            <div class="chip filter-chip" data-filter="reject">Rejected</div>
        </div>

        <div class="table-search">
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
                <circle cx="5.5" cy="5.5" r="4.5" stroke="currentColor" stroke-width="1.2" />
                <path d="M9 9L12 12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
            </svg>
            <input id="tableSearch" type="text" placeholder="Search employee, leave type..." />
        </div>

        <!-- Items per page selector -->
        <div class="items-per-page">
            <select id="itemsPerPage" class="per-page-select">
                <option value="10">10 per page</option>
                <option value="25">25 per page</option>
                <option value="50">50 per page</option>
                <option value="100">100 per page</option>
            </select>
        </div>
    </div>

    <!-- Desktop table -->
    <div class="table-wrap">
        <table class="emp-table" id="leaveApplicationTable">
            <thead>
                <tr>
                    <th data-sort="0">EMPLOYEE</th>
                    <th data-sort="1">LEAVE TYPE</th>
                    <th data-sort="2">DURATION</th>
                    <th data-sort="3">DAYS</th>
                    <th data-sort="4">DATES</th>
                    <th data-sort="5">STATUS</th>
                    <th>ACTIONS</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @{
                    var avatarColors = new[] {
                        ("#e8eefa","#1a4fa0"), ("#e8f5ee","#1a7a4a"), ("#fef3e0","#a05c00"),
                        ("#fdecea","#c0392b"), ("#f2f2ef","#3a3a38"), ("#f0eeff","#4a35c0")
                    };
                    int colorIdx = 0;
                }
                @foreach (var item in Model)
                {
                    var (bg, tc) = avatarColors[colorIdx++ % avatarColors.Length];
                    var employeeInitials = "";
                    if (!string.IsNullOrEmpty(item.Employee?.FirstName) && !string.IsNullOrEmpty(item.Employee?.LastName))
                    {
                        employeeInitials = $"{item.Employee.FirstName.Substring(0, 1)}{item.Employee.LastName.Substring(0, 1)}".ToUpper();
                    }

                    var statusKey = item.Status?.Description ?? "Pending";
                    var (statusBg, statusText) = statusColors.ContainsKey(statusKey) ? statusColors[statusKey] : ("#f2f2ef", "#3a3a38");

                    <tr data-id="@item.Id">
                        <td>
                                <div>
                                    <div class="emp-name">@(item.Employee?.FullName ?? "—")</div>
                                    @* <div class="emp-id">@(item.Employee?.EmpNo ?? "")</div> *@
                                </div>
                        </td>
                        <td>
                            <span class="dept-badge" style="background:@bg;color:@tc">@(item.LeaveType?.Name ?? "—")</span>
                        </td>
                        <td style="color:var(--ink2)">@(item.Duration?.Description ?? "—")</td>
                        <td style="color:var(--ink2);font-weight:500">@item.NoOfDays</td>
                        <td>
                            <div style="display:flex;flex-direction:column;gap:2px">
                                <span class="date-badge">@item.StartDate.ToString("dd MMM yyyy")</span>
                                <span style="font-size:10px;color:var(--ink4);text-align:center">to</span>
                                <span class="date-badge">@item.EndDate.ToString("dd MMM yyyy")</span>
                            </div>
                        </td>
                        <td>
                            <span class="status-badge" style="background:@statusBg;color:@statusText">@statusKey</span>
                        </td>
                        <td>
                            <div class="action-group">
                            <!-- View always enabled -->
                            <a class="action-btn" asp-action="Details" asp-route-id="@item.Id" title="View">
                                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                    <circle cx="7" cy="7" r="2.5" fill="currentColor" />
                                    <path d="M1 7C2.5 3.5 4.5 2 7 2s4.5 1.5 6 5c-1.5 3.5-3.5 5-6 5S2.5 10.5 1 7z" stroke="currentColor" stroke-width="1.2" fill="none" />
                                </svg>
                            </a>

                            <!-- APPROVE -->
                            @if (item.Status?.Code == "Pending")
                            {
                                <a class="action-btn approve" asp-action="Approval" asp-route-id="@item.Id" title="Approve" style="color:#1a7a4a;">
                                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                        <path d="M2 7L5 10L12 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                </a>
                            }
                            else
                            {
                                <span class="action-btn disabled" title="Already approved">
                                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" opacity="0.3">
                                        <path d="M2 7L5 10L12 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                </span>
                            }

                            <!-- EDIT -->
                            @if (item.Status?.Code == "Approval")
                            {
                                <a class="action-btn" asp-action="Edit" asp-route-id="@item.Id" title="Edit">
                                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                        <path d="M9.5 2.5l2 2-7 7H2.5v-2l7-7z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" fill="none"/>
                                    </svg>
                                </a>
                            }
                            else
                            {
                                <span class="action-btn disabled" title="Edit only allowed after approval">
                                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" opacity="0.3">
                                        <path d="M9.5 2.5l2 2-7 7H2.5v-2l7-7z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" fill="none"/>
                                    </svg>
                                </span>
                            }

                            <!-- DELETE -->
                            @if (item.Status?.Code == "Approval" || item.Status?.Code == "Reject")
                            {
                                <a class="action-btn del" asp-action="Delete" asp-route-id="@item.Id" title="Delete">
                                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                        <path d="M2 4h10M5 4V2.5h4V4M11 4l-.75 8H3.75L3 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                                    </svg>
                                </a>
                            }
                            else
                            {
                                <span class="action-btn disabled" title="Delete only allowed after approval">
                                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" opacity="0.3">
                                        <path d="M2 4h10M5 4V2.5h4V4M11 4l-.75 8H3.75L3 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                                    </svg>
                                </span>
                            }

                        </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Mobile cards (injected by JS) -->
        <div id="mobileLeaveCards" class="mobile-emp-cards"></div>
    </div>

    <!-- Pagination -->
    <div class="table-pagination">
        <span class="pagination-info" id="paginationInfo"></span>
        <div class="pagination-controls" id="tablePagination">
            <button class="pagination-btn" id="prevPage" disabled>Previous</button>
            <div class="page-numbers" id="pageNumbers"></div>
            <button class="pagination-btn" id="nextPage">Next</button>
        </div>
    </div>
</div>

<style>
    /* Additional styles for leave applications */
    .status-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
    }

    .date-badge {
        background: var(--bg2);
        padding: 4px 8px;
        border-radius: 20px;
        font-size: 11px;
        color: var(--ink3);
        white-space: nowrap;
        display: inline-block;
    }

    .action-btn.disabled {
        opacity: 0.5;
        cursor: not-allowed;
        pointer-events: none;
    }
    
    .action-btn.approve:hover {
        color: #1a7a4a !important;
        background: #e8f5ee;
    }

    .emp-id {
        font-size: 11px;
        color: var(--ink3);
        margin-top: 2px;
    }

    /* Pagination styles */
    .table-pagination {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px;
        border-top: 1px solid var(--border);
        flex-wrap: wrap;
        gap: 12px;
    }

    .pagination-info {
        font-size: 12px;
        color: var(--ink3);
    }

    .pagination-controls {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .pagination-btn {
        padding: 6px 12px;
        border: 1px solid var(--border);
        background: var(--card-bg);
        border-radius: 6px;
        font-size: 12px;
        color: var(--ink2);
        cursor: pointer;
        transition: all 0.2s;
    }

    .pagination-btn:hover:not(:disabled) {
        background: var(--bg2);
        border-color: var(--primary);
        color: var(--primary);
    }

    .pagination-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .page-numbers {
        display: flex;
        gap: 4px;
    }

    .page-number {
        min-width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--border);
        background: var(--card-bg);
        border-radius: 6px;
        font-size: 12px;
        color: var(--ink2);
        cursor: pointer;
        transition: all 0.2s;
    }

    .page-number:hover {
        background: var(--bg2);
        border-color: var(--primary);
        color: var(--primary);
    }

    .page-number.active {
        background: var(--primary);
        border-color: var(--primary);
        color: white;
    }

    /* Items per page selector */
    .items-per-page {
        margin-left: auto;
    }

    .per-page-select {
        padding: 6px 10px;
        border: 1px solid var(--border);
        border-radius: 6px;
        font-size: 12px;
        color: var(--ink2);
        background: var(--card-bg);
        cursor: pointer;
    }

    .per-page-select:hover {
        border-color: var(--primary);
    }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .emp-table th:nth-child(2),
        .emp-table td:nth-child(2),
        .emp-table th:nth-child(3),
        .emp-table td:nth-child(3),
        .emp-table th:nth-child(4),
        .emp-table td:nth-child(4) {
            display: none;
        }

        .emp-table th:first-child,
        .emp-table td:first-child,
        .emp-table th:nth-child(5),
        .emp-table td:nth-child(5),
        .emp-table th:nth-child(6),
        .emp-table td:nth-child(6),
        .emp-table th:last-child,
        .emp-table td:last-child {
            display: table-cell;
        }
        
        .table-pagination {
            flex-direction: column;
            align-items: flex-start;
        }
        
        .pagination-controls {
            width: 100%;
            justify-content: center;
        }
        
        .items-per-page {
            margin-left: 0;
            width: 100%;
        }
        
        .per-page-select {
            width: 100%;
        }
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
    // Get DOM elements
    const searchInput = document.getElementById('tableSearch');
    const table = document.getElementById('leaveApplicationTable');
    const tableBody = document.getElementById('tableBody');
    const rows = Array.from(tableBody.querySelectorAll('tr'));
    const mobileContainer = document.getElementById('mobileLeaveCards');
    const filterChips = document.querySelectorAll('.filter-chip');
    const itemsPerPageSelect = document.getElementById('itemsPerPage');
    const prevBtn = document.getElementById('prevPage');
    const nextBtn = document.getElementById('nextPage');
    const pageNumbersDiv = document.getElementById('pageNumbers');
    const paginationInfo = document.getElementById('paginationInfo');

    // Pagination state
    let currentPage = 1;
    let itemsPerPage = 10;
    let filteredRows = rows;
    let totalPages = 1;
    let currentStatusFilter = 'all';

    // Initialize
    function init() {
        itemsPerPage = parseInt(itemsPerPageSelect.value);
        filterRows();
        updatePagination();
        renderCurrentPage();
        toggleMobileView();
    }

    // Filter rows based on search and status
    function filterRows() {
        const searchTerm = searchInput.value.toLowerCase();
        
        filteredRows = rows.filter(row => {
            const employeeName = row.querySelector('.emp-name')?.textContent.toLowerCase() || '';
            const leaveType = row.querySelector('.dept-badge')?.textContent.toLowerCase() || '';
            const status = row.querySelector('.status-badge')?.textContent.toLowerCase() || '';

            const matchesSearch = !searchTerm || employeeName.includes(searchTerm) || leaveType.includes(searchTerm);
            const matchesStatus = currentStatusFilter === 'all' || status.includes(currentStatusFilter);
            
            return matchesSearch && matchesStatus;
        });
        
        totalPages = Math.ceil(filteredRows.length / itemsPerPage);
        if (currentPage > totalPages) currentPage = totalPages || 1;
    }

    // Render current page
    function renderCurrentPage() {
        const start = (currentPage - 1) * itemsPerPage;
        const end = start + itemsPerPage;
        const pageRows = filteredRows.slice(start, end);
        
        // Hide all rows first
        rows.forEach(row => row.style.display = 'none');
        
        // Show only current page rows
        pageRows.forEach(row => row.style.display = '');
        
        // Update mobile cards
        generateMobileCards(pageRows);
        
        // Update pagination info
        updatePaginationInfo();
    }

    // Update pagination controls
    function updatePagination() {
        // Update button states
        prevBtn.disabled = currentPage === 1;
        nextBtn.disabled = currentPage === totalPages || totalPages === 0;
        
        // Generate page numbers
        generatePageNumbers();
    }

    // Generate page number buttons
    function generatePageNumbers() {
        pageNumbersDiv.innerHTML = '';
        
        if (totalPages <= 7) {
            // Show all pages
            for (let i = 1; i <= totalPages; i++) {
                addPageButton(i);
            }
        } else {
            // Show first page
            addPageButton(1);
            
            if (currentPage > 3) {
                addEllipsis();
            }
            
            // Show pages around current page
            let start = Math.max(2, currentPage - 1);
            let end = Math.min(totalPages - 1, currentPage + 1);
            
            for (let i = start; i <= end; i++) {
                addPageButton(i);
            }
            
            if (currentPage < totalPages - 2) {
                addEllipsis();
            }
            
            // Show last page
            addPageButton(totalPages);
        }
    }

    function addPageButton(pageNum) {
        const btn = document.createElement('button');
        btn.className = `page-number ${pageNum === currentPage ? 'active' : ''}`;
        btn.textContent = pageNum;
        btn.addEventListener('click', () => {
            currentPage = pageNum;
            renderCurrentPage();
            updatePagination();
        });
        pageNumbersDiv.appendChild(btn);
    }

    function addEllipsis() {
        const span = document.createElement('span');
        span.className = 'page-number';
        span.textContent = '...';
        span.style.cursor = 'default';
        pageNumbersDiv.appendChild(span);
    }

    // Update pagination info text
    function updatePaginationInfo() {
        const start = filteredRows.length ? (currentPage - 1) * itemsPerPage + 1 : 0;
        const end = Math.min(currentPage * itemsPerPage, filteredRows.length);
        paginationInfo.textContent = `Showing ${start}-${end} of ${filteredRows.length} applications`;
        
        // Update the total count in the "All" filter chip
        const allChip = document.querySelector('.filter-chip[data-filter="all"]');
        if (allChip) {
            const countSpan = allChip.querySelector('span');
            if (countSpan) {
                countSpan.textContent = rows.length;
            }
        }
    }

    // Generate mobile cards
    function generateMobileCards(pageRows) {
        if (!mobileContainer) return;
        
        mobileContainer.innerHTML = '';
        
        pageRows.forEach(row => {
            const employeeName = row.querySelector('.emp-name').textContent;
            const employeeId = row.querySelector('.emp-id')?.textContent || '';
            const employeeAvatar = row.querySelector('.emp-avatar');
            const avatarBg = employeeAvatar.style.backgroundColor;
            const avatarColor = employeeAvatar.style.color;
            const avatarText = employeeAvatar.textContent;
            
            const leaveType = row.querySelector('.dept-badge').textContent;
            const leaveTypeBg = row.querySelector('.dept-badge').style.backgroundColor;
            const leaveTypeColor = row.querySelector('.dept-badge').style.color;
            
            const duration = row.querySelector('td:nth-child(3)').textContent.trim();
            const days = row.querySelector('td:nth-child(4)').textContent.trim();
            
            const startDate = row.querySelector('td:nth-child(5) .date-badge:first-child').textContent;
            const endDate = row.querySelector('td:nth-child(5) .date-badge:last-child').textContent;
            
            const status = row.querySelector('.status-badge').textContent;
            const statusBg = row.querySelector('.status-badge').style.backgroundColor;
            const statusText = row.querySelector('.status-badge').style.color;

            const detailsLink = row.querySelector('.action-group a[title="View"]').href;
            const approveLink = row.querySelector('.action-group a[title="Approve"]')?.href;
            const editLink = row.querySelector('.action-group a[title="Edit"]')?.href;
            const deleteLink = row.querySelector('.action-group a[title="Delete"]')?.href;
            const hasApproveEditDelete = approveLink && editLink && deleteLink;

            const card = document.createElement('div');
            card.className = 'mobile-emp-card';
            card.innerHTML = `
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px">
                    <div class="emp-avatar" style="background:${avatarBg};color:${avatarColor}">${avatarText}</div>
                    <div style="flex:1">
                        <div class="emp-name">${employeeName}</div>
                        <div class="emp-id">${employeeId}</div>
                    </div>
                    <span class="status-badge" style="background:${statusBg};color:${statusText}">${status}</span>
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px">
                    <div>
                        <div style="font-size:10px;color:var(--ink3);margin-bottom:2px">LEAVE TYPE</div>
                        <span class="dept-badge" style="background:${leaveTypeBg};color:${leaveTypeColor}">${leaveType}</span>
                    </div>
                    <div>
                        <div style="font-size:10px;color:var(--ink3);margin-bottom:2px">DURATION</div>
                        <div style="font-size:12px">${duration} · ${days} days</div>
                    </div>
                </div>
                <div style="background:var(--bg2);border-radius:8px;padding:10px;margin-bottom:12px;display:flex;justify-content:space-between;align-items:center">
                    <div style="font-size:11px;color:var(--ink3)">📅 ${startDate} — ${endDate}</div>
                </div>
                <div class="action-group" style="justify-content:flex-end">
                    <a class="action-btn" href="${detailsLink}" title="View">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                            <circle cx="7" cy="7" r="2.5" fill="currentColor"/>
                            <path d="M1 7C2.5 3.5 4.5 2 7 2s4.5 1.5 6 5c-1.5 3.5-3.5 5-6 5S2.5 10.5 1 7z" stroke="currentColor" stroke-width="1.2" fill="none"/>
                        </svg>
                    </a>
                    ${approveLink ?
                        `<a class="action-btn approve" href="${approveLink}" title="Approve" style="color: #1a7a4a;">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                <path d="M2 7L5 10L12 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </a>` :
                        `<span class="action-btn disabled" title="Cannot approve">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" opacity="0.3">
                                <path d="M2 7L5 10L12 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>`
                    }
                    ${editLink ?
                        `<a class="action-btn" href="${editLink}" title="Edit">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                <path d="M9.5 2.5l2 2-7 7H2.5v-2l7-7z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" fill="none"/>
                            </svg>
                        </a>` :
                        `<span class="action-btn disabled" title="Cannot edit">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" opacity="0.3">
                                <path d="M9.5 2.5l2 2-7 7H2.5v-2l7-7z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" fill="none"/>
                            </svg>
                        </span>`
                    }
                    ${deleteLink ?
                        `<a class="action-btn del" href="${deleteLink}" title="Delete">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                                <path d="M2 4h10M5 4V2.5h4V4M11 4l-.75 8H3.75L3 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                            </svg>
                        </a>` :
                        `<span class="action-btn disabled" title="Cannot delete">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" opacity="0.3">
                                <path d="M2 4h10M5 4V2.5h4V4M11 4l-.75 8H3.75L3 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                            </svg>
                        </span>`
                    }
                </div>
            `;
            mobileContainer.appendChild(card);
        });
    }

    // Toggle mobile/desktop view
    function toggleMobileView() {
        if (!mobileContainer) return;
        
        if (window.innerWidth <= 768) {
            mobileContainer.style.display = 'block';
        } else {
            mobileContainer.style.display = 'none';
        }
    }

    // Filter chips
    filterChips.forEach(chip => {
        chip.addEventListener('click', function () {
            filterChips.forEach(c => c.classList.remove('active'));
            this.classList.add('active');
            currentStatusFilter = this.dataset.filter;
            currentPage = 1;
            filterRows();
            updatePagination();
            renderCurrentPage();
        });
    });

    // Event Listeners
    searchInput.addEventListener('input', function() {
        currentPage = 1;
        filterRows();
        updatePagination();
        renderCurrentPage();
    });

    itemsPerPageSelect.addEventListener('change', function() {
        itemsPerPage = parseInt(this.value);
        currentPage = 1;
        filterRows();
        updatePagination();
        renderCurrentPage();
    });

    prevBtn.addEventListener('click', function() {
        if (currentPage > 1) {
            currentPage--;
            renderCurrentPage();
            updatePagination();
        }
    });

    nextBtn.addEventListener('click', function() {
        if (currentPage < totalPages) {
            currentPage++;
            renderCurrentPage();
            updatePagination();
        }
    });

    window.addEventListener('resize', toggleMobileView);

    // Initialize
    init();
});
</script>