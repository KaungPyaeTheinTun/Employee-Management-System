@model EmployeesManagement.Models.LeaveApplication

@{
    ViewData["Title"] = "Edit Leave Application";
    var statusColors = new Dictionary<string, (string bg, string text)>
    {
        ["Pending"] = ("#fef3e0", "#a05c00"),
        ["Approved"] = ("#e8f5ee", "#1a7a4a"),
        ["Rejected"] = ("#fdecea", "#c0392b"),
        ["Cancelled"] = ("#f2f2ef", "#3a3a38")
    };
    var currentStatus = Model.Status?.Description ?? "Pending";
    var (statusBg, statusText) = statusColors.ContainsKey(currentStatus) ? statusColors[currentStatus] : ("#f2f2ef", "#3a3a38");
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Edit Leave Application</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Leave Applications</a></li>
            <li class="breadcrumb-item active">Edit Application</li>
        </ol>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        <span class="status-badge" style="background:@statusBg;color:@statusText;padding:6px 12px;font-size:13px">@currentStatus</span>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn-ghost">View Details</a>
        <a asp-action="Index" class="btn-ghost">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px">
                <path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Back to List
        </a>
    </div>
</div>

<form asp-action="Edit" id="editForm" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="field-error" style="padding:12px 16px;background:var(--red-bg);border-radius:9px;border:1px solid rgba(192,57,43,0.2);margin-bottom:20px;"></div>

    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CreatedById" />
    <input type="hidden" asp-for="CreatedOn" />
    <input type="hidden" asp-for="ApprovedById" />
    <input type="hidden" asp-for="ApprovedOn" />
    <input type="hidden" asp-for="RejectedById" />
    <input type="hidden" asp-for="RejectedOn" />

    <!-- Employee Information (Read-only) -->
    <div class="form-card" style="margin-bottom:16px">
        <div class="form-card-header">
            <span class="section-badge blue">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <circle cx="6" cy="4" r="2.5" fill="currentColor"/>
                    <path d="M1 11c0-2.76 2.24-5 5-5s5 2.24 5 5" stroke="currentColor" stroke-width="1.3" fill="none"/>
                </svg>
                Employee Information
            </span>
            <span class="mono" style="margin-left:auto;font-size:11px;color:var(--ink4)">@(Model.Employee?.EmpNo ?? "")</span>
        </div>
        <div class="form-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="EmployeeId" class="field-label">Employee</label>
                    <select asp-for="EmployeeId" class="field-control" asp-items="ViewBag.EmployeeId" disabled>
                        <option value="">— Select employee —</option>
                    </select>
                    <span asp-validation-for="EmployeeId" class="field-error"></span>
                    <small class="field-hint">Employee cannot be changed after creation</small>
                </div>
                <div class="col-md-6">
                    <div class="field-hint" style="margin-top:32px;padding:8px 12px;background:var(--bg2);border-radius:6px">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="display:inline;margin-right:4px;vertical-align:-2px">
                            <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2" fill="none"/>
                            <path d="M7 4v4M7 10h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                        <span>Leave balance: <strong>15 days</strong> remaining</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Leave Details -->
    <div class="form-card" style="margin-bottom:16px">
        <div class="form-card-header">
            <span class="section-badge green">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <rect x="2" y="3" width="8" height="6" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M4 2v2M8 2v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Leave Details
            </span>
        </div>
        <div class="form-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="LeaveTypeId" class="field-label">Leave Type</label>
<select asp-for="LeaveTypeId" class="field-control" asp-items="ViewBag.LeaveTypeId">
    @if (currentStatus != "Pending")
    {
        @:disabled
    }
</select>                        <option value="">— Select leave type —</option>
                    </select>
                    <span asp-validation-for="LeaveTypeId" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="DurationId" class="field-label">Duration</label>
                    <select asp-for="DurationId" class="field-control" asp-items="ViewBag.DurationId">
                            @if (currentStatus != "Pending")
    {
        @:disabled
    }
                        <option value="">— Select duration —</option>
                    </select>
                    <span asp-validation-for="DurationId" class="field-error"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="StartDate" class="field-label">Start Date</label>
                    <input asp-for="StartDate" class="field-control" type="date" id="startDate"/>
                        @if (currentStatus != "Pending")
    {
        @:disabled
    }
                    <span asp-validation-for="StartDate" class="field-error"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="EndDate" class="field-label">End Date</label>
                    <input asp-for="EndDate" class="field-control" type="date" id="endDate"/>
                        @if (currentStatus != "Pending")
    {
        @:disabled
    }
                    <span asp-validation-for="EndDate" class="field-error"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="NoOfDays" class="field-label">Number of Days</label>
                    <input asp-for="NoOfDays" class="field-control" type="number" id="noOfDays" readonly />
                    <span asp-validation-for="NoOfDays" class="field-error"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Additional Information -->
    <div class="form-card" style="margin-bottom:16px">
        <div class="form-card-header">
            <span class="section-badge amber">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <rect x="1" y="2" width="10" height="8" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M1 4l5 3.5L11 4" stroke="currentColor" stroke-width="1.2" fill="none"/>
                </svg>
                Additional Information
            </span>
        </div>
        <div class="form-card-body">
            <div class="row g-3">
                <div class="col-md-12">
                    <label asp-for="Description" class="field-label">Reason / Description</label>
                    <textarea asp-for="Description" class="field-control" rows="4" placeholder="Please provide reason for leave...">    @if (currentStatus != "Pending")
    {
        @:disabled
    }</textarea>
                    <span asp-validation-for="Description" class="field-error"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Approval Information (Visible only for appropriate status) -->
    @if (currentStatus == "Approved" || currentStatus == "Rejected")
    {
        <div class="form-card" style="margin-bottom:16px">
            <div class="form-card-header">
                <span class="section-badge neutral">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                        <circle cx="6" cy="6" r="4" stroke="currentColor" stroke-width="1.2" fill="none"/>
                        <path d="M3 6h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                    </svg>
                    @(currentStatus) Information
                </span>
            </div>
            <div class="form-card-body">
                <div class="row g-3">
                    @if (currentStatus == "Approved")
                    {
                        <div class="col-md-6">
                            <label asp-for="ApprovedById" class="field-label">Approved By</label>
                            <input asp-for="ApprovedById" class="field-control" value="@(Model.ApprovedById ?? "—")" readonly disabled />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ApprovedOn" class="field-label">Approved On</label>
                            <input asp-for="ApprovedOn" class="field-control" value="@(Model.ApprovedOn.ToString("yyyy-MM-dd HH:mm") ?? "—")" readonly disabled />
                        </div>
                    }
                    @if (currentStatus == "Rejected")
                    {
                        <div class="col-md-6">
                            <label asp-for="RejectedById" class="field-label">Rejected By</label>
                            <input asp-for="RejectedById" class="field-control" value="@(Model.RejectedById ?? "—")" readonly disabled />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RejectedOn" class="field-label">Rejected On</label>
                            <input asp-for="RejectedOn" class="field-control" value="@(Model.RejectedOn.ToString("yyyy-MM-dd HH:mm") ?? "—")" readonly disabled />
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Audit Trail -->
    <div class="form-card" style="margin-bottom:16px">
        <div class="form-card-header">
            <span class="section-badge neutral">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <circle cx="6" cy="6" r="4" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M6 3v3l2 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Audit Trail
            </span>
        </div>
        <div class="form-card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="CreatedById" class="field-label">Created By</label>
                    <input asp-for="CreatedById" class="field-control" value="@(Model.CreatedById ?? "System")" readonly disabled />
                </div>
                <div class="col-md-3">
                    <label asp-for="CreatedOn" class="field-label">Created On</label>
                    <input asp-for="CreatedOn" class="field-control" value="@Model.CreatedOn.ToString("yyyy-MM-dd HH:mm")" readonly disabled />
                </div>
                <div class="col-md-3">
                    <label asp-for="ModifiedById" class="field-label">Modified By</label>
                    <input asp-for="ModifiedById" class="field-control" value="@(Model.ModifiedById ?? "—")" readonly disabled />
                </div>
                <div class="col-md-3">
                    <label asp-for="ModifiedOn" class="field-label">Modified On</label>
                    <input asp-for="ModifiedOn" class="field-control" value="@(Model.ModifiedOn.ToString("yyyy-MM-dd HH:mm") ?? "—")" readonly disabled />
                </div>
            </div>
            <div class="field-hint" style="margin-top:12px;padding:8px 12px;background:var(--bg2);border-radius:6px">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="display:inline;margin-right:4px;vertical-align:-2px">
                    <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M7 4v4M7 10h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                <span>System fields are automatically tracked</span>
            </div>
        </div>
    </div>

    <!-- Status Change Section (For managers/admin) -->
    @if (User.IsInRole("Manager") || User.IsInRole("Admin"))
    {
        <div class="form-card" style="margin-bottom:16px;border:1px solid rgba(26,79,160,0.3)">
            <div class="form-card-header" style="background:rgba(26,79,160,0.05)">
                <span class="section-badge blue">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                        <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                        <path d="M6 3v3l2 1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                    </svg>
                    Update Status
                </span>
            </div>
            <div class="form-card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="StatusId" class="field-label">Application Status</label>
                        <select asp-for="StatusId" class="field-control" asp-items="ViewBag.StatusId">
                            <option value="">— Select status —</option>
                        </select>
                        <span asp-validation-for="StatusId" class="field-error"></span>
                    </div>
                    <div class="col-md-6">
                        <div style="margin-top:28px;display:flex;gap:8px">
                            <button type="button" class="btn-ghost" onclick="setStatus(2)">Approve</button>
                            <button type="button" class="btn-danger-outline" onclick="setStatus(3)">Reject</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Actions -->
    <div class="form-actions" style="border-top:none;padding-top:0">
        <a asp-action="Index" class="btn-ghost">Cancel</a>
        <button type="submit" class="btn-primary" @(currentStatus != "Pending" ? "disabled style=opacity:0.5;cursor:not-allowed" : "")>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px;vertical-align:-2px">
                <path d="M2 7l3.5 3.5L12 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Update Application
        </button>
    </div>
</form>

<style>
/* Additional styles for file upload and form elements */
.status-badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
    white-space: nowrap;
}

.file-upload-area {
    position: relative;
    margin-top: 4px;
}

.file-control {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    z-index: 2;
}

.file-upload-hint {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 16px;
    background: var(--bg2);
    border: 1px dashed var(--border);
    border-radius: 8px;
    color: var(--ink3);
    font-size: 13px;
    transition: all 0.2s ease;
}

.file-upload-hint:hover {
    border-color: var(--primary);
    background: rgba(26, 79, 160, 0.05);
    color: var(--primary);
}

.field-control[readonly],
.field-control[disabled] {
    background-color: var(--bg2);
    cursor: not-allowed;
    opacity: 0.7;
}

/* Responsive adjustments */
@@media (max-width: 768px) {
    .field-hint {
        font-size: 11px;
    }
    
    .file-upload-hint {
        font-size: 11px;
        padding: 12px;
    }
    
    .form-card-body .row.g-3 > [class*="col-"] {
        margin-bottom: 8px;
    }
    
    .page-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
    }
    
    .page-header > div:last-child {
        width: 100%;
        flex-wrap: wrap;
    }
}
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const currentStatus = '@currentStatus';
            
            // Calculate number of days between start and end date
            function calculateDays() {
                const startDate = document.getElementById('startDate').value;
                const endDate = document.getElementById('endDate').value;
                const daysField = document.getElementById('noOfDays');
                
                if (startDate && endDate) {
                    const start = new Date(startDate);
                    const end = new Date(endDate);
                    
                    if (end >= start) {
                        const diffTime = Math.abs(end - start);
                        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1; // Inclusive of both dates
                        daysField.value = diffDays;
                    } else {
                        daysField.value = 0;
                        if (currentStatus === 'Pending') {
                            alert('End date must be after start date');
                        }
                    }
                }
            }

            // Only enable date calculation for pending applications
            if (currentStatus === 'Pending') {
                document.getElementById('startDate').addEventListener('change', calculateDays);
                document.getElementById('endDate').addEventListener('change', calculateDays);
            }

            // File upload display
            const fileInput = document.getElementById('attachment');
            if (fileInput) {
                const fileHint = document.querySelector('.file-upload-hint span');
                
                fileInput.addEventListener('change', function(e) {
                    if (this.files && this.files[0]) {
                        const fileName = this.files[0].name;
                        const fileSize = (this.files[0].size / 1024).toFixed(0);
                        fileHint.textContent = `Selected: ${fileName} (${fileSize} KB)`;
                    } else {
                        fileHint.textContent = 'Click to replace file (PDF, DOC, JPG up to 5MB)';
                    }
                });
            }

            // Form validation before submit
            const form = document.getElementById('editForm');
            form.addEventListener('submit', function(e) {
                if (currentStatus !== 'Pending') {
                    e.preventDefault();
                    alert('This application cannot be edited because it is already ' + currentStatus.toLowerCase());
                }
                
                const days = parseInt(document.getElementById('noOfDays').value);
                if (days <= 0) {
                    e.preventDefault();
                    alert('Please select valid start and end dates');
                }
            });

            // Track form changes for unsaved warning
            let formChanged = false;
            form.addEventListener('input', function() {
                formChanged = true;
            });

            // Warn on cancel if changes were made
            const cancelBtn = document.querySelector('.btn-ghost[asp-action="Index"]');
            if (cancelBtn) {
                cancelBtn.addEventListener('click', function(e) {
                    if (formChanged) {
                        if (!confirm('You have unsaved changes. Are you sure you want to leave?')) {
                            e.preventDefault();
                        }
                    }
                });
            }
        });

        // Function to set status (for manager buttons)
        function setStatus(statusId) {
            const statusSelect = document.getElementById('StatusId');
            if (statusSelect) {
                statusSelect.value = statusId;
            }
        }
    </script>
}