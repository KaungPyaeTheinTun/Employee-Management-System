    <script>
        // Mobile sidebar functions
        function toggleMobileSidebar() {
            var sidebar = document.getElementById('mobileSidebar');
            var overlay = document.getElementById('overlay');
            var btn = document.getElementById('togBtn');
            var isOpen = sidebar.classList.contains('open');
            
            if (isOpen) {
                closeMobileSidebar();
            } else {
                sidebar.classList.add('open');
                overlay.classList.add('open');
                btn.classList.add('open');
                document.body.style.overflow = 'hidden';
            }
        }
        
        function closeMobileSidebar() {
            var sidebar = document.getElementById('mobileSidebar');
            var overlay = document.getElementById('overlay');
            var btn = document.getElementById('togBtn');
            
            sidebar.classList.remove('open');
            overlay.classList.remove('open');
            if (btn) btn.classList.remove('open');
            document.body.style.overflow = '';
        }
        
        function toggleMobileSubMenu(element, subId) {
            var sub = document.getElementById(subId);
            var isOpen = sub.classList.contains('open');
            
            // Close all other submenus
            document.querySelectorAll('.mob-sidebar .nav-sub').forEach(function(submenu) {
                if (submenu.id !== subId) {
                    submenu.classList.remove('open');
                }
            });
            
            document.querySelectorAll('.mob-sidebar .nav-dropdown-toggle').forEach(function(item) {
                if (item !== element) {
                    item.classList.remove('expanded');
                }
            });
            
            // Toggle current submenu
            if (sub) {
                sub.classList.toggle('open');
                element.classList.toggle('expanded');
            }
        }
        
        function handleMobileNavClick(element, page) {
            // Remove active class from all nav items
            document.querySelectorAll('.mob-sidebar .nav-item').forEach(function(item) {
                item.classList.remove('active');
            });
            
            // Add active class to clicked item
            element.classList.add('active');
            
            // Close sidebar after navigation
            setTimeout(function() {
                closeMobileSidebar();
            }, 300);
            
            console.log('Navigating to:', page);
        }
        
        function handleMobileSubItemClick(itemName) {
            console.log('Selected sub-item:', itemName);
            closeMobileSidebar();
        }
        
        function showNotification() {
            alert('Notifications feature coming soon!');
        }
        
        // Close mobile sidebar when clicking outside
        document.addEventListener('click', function(event) {
            var sidebar = document.getElementById('mobileSidebar');
            var overlay = document.getElementById('overlay');
            var btn = document.getElementById('togBtn');
            
            if (sidebar && sidebar.classList.contains('open')) {
                if (!sidebar.contains(event.target) && !btn.contains(event.target)) {
                    closeMobileSidebar();
                }
            }
        });
        
        // Handle window resize
        window.addEventListener('resize', function() {
            if (window.innerWidth > 768) {
                closeMobileSidebar();
            }
        });
        
        // Desktop sidebar dropdown toggle (FIXED - includes Setting dropdown)
        document.addEventListener('DOMContentLoaded', function () {
            var dropdownToggles = document.querySelectorAll('.sidebar .nav-dropdown-toggle');

            dropdownToggles.forEach(function (toggle) {
                toggle.addEventListener('click', function (e) {
                    e.stopPropagation();

                    var subId = 
                        this.id === 'HRToggle' ? 'HRSub' :
                        this.id === 'UserToggle' ? 'UserSub' :
                        this.id === 'leaveToggle' ? 'leaveSub' :
                        this.id === 'setToggle' ? 'setSub' :
                        this.id === 'SystemToggle' ? 'SystemSub' : null;

                    if (subId) {
                        var sub = document.getElementById(subId);
                        if (sub) {
                            // Close all other submenus
                            document.querySelectorAll('.sidebar .nav-sub').forEach(function(submenu) {
                                if (submenu.id !== subId) {
                                    submenu.classList.remove('open');
                                }
                            });
                            
                            document.querySelectorAll('.sidebar .nav-dropdown-toggle').forEach(function(item) {
                                if (item.id !== toggle.id) {
                                    item.classList.remove('expanded');
                                }
                            });
                            
                            // Toggle current submenu
                            sub.classList.toggle('open');
                            toggle.classList.toggle('expanded');
                        }
                    }
                });
            });
        });
        
    </script>

