@model EmployeesManagement.Models.Holiday

@{
    ViewData["Title"] = "Delete Holiday";
    
    var duration = (Model.EndDate - Model.StartDate).Days + 1;
    var isUpcoming = Model.StartDate > DateTime.Today;
    var isPast = Model.EndDate < DateTime.Today;
    var initials = !string.IsNullOrEmpty(Model.Title) && Model.Title.Length > 0 
        ? Model.Title.Substring(0, 1).ToUpper() 
        : "H";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Delete Holiday</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Holidays</a></li>
            <li class="breadcrumb-item active">Delete</li>
        </ol>
    </div>
</div>

<div class="delete-card">
    <!-- Warning header -->
    <div class="delete-warning-header">
        <div class="delete-warning-icon">⚠️</div>
        <div>
            <div class="delete-warning-title">This action cannot be undone</div>
            <div class="delete-warning-sub">Deleting this holiday will permanently remove it from the calendar and affect leave calculations for this period.</div>
        </div>
    </div>

    <!-- Holiday summary -->
    <div style="padding:20px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:14px">
        <div class="emp-avatar" style="width:48px;height:48px;border-radius:12px;background:var(--bg2);border:1px solid var(--border);font-size:20px;font-weight:600">@initials</div>
        <div>
            <div style="font-size:17px;font-weight:700">@Model.Title</div>
            <div style="font-size:13px;color:var(--ink3)">@duration day@(duration > 1 ? "s" : "") holiday</div>
        </div>
        @if (isUpcoming)
        {
            <span class="status-badge upcoming" style="margin-left:auto">Upcoming</span>
        }
        else if (isPast)
        {
            <span class="status-badge past" style="margin-left:auto">Past</span>
        }
        else
        {
            <span class="status-badge current" style="margin-left:auto">Current</span>
        }
    </div>

    <!-- Holiday Details -->
    <dl class="delete-dl">
        <dt>Holiday Title</dt>
        <dd>@Model.Title</dd>

        <dt>Start Date</dt>
        <dd>
            @Model.StartDate.ToString("dddd, dd MMMM yyyy")
            <span class="mono" style="display:block;font-size:11px;color:var(--ink4);margin-top:2px">@Model.StartDate.ToString("HH:mm")</span>
        </dd>

        <dt>End Date</dt>
        <dd>
            @Model.EndDate.ToString("dddd, dd MMMM yyyy")
            <span class="mono" style="display:block;font-size:11px;color:var(--ink4);margin-top:2px">@Model.EndDate.ToString("HH:mm")</span>
        </dd>

        <dt>Duration</dt>
        <dd>
            <strong>@duration</strong> calendar day@(duration > 1 ? "s" : "")
        </dd>

        <dt>Description</dt>
        <dd>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div style="background:var(--bg2);padding:8px 12px;border-radius:6px;font-size:13px">@Model.Description</div>
            }
            else
            {
                <span style="color:var(--ink4);font-style:italic">No description provided</span>
            }
        </dd>

        <dt>Created On</dt>
        <dd class="mono">@Model.CreatedOn.ToString("dd MMM yyyy HH:mm")</dd>

        <dt>Created By</dt>
        <dd>@(Model.CreatedBy?.FullName)</dd>

        @if (!string.IsNullOrEmpty(Model.ModifiedById))
        {
            <dt>Last Modified</dt>
            <dd class="mono">@Model.ModifiedOn.ToString("dd MMM yyyy HH:mm")</dd>
            
            <dt>Modified By</dt>
            <dd>@(Model.ModifiedBy?.FullName)</dd>
        }
    </dl>

    <!-- Additional Warning for Current/Upcoming Holidays -->
    @if (isUpcoming)
    {
        <div style="margin:0 24px 20px 24px;padding:12px;background:#fef3e0;border-left:3px solid #a05c00;border-radius:6px">
            <div style="display:flex;gap:10px;align-items:flex-start">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:1px">
                    <circle cx="8" cy="8" r="6.5" stroke="#a05c00" stroke-width="1.2"/>
                    <path d="M8 4v4l2 2" stroke="#a05c00" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                <div style="font-size:12px;color:#a05c00">
                    <strong>Upcoming Holiday</strong><br />
                    This holiday is scheduled for the future. Deleting it will remove it from the calendar.
                </div>
            </div>
        </div>
    }
    else if(isPast)
    {
        <div style="margin:0 24px 20px 24px;padding:12px;background:#fdecea;border-left:3px solid #c0392b;border-radius:6px">
            <div style="display:flex;gap:10px;align-items:flex-start">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:1px">
                    <circle cx="8" cy="8" r="6.5" stroke="#c0392b" stroke-width="1.2"/>
                    <path d="M8 4v4M8 12v-1" stroke="#c0392b" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                <div style="font-size:12px;color:#c0392b">
                    <strong>⚠️ Holiday in Progress</strong><br />
                    This holiday is currently ongoing. Deleting it may affect attendance records and leave calculations for this period.
                </div>
            </div>
        </div>
    }

    <!-- Actions -->
    <div style="padding:16px 24px;background:var(--bg2);border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:10px">
        <a asp-action="Index" class="btn-ghost">Cancel</a>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn-ghost">View Details</a>
        <form asp-action="Delete" method="post" style="display:inline">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn-danger-outline">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" style="margin-right:6px;vertical-align:-2px">
                    <path d="M2 4h9M5 4V3a1.5 1.5 0 0 1 3 0v1M10.5 4l-.7 7H3.2L2.5 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" fill="none"/>
                </svg>
                Permanently Delete Holiday
            </button>
        </form>
    </div>
</div>

<style>
    /* Delete card styles */
    .delete-card {
        background: var(--card-bg);
        border-radius: 16px;
        border: 1px solid var(--border);
        overflow: hidden;
        margin-top: 20px;
    }

    /* Warning header */
    .delete-warning-header {
        background: #fdecea;
        padding: 20px 24px;
        display: flex;
        gap: 14px;
        align-items: flex-start;
        border-bottom: 1px solid rgba(192, 57, 43, 0.2);
    }

    .delete-warning-icon {
        width: 40px;
        height: 40px;
        background: #c0392b;
        border-radius: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: white;
        flex-shrink: 0;
    }

    .delete-warning-title {
        font-size: 15px;
        font-weight: 700;
        color: #c0392b;
        margin-bottom: 4px;
    }

    .delete-warning-sub {
        font-size: 13px;
        color: var(--ink2);
        line-height: 1.4;
    }

    /* Status badges */
    .status-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

    .status-badge.upcoming {
        background: #fef3e0;
        color: #a05c00;
    }

    .status-badge.past {
        background: var(--bg2);
        color: var(--ink3);
    }

    .status-badge.current {
        background: #e8f5ee;
        color: #1a7a4a;
    }

    /* Definition list styles */
    .delete-dl {
        display: grid;
        grid-template-columns: 160px 1fr;
        gap: 12px 8px;
        padding: 20px 24px;
        margin: 0;
        border-bottom: 1px solid var(--border);
    }

    .delete-dl dt {
        font-size: 12px;
        font-weight: 500;
        color: var(--ink3);
        text-transform: uppercase;
        letter-spacing: 0.3px;
        margin: 0;
    }

    .delete-dl dd {
        font-size: 14px;
        color: var(--ink1);
        font-weight: 500;
        margin: 0;
    }

    .mono {
        font-family: monospace;
        font-size: 12px;
        color: var(--ink2);
    }

    .emp-avatar {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    /* Button styles */
    .btn-ghost {
        display: inline-flex;
        align-items: center;
        padding: 8px 16px;
        background: var(--bg2);
        color: var(--ink2);
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-ghost:hover {
        background: var(--border);
        color: var(--ink1);
        text-decoration: none;
    }

    .btn-danger-outline {
        display: inline-flex;
        align-items: center;
        padding: 8px 16px;
        background: transparent;
        color: #c0392b;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        border: 1px solid #c0392b;
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-danger-outline:hover {
        background: #c0392b;
        color: white;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(192, 57, 43, 0.2);
    }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .delete-dl {
            grid-template-columns: 1fr;
            gap: 4px 0;
            padding: 16px;
        }

        .delete-dl dt {
            margin-top: 8px;
            margin-bottom: 2px;
        }

        .delete-dl dt:first-child {
            margin-top: 0;
        }

        .delete-warning-header {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .delete-warning-icon {
            width: 48px;
            height: 48px;
            font-size: 24px;
        }

        div[style*="display:flex;align-items:center;gap:14px"] {
            flex-wrap: wrap;
        }

        .status-badge {
            margin-left: 0 !important;
        }

        div[style*="padding:16px 24px;background:var(--bg2)"] {
            flex-direction: column;
        }

        .btn-ghost,
        .btn-danger-outline {
            width: 100%;
            justify-content: center;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 12px;
        }
    }
</style>