@model EmployeesManagement.Models.Employee

@{
    ViewData["Title"] = "Delete Employee";
    var initials = $"{Model.FirstName?.Substring(0,1)}{Model.LastName?.Substring(0,1)}".ToUpper();
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Delete Employee</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Employees</a></li>
            <li class="breadcrumb-item active">Delete</li>
        </ol>
    </div>
</div>

<div class="delete-card">
    <!-- Warning header -->
    <div class="delete-warning-header">
        <div class="delete-warning-icon">⚠</div>
        <div>
            <div class="delete-warning-title">This action cannot be undone</div>
            <div class="delete-warning-sub">Deleting this employee will permanently remove all their records.</div>
        </div>
    </div>

    <!-- Employee summary -->
    <div style="padding:20px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:14px">
        <div class="emp-avatar" style="width:48px;height:48px;border-radius:12px;background:var(--surface2);border:1px solid var(--border);font-size:16px">@initials</div>
        <div>
            <div style="font-size:17px;font-weight:700">@Model.FirstName @Model.MiddleName @Model.LastName</div>
            <div style="font-size:13px;color:var(--ink3)">@Model.Designation · @Model.Department</div>
        </div>
        <span class="mono" style="margin-left:auto;font-size:12px;color:var(--ink4)">@Model.EmpNo</span>
    </div>

    <!-- Details -->
    <dl class="delete-dl">
        <dt>Employee ID</dt>
        <dd class="mono">@Model.EmpNo</dd>

        <dt>Full Name</dt>
        <dd>@Model.FirstName @Model.MiddleName @Model.LastName</dd>

        <dt>Email</dt>
        <dd>@Model.EmailAddress</dd>

        <dt>Phone</dt>
        <dd>@Model.PhoneNumber</dd>

        <dt>Department</dt>
        <dd>@Model.Department</dd>

        <dt>Designation</dt>
        <dd>@Model.Designation</dd>

        <dt>Country</dt>
        <dd>@Model.Country</dd>

        <dt>Date of Birth</dt>
        <dd>@Model.DateOfBirth.ToString("dd MMMM yyyy")</dd>

        <dt>Created On</dt>
        <dd class="mono">@Model.CreatedOn.ToString("dd MMM yyyy HH:mm")</dd>

        <dt>Created By</dt>
        <dd>@(Model.CreatedById ?? "System")</dd>
    </dl>

    <!-- Actions -->
    <div style="padding:16px 24px;background:var(--surface2);border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:10px">
        <a asp-action="Index" class="btn-ghost">Cancel</a>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn-ghost">View Profile</a>
        <form asp-action="Delete" method="post" style="display:inline">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn-danger-outline">
                <svg width="13" height="13" viewBox="0 0 13 13" fill="none" style="margin-right:6px;vertical-align:-2px">
                    <path d="M2 4h9M5 4V3a1.5 1.5 0 0 1 3 0v1M10.5 4l-.7 7H3.2L2.5 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" fill="none"/>
                </svg>
                Confirm Delete
            </button>
        </form>
    </div>
</div>
