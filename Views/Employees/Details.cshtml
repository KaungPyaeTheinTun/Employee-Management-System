@model EmployeesManagement.Models.Employee

@{
    ViewData["Title"] = "Employee Profile";
    var initials = $"{Model.FirstName?.Substring(0, 1)}{Model.LastName?.Substring(0, 1)}".ToUpper();
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Employee Profile</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Employees</a></li>
            <li class="breadcrumb-item active">@Model.FirstName @Model.LastName</li>
        </ol>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="add-btn">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M9.5 2.5l2 2-7 7H2.5v-2l7-7z" stroke="currentColor" stroke-width="1.3" fill="none" />
            </svg>
            Edit Profile
        </a>
        <a asp-action="Index" class="btn-ghost">Back to List</a>
    </div>
</div>

<div class="detail-grid">
    <!-- Left: Profile card -->
    <div>
        <div class="profile-card">
            <div class="profile-card-top">
                <div class="profile-avatar-lg" style="width: 100%; height:100%;border-radius:20%;">
                    @if (!string.IsNullOrEmpty(Model.Photo))
                    {
                        <img src="~/uploads/@Model.Photo" alt="Employee Photo"
                             style="width:100%;height:100%;object-fit:cover;border-radius:10%;" />
                    }
                    else
                    {
                        @initials
                    }
                </div>
                <div class="profile-name">@Model.FirstName @Model.MiddleName @Model.LastName</div>
                <div class="profile-role">@Model.Designation · @Model.Department</div>
            </div>
            <div class="profile-card-body">
                <div class="info-row">
                    <div class="info-icon">🪪</div>
                    <div>
                        <div class="info-label">EMPLOYEE ID</div>
                        <div class="info-value mono">@Model.EmpNo</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">✉</div>
                    <div>
                        <div class="info-label">EMAIL</div>
                        <div class="info-value" style="word-break:break-all">@Model.EmailAddress</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">☎</div>
                    <div>
                        <div class="info-label">PHONE</div>
                        <div class="info-value">@Model.PhoneNumber</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">📍</div>
                    <div>
                        <div class="info-label">LOCATION</div>
                        <div class="info-value">@Model.Country</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Banking Information Card -->
        <div class="profile-card" style="margin-top:16px">
            <div class="detail-section-header" style="border-radius:var(--r-lg) var(--r-lg) 0 0">
                Banking Information
            </div>
            <div class="profile-card-body">
                <div class="info-row">
                    <div class="info-icon">🏦</div>
                    <div>
                        <div class="info-label">BANK</div>
                        <div class="info-value">@(Model.Bank?.Name ?? "—")</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">🔢</div>
                    <div>
                        <div class="info-label">ACCOUNT NUMBER</div>
                        <div class="info-value mono">@(string.IsNullOrEmpty(Model.BankAccountNo) ? "—" : Model.BankAccountNo)</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">🌍</div>
                    <div>
                        <div class="info-label">IBAN</div>
                        <div class="info-value mono">@(string.IsNullOrEmpty(Model.IBAN) ? "—" : Model.IBAN)</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">⚡</div>
                    <div>
                        <div class="info-label">SWIFT CODE</div>
                        <div class="info-value mono">@(string.IsNullOrEmpty(Model.SWIFTCode) ? "—" : Model.SWIFTCode)</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tax & Social Security Card -->
        <div class="profile-card" style="margin-top:16px">
            <div class="detail-section-header" style="border-radius:var(--r-lg) var(--r-lg) 0 0">
                Tax & Social Security
            </div>
            <div class="profile-card-body">
                <div class="info-row">
                    <div class="info-icon">📋</div>
                    <div>
                        <div class="info-label">KRA PIN</div>
                        <div class="info-value mono">@(string.IsNullOrEmpty(Model.KRAPIN) ? "—" : Model.KRAPIN)</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">🏛️</div>
                    <div>
                        <div class="info-label">NSSF NUMBER</div>
                        <div class="info-value mono">@(string.IsNullOrEmpty(Model.NSSFNO) ? "—" : Model.NSSFNO)</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">🏥</div>
                    <div>
                        <div class="info-label">NHIF NUMBER</div>
                        <div class="info-value mono">@(string.IsNullOrEmpty(Model.NHIF) ? "—" : Model.NHIF)</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Audit card -->
        <div class="profile-card" style="margin-top:16px">
            <div class="detail-section-header" style="border-radius:var(--r-lg) var(--r-lg) 0 0">
                Audit Information
            </div>
            <div class="profile-card-body">
                <div class="info-row">
                    <div class="info-icon">⊕</div>
                    <div>
                        <div class="info-label">CREATED BY</div>
                        <div class="info-value">@(Model.CreatedById ?? "System")</div>
                        <div class="mono" style="font-size:11px;color:var(--ink4)">@Model.CreatedOn.ToString("dd MMM yyyy, HH:mm")</div>
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-icon">✎</div>
                    <div>
                        <div class="info-label">LAST MODIFIED</div>
                        <div class="info-value">@(Model.ModifiedById ?? "Not modified")</div>
                        @if (!string.IsNullOrEmpty(Model.ModifiedById))
                        {
                            <div class="mono" style="font-size:11px;color:var(--ink4)">@Model.ModifiedOn.ToString("dd MMM yyyy, HH:mm")</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Detail sections -->
    <div class="detail-sections">

        <!-- Personal Information -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <circle cx="7" cy="5" r="3" fill="currentColor" />
                    <path d="M1 13c0-3.31 2.69-6 6-6s6 2.69 6 6" stroke="currentColor" stroke-width="1.3" fill="none" />
                </svg>
                Personal Information
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-2">
                    <div>
                        <div class="detail-field-label">EMPLOYEE NUMBER</div>
                        <div class="detail-field-value mono">@Model.EmpNo</div>
                    </div>
                    <div>
                        <div class="detail-field-label">GENDER</div>
                        <div class="detail-field-value">@Model.Gender</div>
                    </div>
                    <div>
                        <div class="detail-field-label">FIRST NAME</div>
                        <div class="detail-field-value">@Model.FirstName</div>
                    </div>
                    <div>
                        <div class="detail-field-label">MIDDLE NAME</div>
                        <div class="detail-field-value">@(string.IsNullOrEmpty(Model.MiddleName) ? "—" : Model.MiddleName)</div>
                    </div>
                    <div>
                        <div class="detail-field-label">LAST NAME</div>
                        <div class="detail-field-value">@Model.LastName</div>
                    </div>
                    <div>
                        <div class="detail-field-label">DATE OF BIRTH</div>
                        <div class="detail-field-value">@Model.DateOfBirth.ToString("dd MMMM yyyy")</div>
                    </div>
                    <div>
                        <div class="detail-field-label">AGE</div>
                        <div class="detail-field-value">@(DateTime.Now.Year - Model.DateOfBirth.Year) years</div>
                    </div>
                    <div>
                        <div class="detail-field-label">PASSPORT NUMBER</div>
                        <div class="detail-field-value">@(string.IsNullOrEmpty(Model.PassportNo) ? "—" : Model.PassportNo)</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Contact Information -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <rect x="1" y="2" width="12" height="10" rx="1.5" stroke="currentColor" stroke-width="1.2"
                          fill="none" />
                    <path d="M1 5l6 4.5L13 5" stroke="currentColor" stroke-width="1.2" fill="none" />
                </svg>
                Contact Information
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-2">
                    <div>
                        <div class="detail-field-label">PHONE NUMBER</div>
                        <div class="detail-field-value">@Model.PhoneNumber</div>
                    </div>
                    <div>
                        <div class="detail-field-label">EMAIL ADDRESS</div>
                        <div class="detail-field-value" style="word-break:break-all">@Model.EmailAddress</div>
                    </div>
                    <div>
                        <div class="detail-field-label">COMPANY EMAIL</div>
                        <div class="detail-field-value" style="word-break:break-all">@(string.IsNullOrEmpty(Model.CompanyEmail) ? "—" : Model.CompanyEmail)</div>
                    </div>
                    <div>
                        <div class="detail-field-label">COUNTRY</div>
                        <div class="detail-field-value">@Model.Country</div>
                    </div>
                    <div>
                        <div class="detail-field-label">ADDRESS</div>
                        <div class="detail-field-value">@(string.IsNullOrEmpty(Model.Address) ? "—" : Model.Address)</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Employment Details -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <rect x="2" y="4" width="10" height="9" rx="1.5" stroke="currentColor" stroke-width="1.2"
                          fill="none" />
                    <path d="M5 4V3a2 2 0 0 1 4 0v1" stroke="currentColor" stroke-width="1.2" fill="none" />
                </svg>
                Employment Details
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-2">
                    <div>
                        <div class="detail-field-label">DEPARTMENT</div>
                        <div class="detail-field-value">
                            <span class="dept-badge">@Model.Department</span>
                        </div>
                    </div>
                    <div>
                        <div class="detail-field-label">DESIGNATION</div>
                        <div class="detail-field-value">@Model.Designation</div>
                    </div>
                    <div>
                        <div class="detail-field-label">EMPLOYMENT DATE</div>
                        <div class="detail-field-value">@Model.EmployeeDate</div>
                    </div>
                    <div>
                        <div class="detail-field-label">EMPLOYMENT TERMS</div>
                        <div class="detail-field-value">@Model.EmploymentTerms</div>
                    </div>
                    <div>
                        <div class="detail-field-label">LEAVE BALANCE</div>
                        <div class="detail-field-value">@Model.LeaveOutStandingBalance days</div>
                    </div>
                    <div>
                        <div class="detail-field-label">ALLOCATED DAYS</div>
                        <div class="detail-field-value">@Model.AllocatedLeaveDays days</div>
                    </div>
                </div>
            </div>
        </div>

            <div class="detail-section">
                <div class="detail-section-header">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                        <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                        <path d="M7 4v3l2 1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                    </svg>
                    Disability Information
                </div>
                <div class="detail-section-body">
                    <div class="detail-grid-2">
                        <div>
                            <div class="detail-field-label">DISABILITY STATUS</div>
                            <div class="detail-field-value">@Model.Disability</div>
                        </div>
                        <div>
                            <div class="detail-field-label">DISABILITY CERTIFICATE</div>
                            <div class="detail-field-value">@(string.IsNullOrEmpty(Model.DisabilityCertificate) ? "—" : Model.DisabilityCertificate)</div>
                        </div>
                    </div>
                </div>
            </div>
    

        <!-- Banking Details Section -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <rect x="1.5" y="2.5" width="11" height="9" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M3 5h8M3 7h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Banking Details
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-2">
                    <div>
                        <div class="detail-field-label">BANK</div>
                        <div class="detail-field-value">@(Model.Bank?.Name ?? "—")</div>
                    </div>
                    <div>
                        <div class="detail-field-label">BANK CODE</div>
                        <div class="detail-field-value">@(Model.Bank?.Code ?? "—")</div>
                    </div>
                    <div>
                        <div class="detail-field-label">ACCOUNT NUMBER</div>
                        <div class="detail-field-value mono">@(string.IsNullOrEmpty(Model.BankAccountNo) ? "—" : Model.BankAccountNo)</div>
                    </div>
                    <div>
                        <div class="detail-field-label">IBAN</div>
                        <div class="detail-field-value mono">@(string.IsNullOrEmpty(Model.IBAN) ? "—" : Model.IBAN)</div>
                    </div>
                    <div>
                        <div class="detail-field-label">SWIFT CODE</div>
                        <div class="detail-field-value mono">@(string.IsNullOrEmpty(Model.SWIFTCode) ? "—" : Model.SWIFTCode)</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tax & Social Security Section -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <path d="M2 4h10v8H2V4z" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M4 2v2M10 2v2M2 7h10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Tax & Social Security
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-2">
                    <div>
                        <div class="detail-field-label">KRA PIN</div>
                        <div class="detail-field-value mono">@(string.IsNullOrEmpty(Model.KRAPIN) ? "—" : Model.KRAPIN)</div>
                    </div>
                    <div>
                        <div class="detail-field-label">NSSF NUMBER</div>
                        <div class="detail-field-value mono">@(string.IsNullOrEmpty(Model.NSSFNO) ? "—" : Model.NSSFNO)</div>
                    </div>
                    <div>
                        <div class="detail-field-label">NHIF NUMBER</div>
                        <div class="detail-field-value mono">@(string.IsNullOrEmpty(Model.NHIF) ? "—" : Model.NHIF)</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Leave Balance Section -->
        <div class="detail-section">
            <div class="detail-section-header">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="opacity:.6">
                    <rect x="2" y="3" width="10" height="8" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M5 2v2M9 2v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Leave Balance
            </div>
            <div class="detail-section-body">
                <div class="detail-grid-3">
                    <div class="stat-card">
                        <div class="stat-label">ALLOCATED DAYS</div>
                        <div class="stat-value">@Model.AllocatedLeaveDays</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">USED DAYS</div>
                        <div class="stat-value">@(Model.AllocatedLeaveDays - Model.LeaveOutStandingBalance)</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">REMAINING BALANCE</div>
                        <div class="stat-value">@Model.LeaveOutStandingBalance</div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    /* Detail Grid Layout */
    .detail-grid {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: 20px;
    }

    /* Profile Card Styles */
    .profile-card {
        background: var(--card-bg);
        border-radius: 16px;
        border: 1px solid var(--border);
        overflow: hidden;
        position: sticky;
        top: 20px;
    }

    .profile-card-top {
        text-align: center;
        padding: 24px 20px 16px;
        background: linear-gradient(135deg, var(--bg2) 0%, var(--card-bg) 100%);
        border-bottom: 1px solid var(--border);
    }

    .profile-avatar-lg {
        width: 120px;
        height: 120px;
        margin: 0 auto 16px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 48px;
        font-weight: 600;
        border-radius: 50%;
        overflow: hidden;
    }

    .profile-name {
        font-size: 18px;
        font-weight: 600;
        color: var(--ink1);
        margin-bottom: 4px;
    }

    .profile-role {
        font-size: 12px;
        color: var(--ink3);
    }

    .profile-card-body {
        padding: 16px;
    }

    .info-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid var(--border);
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-icon {
        width: 32px;
        height: 32px;
        background: var(--bg2);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        flex-shrink: 0;
    }

    .info-label {
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--ink4);
        margin-bottom: 2px;
    }

    .info-value {
        font-size: 13px;
        font-weight: 500;
        color: var(--ink1);
    }

    /* Detail Sections Styles */
    .detail-sections {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .detail-section {
        background: var(--card-bg);
        border-radius: 12px;
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .detail-section-header {
        padding: 14px 20px;
        background: var(--bg2);
        border-bottom: 1px solid var(--border);
        font-weight: 600;
        font-size: 13px;
        color: var(--ink2);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .detail-section-body {
        padding: 20px;
    }

    .detail-grid-2 {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    .detail-grid-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }

    .detail-field-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--ink4);
        margin-bottom: 6px;
    }

    .detail-field-value {
        font-size: 13px;
        font-weight: 500;
        color: var(--ink1);
        word-break: break-word;
    }

    /* Badge styles */
    .dept-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
    }

    .mono {
        font-family: monospace;
        font-size: 11px;
        color: var(--ink3);
    }

    /* Stat Card */
    .stat-card {
        background: var(--bg2);
        border-radius: 12px;
        padding: 16px;
        text-align: center;
    }

    .stat-label {
        font-size: 11px;
        color: var(--ink4);
        text-transform: uppercase;
        letter-spacing: 0.3px;
        margin-bottom: 4px;
    }

    .stat-value {
        font-size: 24px;
        font-weight: 600;
        color: var(--ink1);
        line-height: 1.2;
    }

    /* Button styles */
    .add-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: var(--primary);
        color: white;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.15s;
    }

    .add-btn:hover {
        background: #134080;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(26, 79, 160, 0.2);
        color: white;
        text-decoration: none;
    }

    .btn-ghost {
        display: inline-flex;
        align-items: center;
        padding: 8px 16px;
        background: var(--bg2);
        color: var(--ink2);
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-ghost:hover {
        background: var(--border);
        color: var(--ink1);
        text-decoration: none;
    }

    /* Page Header */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 24px;
        gap: 16px;
    }

    .page-header-title {
        font-size: 24px;
        font-weight: 600;
        color: var(--ink1);
        margin: 0 0 8px 0;
    }

    .breadcrumb {
        display: flex;
        flex-wrap: wrap;
        padding: 0;
        margin: 0;
        list-style: none;
        gap: 8px;
        font-size: 13px;
    }

    .breadcrumb-item {
        color: var(--ink3);
    }

    .breadcrumb-item a {
        color: var(--primary);
        text-decoration: none;
    }

    .breadcrumb-item a:hover {
        text-decoration: underline;
    }

    .breadcrumb-item.active {
        color: var(--ink2);
        font-weight: 500;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "/";
        margin-right: 8px;
        color: var(--ink4);
    }

    /* CSS Variables */
    :root {
        --ink1: #1a1a1a;
        --ink2: #4a4a4a;
        --ink3: #8a8a8a;
        --ink4: #c0c0c0;
        --border: #e5e5e5;
        --bg2: #f8f8f8;
        --card-bg: #ffffff;
        --primary: #1a4fa0;
    }

    /* Responsive */
    @@media (max-width: 900px) {
        .detail-grid {
            grid-template-columns: 1fr;
