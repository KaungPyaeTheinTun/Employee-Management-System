@model EmployeeManagement.ViewModels.EmployeeViewModel

@{
    ViewData["Title"] = "Add New Employee";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Add New Employee</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Employees</a></li>
            <li class="breadcrumb-item active">Add New</li>
        </ol>
    </div>
    <a asp-action="Index" class="btn-ghost">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px">
            <path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Back to List
    </a>
</div>

<form asp-action="Create" id="createForm" method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="field-error" style="padding:12px 16px;background:var(--red-bg);border-radius:9px;border:1px solid rgba(192,57,43,0.2);margin-bottom:20px;"></div>

    <!-- Personal Details -->
    <div class="form-card" style="margin-bottom:16px">
        <div class="form-card-header">
            <span class="section-badge blue">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="4" r="2.5" fill="currentColor"/><path d="M1 11c0-2.76 2.24-5 5-5s5 2.24 5 5" stroke="currentColor" stroke-width="1.3" fill="none"/></svg>
                Personal Details
            </span>
        </div>
        <div class="form-card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="EmpNo" class="field-label">Employee Number</label>
                    <input asp-for="EmpNo" class="field-control" placeholder="e.g. EMP001" />
                    <span asp-validation-for="EmpNo" class="field-error"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="FirstName" class="field-label">First Name</label>
                    <input asp-for="FirstName" class="field-control" placeholder="Enter first name" />
                    <span asp-validation-for="FirstName" class="field-error"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="MiddleName" class="field-label">Middle Name</label>
                    <input asp-for="MiddleName" class="field-control" placeholder="Enter middle name" />
                    <span asp-validation-for="MiddleName" class="field-error"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="LastName" class="field-label">Last Name</label>
                    <input asp-for="LastName" class="field-control" placeholder="Enter last name" />
                    <span asp-validation-for="LastName" class="field-error"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="GenderId" class="field-label">Gender</label>
                    <select asp-for="GenderId" class="field-control" asp-items="ViewBag.GenderId">
                        <option value="">— Select Gender —</option>
                    </select>
                    <span asp-validation-for="GenderId" class="field-error"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="DateOfBirth" class="field-label">Date of Birth</label>
                    <input asp-for="DateOfBirth" class="field-control" type="date" />
                    <span asp-validation-for="DateOfBirth" class="field-error"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Photo" class="field-label">Photo</label>
                    <input name="employeephoto" class="field-control" type="file" accept=".png,.jpg,.jpeg" />
                    <span asp-validation-for="Photo" class="field-error"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Contact Information -->
    <div class="form-card" style="margin-bottom:16px">
        <div class="form-card-header">
            <span class="section-badge green">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><rect x="1" y="2" width="10" height="8" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/><path d="M1 4l5 3.5L11 4" stroke="currentColor" stroke-width="1.2" fill="none"/></svg>
                Contact Information
            </span>
        </div>
        <div class="form-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="PhoneNumber" class="field-label">Phone Number</label>
                    <input asp-for="PhoneNumber" class="field-control" placeholder="+1 234 567 8900" />
                    <span asp-validation-for="PhoneNumber" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="EmailAddress" class="field-label">Email Address</label>
                    <input asp-for="EmailAddress" class="field-control" type="email" placeholder="john@company.com" />
                    <span asp-validation-for="EmailAddress" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="CountryId" class="field-label">Country</label>
                    <select asp-for="CountryId" class="field-control" asp-items="ViewBag.CountryId">
                        <option value="">— Select Country —</option>
                    </select>
                    <span asp-validation-for="CountryId" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="EmployeeDate" class="field-label">Employment Date</label>
                    <input asp-for="EmployeeDate" class="field-control" type="date" placeholder="..." />
                    <span asp-validation-for="EmployeeDate" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Address" class="field-label">Address</label>
                    <textarea asp-for="Address" class="field-control" placeholder="Street, city, postal code" rows="3"></textarea>
                    <span asp-validation-for="Address" class="field-error"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Employment Details -->
    <div class="form-card" style="margin-bottom:16px">
        <div class="form-card-header">
            <span class="section-badge amber">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><rect x="1.5" y="3" width="9" height="8" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/><path d="M4 3V2.5a2 2 0 0 1 4 0V3" stroke="currentColor" stroke-width="1.2" fill="none"/></svg>
                Employment Details
            </span>
        </div>
        <div class="form-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="DepartmentId" class="field-label">Department</label>
                    <select asp-for="DepartmentId" class="field-control" asp-items="ViewBag.DepartmentId">
                        <option value="">— Select Department —</option>
                    </select>
                    <span asp-validation-for="DepartmentId" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="DesignationId" class="field-label">Designation / Position</label>
                    <select asp-for="DesignationId" class="field-control" asp-items="ViewBag.DesignationId">
                        <option value="">— Select Designation —</option>
                    </select>
                    <span asp-validation-for="DesignationId" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="BankId" class="field-label">Bank Id</label>
                    <select asp-for="BankId" class="field-control" asp-items="ViewBag.BankId">
                        <option value="">— Select Bank —</option>
                    </select>
                    <span asp-validation-for="BankId" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="BankAccountNo" class="field-label">Bank Account Number</label>
                    <input asp-for="BankAccountNo" class="field-control" type="type" placeholder="..." />
                    <span asp-validation-for="BankAccountNo" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="IBAN" class="field-label">International Bank Account Number</label>
                    <input asp-for="IBAN" class="field-control" type="type" placeholder="..." />
                    <span asp-validation-for="IBAN" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="SWIFTCode" class="field-label">SWIFT Code</label>
                    <input asp-for="SWIFTCode" class="field-control" type="type" placeholder="..." />
                    <span asp-validation-for="SWIFTCode" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="NSSFNO" class="field-label">N.S.S.F Number</label>
                    <input asp-for="NSSFNO" class="field-control" type="type" placeholder="..." />
                    <span asp-validation-for="NSSFNO" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="NHIF" class="field-label">NHIF Number</label>
                    <input asp-for="NHIF" class="field-control" type="type" placeholder="..." />
                    <span asp-validation-for="NHIF" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="CompanyEmail" class="field-label">Company Email</label>
                    <input asp-for="CompanyEmail" class="field-control" type="email" placeholder="..." />
                    <span asp-validation-for="CompanyEmail" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="KRAPIN" class="field-label">KRA PIN</label>
                    <input asp-for="KRAPIN" class="field-control" type="type" placeholder="..." />
                    <span asp-validation-for="KRAPIN" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PassportNo" class="field-label">Passport Number</label>
                    <input asp-for="PassportNo" class="field-control" type="type" placeholder="..." />
                    <span asp-validation-for="PassportNo" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="EmploymentTermsId" class="field-label">Employment Terms</label>
                    <select asp-for="EmploymentTermsId" class="field-control" asp-items="ViewBag.EmploymentTermsId">
                        <option value="">— Select EmploymentTerms —</option>
                    </select>
                    <span asp-validation-for="EmploymentTermsId" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="DisabilityId" class="field-label">Employment Terms</label>
                    <select asp-for="DisabilityId" class="field-control" asp-items="ViewBag.DisabilityId">
                        <option value="">— Select Disability —</option>
                    </select>
                    <span asp-validation-for="DisabilityId" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="DisabilityCertificate" class="field-label">DisabilityCertificate</label>
                    <input asp-for="DisabilityCertificate" class="field-control" type="type" placeholder="..." />
                    <span asp-validation-for="DisabilityCertificate" class="field-error"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="form-actions" style="border-top:none;padding-top:0">
        <a asp-action="Index" class="btn-ghost">Cancel</a>
        <button type="submit" class="btn-primary" style="background-color: black;">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px;vertical-align:-2px">
                <path d="M2 7l3.5 3.5L12 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Save Employee
        </button>
    </div>
</form>

<style>
    /* Form field styles */
    .field-label {
        display: block;
        font-size: 12px;
        font-weight: 500;
        color: var(--ink2);
        margin-bottom: 6px;
    }

    .field-control {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 13px;
        color: var(--ink1);
        background: var(--card-bg);
        transition: all 0.15s;
    }

    .field-control:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(26, 79, 160, 0.1);
    }

    /* Select field specific styles */
    select.field-control {
        appearance: none;
        background-image: url("data:image/svg+xml,%3Csvg width='12' height='12' viewBox='0 0 12 12' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M2 4L6 8L10 4' stroke='%23666' stroke-width='1.2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-position: right 12px center;
        padding-right: 32px;
        cursor: pointer;
    }

    select.field-control:hover {
        border-color: var(--primary);
    }

    select.field-control option {
        padding: 8px;
        font-size: 13px;
    }

    textarea.field-control {
        resize: vertical;
        min-height: 80px;
    }

    .field-error {
        font-size: 11px;
        color: #c0392b;
        margin-top: 4px;
        display: block;
    }

    .field-hint {
        font-size: 11px;
        color: var(--ink3);
        margin-top: 4px;
        display: block;
    }

    /* Form card styles */
    .form-card {
        background: var(--card-bg);
        border-radius: 12px;
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .form-card-header {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        background: var(--bg2);
    }

    .form-card-body {
        padding: 20px;
    }

    .section-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
    }

    .section-badge.blue {
        background: #e8eefa;
        color: #1a4fa0;
    }

    .section-badge.green {
        background: #e8f5ee;
        color: #1a7a4a;
    }

    .section-badge.amber {
        background: #fef3e0;
        color: #a05c00;
    }

    /* Button styles */
    .btn-primary {
        display: inline-flex;
        align-items: center;
        padding: 10px 20px;
        background: var(--primary);
        color: white;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        border: none;
        cursor: pointer;
        transition: all 0.15s;
        text-decoration: none;
    }

    .btn-primary:hover {
        background: #134080;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(26, 79, 160, 0.2);
        color: white;
        text-decoration: none;
    }

    .btn-ghost {
        display: inline-flex;
        align-items: center;
        padding: 10px 20px;
        background: var(--bg2);
        color: var(--ink2);
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-ghost:hover {
        background: var(--border);
        color: var(--ink1);
        text-decoration: none;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        padding: 20px 0;
        border-top: 1px solid var(--border);
        margin-top: 20px;
    }

    /* Grid system */
    .row {
        display: flex;
        flex-wrap: wrap;
        margin: -8px;
    }

    .g-3 {
        margin: -8px;
    }

    .g-3 > [class*="col-"] {
        padding: 8px;
    }

    .col-md-4 {
        flex: 0 0 33.333333%;
        max-width: 33.333333%;
    }

    .col-md-6 {
        flex: 0 0 50%;
        max-width: 50%;
    }

    .col-md-12 {
        flex: 0 0 100%;
        max-width: 100%;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .col-md-4,
        .col-md-6,
        .col-md-12 {
            flex: 0 0 100%;
            max-width: 100%;
        }
        
        .form-actions {
            flex-direction: column-reverse;
        }
        
        .btn-primary,
        .btn-ghost {
            width: 100%;
            justify-content: center;
        }
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}