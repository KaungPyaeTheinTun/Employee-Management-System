@model EmployeesManagement.Models.SystemProfile

@{
    ViewData["Title"] = "Create System Profile";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Create System Profile</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">System Profiles</a></li>
            <li class="breadcrumb-item active">Create New</li>
        </ol>
    </div>
    <a asp-action="Index" class="btn-ghost" style="background-color:black;color:white; display: inline-flex; align-items: center;">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px">
            <path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Back to List
    </a>
</div>

<form asp-action="Create" id="createForm">
    <div asp-validation-summary="ModelOnly" class="field-error" style="padding:12px 16px;background:var(--red-bg);border-radius:9px;border:1px solid rgba(192,57,43,0.2);margin-bottom:20px;"></div>

    <!-- Profile Details -->
    <div class="form-card" style="margin-bottom:16px">
        <div class="form-card-header">
            <span class="section-badge blue">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <rect x="1.5" y="2.5" width="9" height="7" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M3 5h6M3 7h6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Profile Information
            </span>
        </div>
        <div class="form-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="field-label">Profile Name</label>
                    <input asp-for="Name" class="field-control" placeholder="e.g. Admin Profile, User Profile, etc." />
                    <span asp-validation-for="Name" class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Order" class="field-label">Display Order</label>
                    <input asp-for="Order" class="field-control" type="number" placeholder="e.g. 1, 2, 3..." />
                    <span asp-validation-for="Order" class="field-error"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="ProfileId" class="field-label">Parent Profile</label>
                    <select asp-for="ProfileId" class="field-control" asp-items="ViewBag.ProfileId">
                        <option value="">— Select parent profile (optional) —</option>
                    </select>
                    <span class="field-hint">Leave empty if this is a top-level profile</span>
                    <span asp-validation-for="ProfileId" class="field-error"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Information Card -->
    <div class="form-card" style="margin-bottom:16px;background:var(--bg2);">
        <div class="form-card-body">
            <div style="display:flex;gap:12px;align-items:center">
                <div style="width:32px;height:32px;border-radius:32px;background:var(--primary-bg);color:var(--primary);display:flex;align-items:center;justify-content:center">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2"/>
                        <path d="M8 4v4l2 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                    </svg>
                </div>
                <div>
                    <div style="font-weight:500;margin-bottom:2px">About System Profiles</div>
                    <div style="font-size:12px;color:var(--ink3)">Profiles define the structure of your system hierarchy. You can create parent-child relationships to organize different sections of your application.</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="form-actions" style="border-top:none;padding-top:0">
        <a asp-action="Index" class="btn-ghost">Cancel</a>
        <button type="submit" class="btn-primary" style="background-color:black;color: white; display: inline-flex; align-items: center;">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px;">
        <path d="M2 7l3.5 3.5L12 3" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    Create Profile
</button>
    </div>
</form>

<style>
    /* Form field styles */
    .field-label {
        display: block;
        font-size: 12px;
        font-weight: 500;
        color: var(--ink2);
        margin-bottom: 6px;
    }

    .field-control {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 13px;
        color: var(--ink1);
        background: var(--card-bg);
        transition: all 0.15s;
    }

    .field-control:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(26, 79, 160, 0.1);
    }

    select.field-control {
        appearance: none;
        background-image: url("data:image/svg+xml,%3Csvg width='12' height='12' viewBox='0 0 12 12' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M2 4L6 8L10 4' stroke='%23666' stroke-width='1.2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
        background-repeat: no-repeat;
        background-position: right 12px center;
        padding-right: 32px;
    }

    .field-error {
        font-size: 11px;
        color: #c0392b;
        margin-top: 4px;
        display: block;
    }

    .field-hint {
        font-size: 11px;
        color: var(--ink3);
        margin-top: 4px;
        display: block;
    }

    /* Form card styles */
    .form-card {
        background: var(--card-bg);
        border-radius: 12px;
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .form-card-header {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        background: var(--bg2);
    }

    .form-card-body {
        padding: 20px;
    }

    .section-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
    }

    .section-badge.blue {
        background: #e8eefa;
        color: #1a4fa0;
    }

    .section-badge.green {
        background: #e8f5ee;
        color: #1a7a4a;
    }

    .section-badge.amber {
        background: #fef3e0;
        color: #a05c00;
    }

    /* Button styles */
    .btn-primary {
        display: inline-flex;
        align-items: center;
        padding: 10px 20px;
        background: var(--primary);
        color: white;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        border: none;
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-primary:hover {
        background: #134080;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(26, 79, 160, 0.2);
    }

    .btn-ghost {
        display: inline-flex;
        align-items: center;
        padding: 10px 20px;
        background: var(--bg2);
        color: var(--ink2);
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-ghost:hover {
        background: var(--border);
        color: var(--ink1);
        text-decoration: none;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        padding: 20px 0;
        border-top: 1px solid var(--border);
        margin-top: 20px;
    }

    /* Grid system */
    .row {
        display: flex;
        flex-wrap: wrap;
        margin: -8px;
    }

    .g-3 {
        margin: -8px;
    }

    .g-3 > [class*="col-"] {
        padding: 8px;
    }

    .col-md-4 {
        flex: 0 0 33.333333%;
        max-width: 33.333333%;
    }

    .col-md-6 {
        flex: 0 0 50%;
        max-width: 50%;
    }

    .col-md-12 {
        flex: 0 0 100%;
        max-width: 100%;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .col-md-4,
        .col-md-6,
        .col-md-12 {
            flex: 0 0 100%;
            max-width: 100%;
        }
        
        .form-actions {
            flex-direction: column-reverse;
        }
        
        .btn-primary,
        .btn-ghost {
            width: 100%;
            justify-content: center;
        }
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}