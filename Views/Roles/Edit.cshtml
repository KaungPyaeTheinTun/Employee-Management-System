@model EmployeeManagement.ViewModels.RoleViewModel

@{
    ViewData["Title"] = "Edit Role";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">@ViewData["Title"]</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Roles</a></li>
            <li class="breadcrumb-item active">Edit Role</li>
        </ol>
    </div>
    <a asp-action="Index" class="btn-ghost">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px">
            <path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Back to List
    </a>
</div>

<div class="row" style="justify-content: center;">
    <div class="col-md-8">
        <!-- User Details Card -->
        <div class="form-card" style="max-width:800px;margin:0 auto;">
            <div class="form-card-header">
                <span class="section-badge blue">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                        <circle cx="6" cy="4" r="2.5" fill="currentColor"/>
                        <path d="M1 11c0-2.76 2.24-5 5-5s5 2.24 5 5" stroke="currentColor" stroke-width="1.3" fill="none"/>
                    </svg>
                    Role Information
                </span>
                <span class="field-hint" style="font-size:11px">Edit role details</span>
            </div>

            <div class="form-card-body">
                <form asp-action="Edit" id="createForm">
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="field-error" style="padding:12px 16px;background:var(--red-bg);border-radius:9px;border:1px solid rgba(192,57,43,0.2);margin-bottom:20px;"></div>

                    <!-- Role Name Field with Actions Side by Side -->
                    <div style="display:flex; gap:16px; align-items:flex-end; margin-bottom:24px;">
                        <!-- Role Name Field (takes most of the space) -->
                        <div style="flex:2;">
                            <label asp-for="RoleName" class="field-label">Role Name</label>
                            <div style="position:relative">
                                <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--ink3);">
                                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                                        <rect x="2" y="3" width="12" height="10" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
                                        <path d="M3 5l5 4 5-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                    </svg>
                                </span>
                                <input asp-for="RoleName" class="field-control" style="padding-left:36px;" placeholder="e.g. Admin, Manager, Employee" />
                            </div>
                            <span asp-validation-for="RoleName" class="field-error"></span>
                        </div>
                        
                        <!-- Actions (takes less space) -->
                        <div style="flex:1; display:flex; gap:8px; justify-content:flex-end;">
                            <a asp-action="Index" class="btn-ghost" style="white-space:nowrap;">Cancel</a>
                            <button type="submit" class="btn-primary" style="white-space:nowrap;">
                                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px;vertical-align:-2px">
                                    <path d="M2 7l3.5 3.5L12 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                                Edit Role
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Security Notice -->
        <div style="max-width:800px;margin:20px auto 0;text-align:center;">
            <div class="field-hint" style="font-size:12px;display:flex;align-items:center;justify-content:center;gap:8px;">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <rect x="2" y="5" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M4 5V3.5C4 2 5.5 1 7 1s3 1 3 2.5V5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                <span>All data is encrypted and securely stored</span>
            </div>
        </div>
    </div>
</div>

<style>
/* Form element styles */
.field-checkbox {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 0;
}

.field-checkbox input[type="checkbox"] {
    width: 16px;
    height: 16px;
    margin: 0;
    cursor: pointer;
}

.field-checkbox label {
    font-size: 14px;
    color: var(--ink2);
    cursor: pointer;
    font-weight: normal;
}

/* Input icon positioning */
input.field-control {
    transition: border-color 0.2s, box-shadow 0.2s;
}

input.field-control:focus {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(26, 79, 160, 0.1);
}

/* Password toggle button styles */
.btn-icon {
    transition: color 0.2s, background-color 0.2s;
    z-index: 2;
}

.btn-icon:hover {
    background-color: var(--bg2) !important;
    color: var(--blue) !important;
}

.btn-icon:active {
    background-color: var(--bg3) !important;
}

/* Responsive adjustments */
@@media (max-width: 768px) {
    .form-card {
        margin-left: 12px;
        margin-right: 12px;
    }
    
    .form-card-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 4px;
    }
    
    /* Stack input and buttons vertically on mobile */
    div[style*="display:flex"][style*="align-items:flex-end"] {
        flex-direction: column;
        gap: 16px;
    }
    
    div[style*="flex:1"][style*="display:flex"] {
        width: 100%;
        justify-content: stretch !important;
    }
    
    .btn-ghost, .btn-primary {
        flex: 1;
        justify-content: center !important;
        text-align: center;
    }
}

/* Animation for submit button */
.btn-primary {
    transition: transform 0.2s, box-shadow 0.2s;
}

.btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(26, 79, 160, 0.2);
}

.btn-primary:active {
    transform: translateY(0);
}

/* Section headers */
h4 {
    letter-spacing: -0.01em;
}
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const roleNameInput = document.getElementById('RoleName');
            
            // Focus on role name field on page load
            if (roleNameInput) {
                roleNameInput.focus();
            }
        });
    </script>
}