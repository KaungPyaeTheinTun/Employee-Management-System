@model EmployeesManagement.Models.Bank

@{
    ViewData["Title"] = "Edit Bank";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Edit Bank</h1>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Banks</a></li>
            <li class="breadcrumb-item active">Edit @Model.Code</li>
        </ol>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn-ghost">View Details</a>
        <a asp-action="Index" class="btn-ghost">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px">
                <path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            Back to List
        </a>
    </div>
</div>

<form asp-action="Edit" id="editForm">
    <div asp-validation-summary="ModelOnly" class="field-error" style="padding:12px 16px;background:var(--red-bg);border-radius:9px;border:1px solid rgba(192,57,43,0.2);margin-bottom:20px;"></div>

    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="CreatedById" />
    <input type="hidden" asp-for="CreatedOn" />

    <!-- Bank Information -->
    <div class="form-card" style="margin-bottom:16px">
        <div class="form-card-header">
            <span class="section-badge blue">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <rect x="2" y="3" width="8" height="6" rx="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M4 2v2M8 2v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Bank Information
            </span>
            <span class="mono" style="margin-left:auto;font-size:11px;color:var(--ink4)">ID: @Model.Id</span>
        </div>
        <div class="form-card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Code" class="field-label">Bank Code <span class="field-required">*</span></label>
                    <input asp-for="Code" class="field-control" placeholder="e.g. KCB, EQUITY, ABSA" />
                    <span asp-validation-for="Code" class="field-error"></span>
                    <span class="field-hint">Unique code for the bank (uppercase, no spaces)</span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Name" class="field-label">Bank Name <span class="field-required">*</span></label>
                    <input asp-for="Name" class="field-control" placeholder="e.g. KCB Bank, Equity Bank" />
                    <span asp-validation-for="Name" class="field-error"></span>
                    <span class="field-hint">Full name of the bank</span>
                </div>
                <div class="col-md-4">
                    <label asp-for="AccoutNo" class="field-label">Account Number</label>
                    <input asp-for="AccoutNo" class="field-control" placeholder="e.g. 1234567890" />
                    <span asp-validation-for="AccoutNo" class="field-error"></span>
                    <span class="field-hint">Company account number with this bank (if applicable)</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Preview Card -->
    <div class="form-card" style="margin-bottom:16px;background:var(--bg2);" id="previewCard">
        <div class="form-card-header">
            <span class="section-badge neutral">Live Preview</span>
        </div>
        <div class="form-card-body">
            <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
                <div style="display:flex;align-items:center;gap:12px;">
                    <div id="previewAvatar" class="emp-avatar" style="width:48px;height:48px;background:#e8eefa;color:#1a4fa0;font-size:18px">@(Model.Code?.Substring(0, 1).ToUpper() ?? "B")</div>
                    <div>
                        <div style="font-size:11px;color:var(--ink3);margin-bottom:2px;">BANK CODE</div>
                        <div>
                            <span id="previewBadge" class="dept-badge" style="background:#e8eefa;color:#1a4fa0">@Model.Code</span>
                        </div>
                    </div>
                </div>
                <div style="flex:1">
                    <div style="font-size:11px;color:var(--ink3);margin-bottom:2px;">BANK NAME</div>
                    <div id="previewName" style="font-size:13px;color:var(--ink1);font-weight:500;">@Model.Name</div>
                </div>
                <div>
                    <div style="font-size:11px;color:var(--ink3);margin-bottom:2px;">ACCOUNT NUMBER</div>
                    <div id="previewAccount" class="sequence-badge" style="display:inline-block">@(string.IsNullOrEmpty(Model.AccoutNo) ? "—" : Model.AccoutNo)</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Audit Trail -->
    <div class="form-card" style="margin-bottom:16px">
        <div class="form-card-header">
            <span class="section-badge neutral">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <circle cx="6" cy="6" r="4" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M6 3v3l2 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Audit Trail
            </span>
        </div>
        <div class="form-card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="CreatedById" class="field-label">Created By</label>
                    <input asp-for="CreatedById" class="field-control" value="@(Model.CreatedBy?.FullName ?? "System")" readonly disabled />
                </div>
                <div class="col-md-3">
                    <label asp-for="CreatedOn" class="field-label">Created On</label>
                    <input asp-for="CreatedOn" class="field-control" readonly disabled value="@Model.CreatedOn.ToString("yyyy-MM-dd HH:mm")" />
                </div>
                <div class="col-md-3">
                    <label asp-for="ModifiedById" class="field-label">Modified By</label>
                    <input asp-for="ModifiedById" class="field-control" value="@(Model.ModifiedBy?.FullName ?? "—")" readonly disabled />
                </div>
                <div class="col-md-3">
                    <label asp-for="ModifiedOn" class="field-label">Modified On</label>
                    <input asp-for="ModifiedOn" class="field-control" value="@(Model.ModifiedOn.ToString("yyyy-MM-dd HH:mm") ?? "—")" readonly disabled />
                </div>
            </div>
            <div class="field-hint" style="margin-top:12px;padding:8px 12px;background:var(--bg2);border-radius:6px">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="display:inline;margin-right:4px;vertical-align:-2px">
                    <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2" fill="none"/>
                    <path d="M7 4v4M7 10h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                <span>System fields are automatically tracked and cannot be modified</span>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="form-actions" style="border-top:none;padding-top:0">
        <a asp-action="Index" class="btn-ghost">Cancel</a>
        <button type="submit" class="btn-primary" style="background-color: black;">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="margin-right:6px;vertical-align:-2px">
                <path d="M2 7l3.5 3.5L12 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Update Bank
        </button>
    </div>
</form>

<style>
    /* Form field styles */
    .field-label {
        display: block;
        font-size: 12px;
        font-weight: 500;
        color: var(--ink2);
        margin-bottom: 6px;
    }

    .field-required {
        color: #c0392b;
        font-size: 12px;
    }

    .field-control {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid var(--border);
        border-radius: 8px;
        font-size: 13px;
        color: var(--ink1);
        background: var(--card-bg);
        transition: all 0.15s;
    }

    .field-control:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(26, 79, 160, 0.1);
    }

    .field-error {
        font-size: 11px;
        color: #c0392b;
        margin-top: 4px;
        display: block;
    }

    .field-hint {
        display: block;
        font-size: 11px;
        color: var(--ink3);
        margin-top: 4px;
    }

    input[readonly], 
    input[disabled] {
        background-color: var(--bg2);
        cursor: not-allowed;
        opacity: 0.7;
    }

    /* Form card styles */
    .form-card {
        background: var(--card-bg);
        border-radius: 12px;
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .form-card-header {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border);
        background: var(--bg2);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .form-card-body {
        padding: 20px;
    }

    .section-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
    }

    .section-badge.blue {
        background: #e8eefa;
        color: #1a4fa0;
    }

    .section-badge.green {
        background: #e8f5ee;
        color: #1a7a4a;
    }

    .section-badge.neutral {
        background: var(--bg2);
        color: var(--ink2);
    }

    /* Badge styles */
    .dept-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
    }

    .sequence-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        white-space: nowrap;
        background: var(--bg2);
        color: var(--ink2);
        border: 1px solid var(--border);
    }

    .emp-avatar {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 12px;
        flex-shrink: 0;
    }

    .mono {
        font-family: monospace;
        font-size: 11px;
        color: var(--ink3);
    }

    /* Button styles */
    .btn-primary {
        display: inline-flex;
        align-items: center;
        padding: 10px 20px;
        background: var(--primary);
        color: white;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        border: none;
        cursor: pointer;
        transition: all 0.15s;
        text-decoration: none;
    }

    .btn-primary:hover {
        background: #134080;
        transform: translateY(-1px);
        box-shadow: 0 4px 8px rgba(26, 79, 160, 0.2);
        color: white;
        text-decoration: none;
    }

    .btn-ghost {
        display: inline-flex;
        align-items: center;
        padding: 10px 20px;
        background: var(--bg2);
        color: var(--ink2);
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-ghost:hover {
        background: var(--border);
        color: var(--ink1);
        text-decoration: none;
    }

    .form-actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        padding: 20px 0;
        border-top: 1px solid var(--border);
        margin-top: 20px;
    }

    /* Page Header */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 24px;
        gap: 16px;
    }

    .page-header-title {
        font-size: 24px;
        font-weight: 600;
        color: var(--ink1);
        margin: 0 0 8px 0;
    }

    .breadcrumb {
        display: flex;
        flex-wrap: wrap;
        padding: 0;
        margin: 0;
        list-style: none;
        gap: 8px;
        font-size: 13px;
    }

    .breadcrumb-item {
        color: var(--ink3);
    }

    .breadcrumb-item a {
        color: var(--primary);
        text-decoration: none;
    }

    .breadcrumb-item a:hover {
        text-decoration: underline;
    }

    .breadcrumb-item.active {
        color: var(--ink2);
        font-weight: 500;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: "/";
        margin-right: 8px;
        color: var(--ink4);
    }

    /* Grid system */
    .row {
        display: flex;
        flex-wrap: wrap;
        margin: -8px;
    }

    .g-3 {
        margin: -8px;
    }

    .g-3 > [class*="col-"] {
        padding: 8px;
    }

    .col-md-3 {
        flex: 0 0 25%;
        max-width: 25%;
    }

    .col-md-4 {
        flex: 0 0 33.333333%;
        max-width: 33.333333%;
    }

    /* CSS Variables */
    :root {
        --ink1: #1a1a1a;
        --ink2: #4a4a4a;
        --ink3: #8a8a8a;
        --ink4: #c0c0c0;
        --border: #e5e5e5;
        --bg2: #f8f8f8;
        --card-bg: #ffffff;
        --primary: #1a4fa0;
        --red-bg: rgba(192, 57, 43, 0.1);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .col-md-3,
        .col-md-4 {
            flex: 0 0 100%;
            max-width: 100%;
        }
        
        .form-actions {
            flex-direction: column-reverse;
        }
        
        .btn-primary,
        .btn-ghost {
            width: 100%;
            justify-content: center;
        }

        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .form-card-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 8px;
        }

        .mono {
            margin-left: 0 !important;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Get form elements
        const codeInput = document.getElementById('Code');
        const nameInput = document.getElementById('Name');
        const accountInput = document.getElementById('AccoutNo');
        const previewBadge = document.getElementById('previewBadge');
        const previewName = document.getElementById('previewName');
        const previewAccount = document.getElementById('previewAccount');
        const previewAvatar = document.getElementById('previewAvatar');

        // Avatar colors array matching index page
        const avatarColors = [
            { bg: "#e8eefa", text: "#1a4fa0" },
            { bg: "#e8f5ee", text: "#1a7a4a" },
            { bg: "#fef3e0", text: "#a05c00" },
            { bg: "#fdecea", text: "#c0392b" },
            { bg: "#f2f2ef", text: "#3a3a38" },
            { bg: "#f0eeff", text: "#4a35c0" }
        ];

        function updatePreview() {
            let code = codeInput ? codeInput.value.trim() : '';
            let name = nameInput ? nameInput.value.trim() : '';
            let account = accountInput ? accountInput.value.trim() : '';
            
            // Use color based on code length for consistency
            let colorIndex = code.length % avatarColors.length;
            let colors = avatarColors[colorIndex];
            
            if (previewBadge) {
                previewBadge.textContent = code || "CODE";
                previewBadge.style.backgroundColor = colors.bg;
                previewBadge.style.color = colors.text;
            }
            
            if (previewName) {
                previewName.textContent = name || "Bank name will appear here";
            }
            
            if (previewAccount) {
                previewAccount.textContent = account || "—";
            }
            
            // Update avatar
            if (previewAvatar) {
                let avatarLetter = code ? code.substring(0, 1).toUpperCase() : "B";
                previewAvatar.textContent = avatarLetter;
                previewAvatar.style.backgroundColor = colors.bg;
                previewAvatar.style.color = colors.text;
            }
        }

        // Add event listeners
        if (codeInput) codeInput.addEventListener('input', updatePreview);
        if (nameInput) nameInput.addEventListener('input', updatePreview);
        if (accountInput) accountInput.addEventListener('input', updatePreview);

        // Format code input to uppercase and replace spaces with underscores
        if (codeInput) {
            codeInput.addEventListener('blur', function() {
                let value = this.value.trim().toUpperCase().replace(/\s+/g, '_');
                this.value = value;
                updatePreview();
            });
        }

        // Track unsaved changes
        const form = document.getElementById('editForm');
        const cancelBtn = document.querySelector('.btn-ghost[asp-action="Index"]');
        let formChanged = false;
        
        if (form) {
            form.addEventListener('input', function() {
                formChanged = true;
            });
        }
        
        if (cancelBtn) {
            cancelBtn.addEventListener('click', function(e) {
                if (formChanged) {
                    if (!confirm('You have unsaved changes. Are you sure you want to leave?')) {
                        e.preventDefault();
                    }
                }
            });
        }
    });
</script>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}