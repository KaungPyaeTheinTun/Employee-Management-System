@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout != null)
    {
        Layout = parentLayout.ToString();
    }
    else
    {
        Layout = "/Areas/Identity/Pages/_Layout.cshtml";
    }
}

<div class="manage-shell">
    <div class="manage-head">
        <h1 class="manage-title">Manage your account</h1>
        <p class="manage-subtitle">Update your profile, login, and security settings.</p>
    </div>

    <div class="manage-grid">
        <aside class="manage-nav-wrap">
            <button type="button" class="manage-nav-toggle" id="manageNavToggle" aria-expanded="false" aria-controls="manageNavPanel">
                <span>Account Menu</span>
                <svg class="manage-nav-toggle-icon" width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                </svg>
            </button>
            <partial name="_ManageNav" />
        </aside>

        <section class="manage-content-card">
            @RenderBody()
        </section>
    </div>
</div>

<style>
    .manage-shell {
        max-width: 1120px;
        margin: 0 auto;
        padding: 8px 4px 20px;
    }

    .manage-head {
        margin-bottom: 16px;
    }

    .manage-title {
        margin: 0;
        font-size: 24px;
        font-weight: 700;
        color: var(--ink);
        letter-spacing: -0.2px;
    }

    .manage-subtitle {
        margin: 6px 0 0;
        font-size: 13px;
        color: var(--ink4);
    }

    .manage-grid {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 16px;
        align-items: start;
    }

    .manage-nav-wrap,
    .manage-content-card {
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: var(--r-lg);
    }

    .manage-nav-wrap {
        padding: 10px;
    }

    .manage-nav-toggle {
        display: none;
        width: 100%;
        border: 1px solid var(--border);
        background: var(--surface2);
        color: var(--ink2);
        border-radius: 10px;
        padding: 10px 12px;
        font-size: 13px;
        font-weight: 600;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 10px;
    }

    .manage-nav-toggle-icon {
        transition: transform 0.2s ease;
    }

    .manage-nav-toggle[aria-expanded="true"] .manage-nav-toggle-icon {
        transform: rotate(180deg);
    }

    .manage-content-card {
        padding: 18px;
    }

    .manage-content-card h3 {
        margin: 0 0 6px;
        font-size: 20px;
        font-weight: 700;
    }

    .manage-content-card h4 {
        margin: 16px 0 8px;
        font-size: 15px;
        font-weight: 600;
        color: var(--ink2);
    }

    .manage-content-card p,
    .manage-content-card li,
    .manage-content-card label {
        color: var(--ink3);
    }

    .manage-content-card .row {
        margin: 0;
    }

    .manage-content-card .col-md-6,
    .manage-content-card .col-md-8,
    .manage-content-card .col-md-9 {
        padding: 0;
    }

    .manage-content-card .text-danger {
        font-size: 12px;
    }

    .manage-content-card .form-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--ink3);
        margin-bottom: 6px;
    }

    .manage-content-card .form-control {
        border: 1px solid var(--border);
        border-radius: 10px;
        min-height: 42px;
        font-size: 13px;
        color: var(--ink2);
        background: var(--surface);
        box-shadow: none;
    }

    .manage-content-card .form-control:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.14);
    }

    .manage-content-card .form-floating > label {
        color: var(--ink4);
    }

    .manage-content-card .form-floating > .form-control:disabled {
        background: var(--bg2);
        opacity: 1;
    }

    .manage-content-card .input-group .btn,
    .manage-content-card .btn {
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        min-height: 40px;
        padding: 8px 14px;
    }

    .manage-content-card .btn-primary {
        border: 0;
        color: #fff;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .manage-content-card .btn-primary:hover {
        color: #fff;
        opacity: 0.95;
    }

    .manage-content-card .btn-danger {
        border: 0;
        color: #fff;
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    }

    .manage-content-card .btn-link {
        font-size: 12px;
        font-weight: 600;
        text-decoration: none;
        color: #4a35c0;
        min-height: auto;
        padding: 0;
    }

    .manage-content-card .btn-link:hover {
        text-decoration: underline;
    }

    .manage-content-card .table {
        border-color: var(--border);
        font-size: 13px;
    }

    .manage-content-card .table th {
        color: var(--ink4);
        font-weight: 600;
    }

    .manage-content-card .alert {
        border-radius: 10px;
        border: 1px solid var(--border);
        font-size: 13px;
    }

    .manage-content-card .alert-success {
        background: #ecfdf5;
        color: #166534;
        border-color: #bbf7d0;
    }

    .manage-content-card .alert-danger {
        background: #fef2f2;
        color: #991b1b;
        border-color: #fecaca;
    }

    @@media (max-width: 900px) {
        .manage-grid {
            grid-template-columns: 1fr;
        }

        .manage-nav-toggle {
            display: flex;
        }

        .manage-nav-wrap #manageNavPanel {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.25s ease;
        }

        .manage-nav-wrap #manageNavPanel.open {
            max-height: 420px;
        }

        .manage-content-card {
            padding: 14px;
        }
    }
</style>

@section Scripts {
    <script>
        (function () {
            var toggle = document.getElementById('manageNavToggle');
            var panel = document.getElementById('manageNavPanel');
            if (!toggle || !panel) return;

            function setExpanded(isExpanded) {
                toggle.setAttribute('aria-expanded', isExpanded ? 'true' : 'false');
                panel.classList.toggle('open', isExpanded);
            }

            function syncByViewport() {
                if (window.innerWidth > 900) {
                    panel.classList.add('open');
                    toggle.setAttribute('aria-expanded', 'true');
                } else {
                    setExpanded(false);
                }
            }

            toggle.addEventListener('click', function () {
                var expanded = toggle.getAttribute('aria-expanded') === 'true';
                setExpanded(!expanded);
            });

            window.addEventListener('resize', syncByViewport);
            syncByViewport();
        })();
    </script>
    @RenderSection("Scripts", required: false)
}
